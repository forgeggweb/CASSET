        cardGrad.addColorStop(1,'rgba(255,230,100,0.95)');
      } else if(hover){
        cardGrad.addColorStop(0,'rgba(255,255,255,0.97)');
        cardGrad.addColorStop(1,'rgba(220,252,231,0.95)');
      } else {
        cardGrad.addColorStop(0,'rgba(255,255,255,0.78)');
