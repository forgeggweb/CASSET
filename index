/* Zona de depósito inicial — el jugador farmea y deposita aquí para craftear la bolsa */
const STARTER_ZONE = {
  x: 3100, y: 1520, r: 70,
  visible: true,
};

function drawStarterZone(ctx, t){
  if(!STARTER_ZONE.visible) return;
  const {x, y, r} = STARTER_ZONE;
  ctx.save();

  // Fondo púrpura radial
  const pulse = 0.5 + Math.sin(t*2)*0.1;
  ctx.globalAlpha = pulse;
  const grad = ctx.createRadialGradient(x,y,r*0.1, x,y,r);
  grad.addColorStop(0,'rgba(168,85,247,0.6)');
  grad.addColorStop(1,'rgba(109,40,217,0.1)');
  ctx.fillStyle = grad;
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();

  // Borde amarillo pulsante y giratorio
  const bp = 0.7 + Math.sin(t*3)*0.3;
  ctx.globalAlpha = bp;
  ctx.strokeStyle = '#fde047';
  ctx.lineWidth = 2.5 + Math.sin(t*3)*1;
  ctx.setLineDash([10,6]);
  ctx.lineDashOffset = -t*22;
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.stroke();
  ctx.setLineDash([]);

  // Etiqueta superior
  ctx.globalAlpha = 0.95;
  ctx.font = 'bold 11px Arial';
  ctx.textAlign = 'center';
  ctx.fillStyle = '#fde047';
  ctx.fillText('\u{1F4E6} Deposit\u{00E1} aqu\u{00ED}', x, y - r - 8);

  // Progreso de recursos depositados dentro de la zona
  const logs    = DROPPED_ITEMS.filter(d=>d.type==='log'    && Math.hypot(d.x-x,d.y-y)<r+20).reduce((s,d)=>s+d.count,0);
  const flowers = DROPPED_ITEMS.filter(d=>d.type==='flower' && Math.hypot(d.x-x,d.y-y)<r+20).reduce((s,d)=>s+d.count,0);
  const logOk    = Math.min(logs,3);
  const flowerOk = Math.min(flowers,2);
  ctx.globalAlpha = 0.95;
  ctx.font = 'bold 12px Arial';
  ctx.textAlign = 'center';

  // Icono de tronco dibujado con canvas (SVG-style) + contador
  ctx.save();
  ctx.translate(x-22, y+6);
  ctx.scale(0.55, 0.55);
  drawSpotIcon(ctx, 'log', t);
  ctx.restore();
  ctx.fillStyle = logOk>=3 ? '#4ade80' : '#e5e7eb';
  ctx.fillText(' ' + logOk + '/3', x-5, y+10);

  // Icono de flor dibujado con canvas (SVG-style) + contador
  ctx.save();
  ctx.translate(x+14, y+20);
  ctx.scale(0.55, 0.55);
  drawSpotIcon(ctx, 'flower', t);
  ctx.restore();
  ctx.fillStyle = flowerOk>=2 ? '#4ade80' : '#e5e7eb';
  ctx.fillText(' ' + flowerOk + '/2', x+30, y+24);

  ctx.restore();
}
function drawDroppedItems(ctx, t){
  for(const di of DROPPED_ITEMS){
    const bob = Math.sin(t*3 + di.bobOffset)*4;
    ctx.save();
    ctx.translate(di.x, di.y + bob);
    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.25)';
    ctx.beginPath();ctx.ellipse(0,14,16,5,0,0,Math.PI*2);ctx.fill();
    // Glow ring
    ctx.strokeStyle='rgba(253,224,71,0.6)';ctx.lineWidth=2;
    ctx.beginPath();ctx.arc(0,0,22,0,Math.PI*2);ctx.stroke();
    // Draw the spot icon for this item type
    drawSpotIcon(ctx, di.type, t + di.bobOffset);
    // Count badge
    if(di.count>1){
      ctx.fillStyle='rgba(0,0,0,0.75)';
      ctx.beginPath();ctx.arc(14,-14,9,0,Math.PI*2);ctx.fill();
      ctx.font='bold 9px Arial';ctx.fillStyle='#fde047';ctx.textAlign='center';
      ctx.fillText('x'+di.count,14,-11);
    }
    // Pickup hint gestionado por HUD
    ctx.restore();
  }
}
function tryPickupDropped(){
  if(!game.player) return;
  for(let i=DROPPED_ITEMS.length-1;i>=0;i--){
    const di=DROPPED_ITEMS[i];
    if(Math.hypot(game.player.x-di.x,game.player.y-di.y)<80){
      for(let c=0;c<di.count;c++) addItem(di.type);
      DROPPED_ITEMS.splice(i,1);
      game._msg(`🎒 ${ITEMS[di.type]?.name||di.type} recogido del suelo`);
      sfx.collect();
    }
  }
}

