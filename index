/* ---- FAUNA ---- */
class Animal {
  constructor(type,x,y){
    this.type=type;this.x=x;this.y=y;this.tx=x;this.ty=y;
    this.frame=Math.random()*20;
    this.speed={deer:70,rabbit:90,bird:110,fox:60,duck:45,butterfly:55}[type]||55;
    this.changeTimer=2+Math.random()*6;this.facingRight=Math.random()>0.5;
    this.flying=(type==='bird'||type==='butterfly');
    this.altitude=this.flying?(-30-Math.random()*40):0;
    this.flapFrame=0;this.home={x,y};
    this.funTimer=0;this.funAnim='none';
    // Extra funny states for animals
    this.laughTimer=0;this.sneezed=false;this.tripped=false;this.tripTimer=0;
  }
  update(dt){
    this.frame+=dt*8;this.changeTimer-=dt;
    // Fauna never triggers animations on their own
    this.funAnim='none'; this.funTimer=0;
    if(this.changeTimer<=0){
      this.changeTimer=2+Math.random()*5;
      const r=80+Math.random()*120,a=Math.random()*Math.PI*2;
      this.tx=Math.max(100,Math.min(WORLD.w-100,this.home.x+Math.cos(a)*r));
      this.ty=Math.max(100,Math.min(WORLD.h-100,this.home.y+Math.sin(a)*r));
    }
    const dx=this.tx-this.x,dy=this.ty-this.y,d=Math.hypot(dx,dy);
    if(d>3){this.x+=dx/d*this.speed*dt;this.y+=dy/d*this.speed*dt;this.facingRight=dx>0;}
    if(this.flying)this.altitude=-30+Math.sin(this.frame*0.5)*15;
    this.flapFrame+=dt*12;
  }
  draw(ctx){
    ctx.save();
    let funOff=0,funRot=0;
    if(this.funAnim==='hop') funOff=-Math.abs(Math.sin(this.frame*6))*14;
    if(this.funAnim==='spin') funRot=this.frame*5;
    if(this.funAnim==='wiggle') funRot=Math.sin(this.frame*12)*0.5;
    if(this.funAnim==='sneeze_anim') funOff=Math.sin(this.frame*20)*3;
    if(this.funAnim==='trip') { funRot=Math.PI*0.4; funOff=8; }
    ctx.translate(this.x, this.y+this.altitude+funOff);
    if(funRot!==0)ctx.rotate(funRot);
    if(!this.facingRight)ctx.scale(-1,1);
    const bob=Math.sin(this.frame*2)*2;ctx.translate(0,bob);
    this._draw(ctx);
    // Funny overlays
    if(this.funAnim==='sneeze_anim'){
      ctx.font='16px Arial';ctx.textAlign='center';ctx.fillText('🤧',-5,-30+this.altitude*-0.3);
    }
    if(this.funAnim==='trip'){
      ctx.font='14px Arial';ctx.textAlign='center';ctx.fillText('💥',15,-10);
    }
    ctx.restore();
  }
  _draw(ctx){
    const t=this.type;
    if(t==='deer'){
      ctx.fillStyle='#c2855a';ctx.beginPath();ctx.ellipse(0,0,16,10,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(18,-6,8,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle='#a0622e';ctx.lineWidth=4;ctx.lineCap='round';
      [[-8,0],[-2,0],[4,0],[10,0]].forEach(([x,y])=>{ctx.beginPath();ctx.moveTo(x,y+8);ctx.lineTo(x+Math.sin(this.frame*2+x)*3,y+22);ctx.stroke();});
      ctx.strokeStyle='#92400e';ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(20,-14);ctx.lineTo(16,-26);ctx.lineTo(10,-22);ctx.stroke();
      ctx.beginPath();ctx.moveTo(20,-14);ctx.lineTo(24,-26);ctx.lineTo(28,-20);ctx.stroke();
      ctx.fillStyle='#fde8d0';ctx.beginPath();ctx.arc(21,-5,3,0,Math.PI*2);ctx.fill();
    } else if(t==='rabbit'){
      ctx.fillStyle='#f1f5f9';
      ctx.beginPath();ctx.ellipse(0,2,9,12,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(0,-10,8,0,Math.PI*2);ctx.fill();
      ctx.fillRect(-5,-26,5,16);ctx.fillRect(1,-26,5,16);
      ctx.fillStyle='#fda4af';ctx.fillRect(-3,-25,3,12);ctx.fillRect(2,-25,3,12);
      ctx.fillStyle='#e2e8f0';ctx.beginPath();ctx.arc(-3,2,3,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(3,2,3,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#000';ctx.beginPath();ctx.arc(-2,-10,2,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(2,-10,2,0,Math.PI*2);ctx.fill();
    } else if(t==='bird'){
      const flap=Math.sin(this.flapFrame)*8;
      ctx.fillStyle='#ef4444';ctx.beginPath();ctx.ellipse(0,0,10,6,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#dc2626';
      ctx.beginPath();ctx.moveTo(-10,0);ctx.lineTo(-20,flap-4);ctx.lineTo(-4,0);ctx.closePath();ctx.fill();
      ctx.beginPath();ctx.moveTo(10,0);ctx.lineTo(20,flap-4);ctx.lineTo(4,0);ctx.closePath();ctx.fill();
      ctx.fillStyle='#fde047';ctx.beginPath();ctx.moveTo(14,0);ctx.lineTo(18,-2);ctx.lineTo(14,2);ctx.closePath();ctx.fill();
      ctx.fillStyle='#000';ctx.beginPath();ctx.arc(12,-1,1.5,0,Math.PI*2);ctx.fill();
    } else if(t==='fox'){
      ctx.fillStyle='#f97316';ctx.beginPath();ctx.ellipse(0,0,14,9,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(16,-5,7,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#fef3c7';ctx.beginPath();ctx.arc(18,-4,4,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#000';ctx.beginPath();ctx.arc(20,-5,1.5,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle='#f97316';ctx.lineWidth=4;ctx.lineCap='round';
      [[-6,6],[0,6],[6,6],[10,5]].forEach(([x,y])=>{ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(x-1,y+14);ctx.stroke();});
      ctx.fillStyle='#f97316';ctx.beginPath();ctx.moveTo(-14,0);ctx.quadraticCurveTo(-30,-8,-26,-22);ctx.quadraticCurveTo(-14,-16,-14,0);ctx.fill();
      ctx.fillStyle='#fef3c7';ctx.beginPath();ctx.ellipse(-24,-18,5,4,-0.5,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#f97316';ctx.beginPath();ctx.moveTo(10,-10);ctx.lineTo(14,-22);ctx.lineTo(18,-10);ctx.closePath();ctx.fill();
      ctx.fillStyle='#fda4af';ctx.beginPath();ctx.moveTo(11,-11);ctx.lineTo(14,-20);ctx.lineTo(17,-11);ctx.closePath();ctx.fill();
    } else if(t==='duck'){
      ctx.fillStyle='#fde047';ctx.beginPath();ctx.ellipse(0,2,12,8,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#86efac';ctx.beginPath();ctx.arc(14,-2,6,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#ef4444';ctx.beginPath();ctx.moveTo(18,-2);ctx.lineTo(23,-1);ctx.lineTo(18,1);ctx.closePath();ctx.fill();
      ctx.fillStyle='#000';ctx.beginPath();ctx.arc(16,-3,1.5,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#fde047';ctx.strokeStyle='#d97706';ctx.lineWidth=2;
      [-4,4].forEach(x=>{ctx.beginPath();ctx.moveTo(x,8);ctx.lineTo(x,18);ctx.stroke();ctx.beginPath();ctx.arc(x,18,4,0,Math.PI);ctx.fill();});
    } else if(t==='butterfly'){
      const flap=Math.sin(this.flapFrame)*12;
      ctx.fillStyle='#f59e0b';ctx.globalAlpha=0.8;
      ctx.beginPath();ctx.moveTo(0,0);ctx.bezierCurveTo(-5,-flap,-20,-flap,-18,6);ctx.bezierCurveTo(-14,10,0,4,0,0);ctx.fill();
      ctx.beginPath();ctx.moveTo(0,0);ctx.bezierCurveTo(5,-flap,20,-flap,18,6);ctx.bezierCurveTo(14,10,0,4,0,0);ctx.fill();
      ctx.globalAlpha=0.6;ctx.fillStyle='#7c3aed';
      ctx.beginPath();ctx.moveTo(0,2);ctx.bezierCurveTo(-3,4,-12,8,-10,12);ctx.bezierCurveTo(-6,14,0,6,0,2);ctx.fill();
      ctx.beginPath();ctx.moveTo(0,2);ctx.bezierCurveTo(3,4,12,8,10,12);ctx.bezierCurveTo(6,14,0,6,0,2);ctx.fill();
      ctx.globalAlpha=1;ctx.fillStyle='#451a03';ctx.beginPath();ctx.ellipse(0,2,2,6,0,0,Math.PI*2);ctx.fill();
    }
  }
}

