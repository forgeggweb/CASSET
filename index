      salinaPositions.forEach(([slx,sly],i)=>{
        if(slx<cx-50||slx>cx+1100/z||sly<cy-50||sly>cy+750/z) return;
        ctx.save();ctx.translate(slx,sly);
        // Mancha de salinas (blanco brillante)
        ctx.fillStyle='rgba(240,250,255,0.55)';
        ctx.beginPath();ctx.ellipse(0,0,35+i*5,18+i*3,i*0.3,0,Math.PI*2);ctx.fill();
        // Cristales de sal pequeños
        ctx.fillStyle='rgba(224,242,254,0.85)';
        const saltOff=i*7;
        [[0,-8],[12,-4],[-10,2],[8,6],[-8,-2]].forEach(([px,py])=>{
          ctx.beginPath();ctx.moveTo(px+saltOff*0.1,py-5);ctx.lineTo(px+4+saltOff*0.1,py);ctx.lineTo(px+saltOff*0.1,py+5);ctx.lineTo(px-4+saltOff*0.1,py);ctx.closePath();ctx.fill();
        });
        ctx.restore();
      });
      // === RUINAS ANTIGUAS ===
      const ruinPositions=[
        [8000,7900],[12700,7500],[10200,1600],
      ];
      ruinPositions.forEach(([rx,ry],i)=>{
        if(rx<cx-80||rx>cx+1200/z||ry<cy-80||ry>cy+800/z) return;
        ctx.save();ctx.translate(rx,ry);ctx.globalAlpha=0.75;
        // Columnas rotas
        const numCols=3+i;
        for(let c=0;c<numCols;c++){
          const cx4=c*28-numCols*14;
          const colH=30+Math.sin(c*2.3+i)*18;
          ctx.fillStyle='#b45309';
          ctx.fillRect(cx4-6,-colH,12,colH+4);
          ctx.fillStyle='#d97706';ctx.fillRect(cx4-6,-colH,12,6);
          ctx.fillStyle='#78350f';ctx.fillRect(cx4-6,-2,12,4);
          // Grietas
          ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;
          ctx.beginPath();ctx.moveTo(cx4-2,-colH*0.6);ctx.lineTo(cx4+1,-colH*0.3);ctx.stroke();
        }
        // Arco derrumbado
        if(i===0||i===2){
          ctx.fillStyle='#b45309';
          ctx.beginPath();ctx.arc(0,-26,22,Math.PI,0);ctx.lineTo(22,-26);ctx.lineTo(-22,-26);ctx.closePath();ctx.fill();
          ctx.fillStyle='rgba(0,0,0,0.2)';
          ctx.beginPath();ctx.arc(0,-26,16,Math.PI,0);ctx.fill();
          ctx.strokeStyle='#78350f';ctx.lineWidth=2;
          ctx.beginPath();ctx.arc(0,-26,22,Math.PI,0);ctx.stroke();
        }
        ctx.globalAlpha=1;
        ctx.restore();
      });
    }
    // === NPC HOUSES — one per actual NPC, no duplicates ===
    (game?.npcs||[]).forEach((npc,i)=>{
      const hp=NPC_HOME_POSITIONS[i];
      if(!hp) return;
      if(hp.x+80<cx-10||hp.x>cx+1100/z||hp.y+70<cy-10||hp.y>cy+750/z) return;
      drawNPCHouse(ctx,hp.x,hp.y,npc.char,t,npc.sleeping);
    });
    for(let i=0;i<400;i++){const gx=(i*312.7+Math.floor(cx/50)*50)%WORLD.w,gy=(i*197.3+Math.floor(cy/50)*50)%WORLD.h;if(gx>cx-30&&gx<cx+1050/z&&gy>cy-30&&gy<cy+730/z&&gx<DESERT_X)drawGroundDetail(ctx,gx,gy,i);}
    drawLake(ctx,t);
    for(const tr of TREES){if(tr.y>cy-100&&tr.y<cy+700/z&&tr.x>cx-100&&tr.x<cx+1200/z){if(tr.y<(this.player?.y||700))drawTree(ctx,tr,t);}}
    for(const sp of SPOTS){if(!sp.hidden){const hover=this.hoveredSpot===sp;if(sp.x+sp.w>cx&&sp.x<cx+1024/z&&sp.y+sp.h>cy&&sp.y<cy+700/z)drawSpot(ctx,sp,hover,t);}}
    // Zona de inicio
    drawStarterZone(ctx, t);
    // Draw placed buildings (behind player)
    for(const bld of PLACED_BUILDINGS){
      if(bld.type==='tent'&&bld.x+bld.w>cx&&bld.x<cx+1024/z&&bld.y+bld.h>cy&&bld.y<cy+700/z){
        if(bld.y+bld.h < (this.player?.y||700)) drawTent(ctx,bld.x,bld.y,t,false,bld.data?.doorAnim||0);
      }
    }
    FAUNA.forEach(a=>{if(a.x>cx-50&&a.x<cx+1100/z&&a.y+a.altitude>cy-60&&a.y+a.altitude<cy+750/z)a.draw(ctx);});
    this.npcs.forEach(n=>{if(n.x>cx-60&&n.x<cx+1100/z&&n.y>cy-60&&n.y<cy+750/z)n.draw(ctx);});
    this.player.draw(ctx);
    // Draw placed buildings (in front of player when behind them)
    for(const bld of PLACED_BUILDINGS){
      if(bld.type==='tent'&&bld.x+bld.w>cx&&bld.x<cx+1024/z&&bld.y+bld.h>cy&&bld.y<cy+700/z){
        if(bld.y+bld.h >= (this.player?.y||700)) drawTent(ctx,bld.x,bld.y,t,false,bld.data?.doorAnim||0);
      }
    }
    // Ghost placement preview
    if(this.ghostMode){
      const gx=this.ghostMouseX/z+cx, gy=this.ghostMouseY/z+cy;
      if(this.ghostMode.itemType==='tent') drawTent(ctx,gx-70,gy-55,t,true,0);
    }
    for(const tr of TREES){if(tr.y>cy-100&&tr.y<cy+700/z&&tr.x>cx-100&&tr.x<cx+1200/z){if(tr.y>=(this.player?.y||700))drawTree(ctx,tr,t);}}
    if(this.weather==='rain'){ctx.strokeStyle='rgba(147,197,253,0.4)';ctx.lineWidth=1;this.rainDrops.forEach(d=>{ctx.beginPath();ctx.moveTo(d.x,d.y);ctx.lineTo(d.x-3,d.y+14);ctx.stroke();});}
    // hover: sutil glow sin rectángulo
    // Draw dropped items on the ground
    drawDroppedItems(ctx, this.t);
    // Draw fog of war on top of everything
    drawFog(ctx, cx, z);
    // Click destination marker
    if(this.clickMarker){
      const cm=this.clickMarker;
      cm.t+=0.07;
      const age=cm.t; // 0→1→fade
      if(age<1){
        const alpha=1-age;
        const r1=(12+age*22); // expanding ring
        const r2=(6+age*10);  // smaller inner ring
        ctx.save();
        ctx.globalAlpha=alpha*0.9;
        // outer ring
        ctx.strokeStyle='#fde047';
        ctx.lineWidth=2;
        ctx.beginPath();ctx.arc(cm.wx,cm.wy,r1,0,Math.PI*2);ctx.stroke();
        // inner ring
        ctx.globalAlpha=alpha*0.6;
        ctx.strokeStyle='#fff';
        ctx.lineWidth=1.5;
        ctx.beginPath();ctx.arc(cm.wx,cm.wy,r2,0,Math.PI*2);ctx.stroke();
        // center dot
        ctx.globalAlpha=alpha;
        ctx.fillStyle='#fde047';
        ctx.beginPath();ctx.arc(cm.wx,cm.wy,3,0,Math.PI*2);ctx.fill();
        // 4 small tick marks
        ctx.strokeStyle='#fde047';
        ctx.lineWidth=2;
        ctx.globalAlpha=alpha*0.8;
        const tickR=r1+6;
        [[0,1],[0,-1],[1,0],[-1,0]].forEach(([dx,dy])=>{
          ctx.beginPath();
          ctx.moveTo(cm.wx+dx*tickR,cm.wy+dy*tickR);
          ctx.lineTo(cm.wx+dx*(tickR+7),cm.wy+dy*(tickR+7));
          ctx.stroke();
        });
        ctx.restore();
      } else {
        this.clickMarker=null;
      }
    }
    ctx.restore();
    const tip=document.getElementById('tip');
    if(this.hoveredSpot){
      const s=this.hoveredSpot;
      tip.style.display='flex';
      tip.style.alignItems='center';
      tip.style.gap='6px';
      tip.style.left=((s.x+s.w/2-this.cam.x)*z-70)+'px';
      tip.style.top=((s.y-this.cam.y)*z-48)+'px';
      if(s.requiresTool){
        const hasTool=_playerHasPickaxe(s.toolTier||1);
        const needed=s.toolTier>=2?'Pico de Hierro':'Pico de Piedra';
        const lockIcon=hasTool?'✅':'🔒';
        const lockMsg=hasTool?'Tenés el pico correcto':'Necesitás '+needed;
        tip.innerHTML=`${itemSVG(s.item,20)}<span>${s.name} — <strong>${lockIcon} ${lockMsg}</strong></span>`;
      } else {
        tip.innerHTML=`${itemSVG(s.item,20)}<span>${s.name} — Clic para ir</span>`;
      }
    }
    else tip.style.display='none';
  }

  drawMiniMap(){
    // Mini-mapa reemplazado por bigmap overlay — no-op
  }
}

/* ================================================================
   CINEMATIC INTRO SYSTEM
   ================================================================ */
const CIN = {
  canvas: null, ctx: null,
  overlay: null, subtitle: null,
  phase: 0,       // 0=fade-in, 1=scene1, 2=scene2 ... 6=fade-out
  t: 0,
  charId: 0,
  char: null,
  running: false,
  raf: null,
  lastT: 0,
  musicCtx: null,
  musicNodes: [],

  /* Subtítulos con timestamps (segundos) */
  subs: [
    {t:0.5,  txt:'Era un día tranquilo en el campo...'},
    {t:3.5,  txt:'Pero algo no estaba bien...'},
    {t:6.5,  txt:'...'},
    {t:8,    txt:'¡Estás en el suelo! ¿Qué pasó?'},
    {t:11,   txt:'*gruñido* Uf... mi cabeza...'},
    {t:14.5, txt:'¡Tienes que levantarte y construir un refugio!'},
    {t:18,   txt:'Primero... recoge recursos del campo.'},
    {t:22,   txt:'Con troncos y piedras podrás craftear tu cabaña.'},
    {t:26.5, txt:'¡Vamos, aventurero! 🌿'},
  ],
  shownSubs: new Set(),

  playMusic(){
    try{
      const ac = new (window.AudioContext||window.webkitAudioContext)();
      this.musicCtx = ac;
      const play=(freq,type,startT,dur,gain=0.18)=>{
        const o=ac.createOscillator(), g=ac.createGain();
        o.type=type; o.frequency.value=freq;
        g.gain.setValueAtTime(0,ac.currentTime+startT);
        g.gain.linearRampToValueAtTime(gain,ac.currentTime+startT+0.05);
        g.gain.linearRampToValueAtTime(gain*0.7,ac.currentTime+startT+dur*0.7);
        g.gain.linearRampToValueAtTime(0,ac.currentTime+startT+dur);
        o.connect(g); g.connect(ac.destination);
        o.start(ac.currentTime+startT); o.stop(ac.currentTime+startT+dur+0.1);
        this.musicNodes.push(o);
      };
      // Melodía cinematográfica lenta
      const melody=[
        [196,0],[220,0.8],[261.6,1.6],[220,2.4],[196,3.2],
        [174.6,4],[196,4.8],[220,5.6],[261.6,6.4],[293.7,7.2],
        [329.6,8],[293.7,9],[261.6,10],[220,11],[196,12],
        [174.6,13],[196,14],[220,15],[261.6,16],[329.6,17],
        [392,18],[349.2,19],[329.6,20],[293.7,21],[261.6,22],
        [220,23],[196,24],[174.6,25],[196,26],[220,27],
        [261.6,28],[220,29],[196,30],[174.6,31],[130.8,32],
      ];
      melody.forEach(([f,s])=>play(f,'sine',s,0.75,0.12));
      // Bajo
      const bass=[
        [65.4,0],[73.4,4],[87.3,8],[73.4,12],[65.4,16],[55,20],[65.4,24],[43.7,28],
      ];
      bass.forEach(([f,s])=>play(f,'triangle',s,3.5,0.08));
      // Shimmer
      for(let i=0;i<16;i++) play(523.3+i*40,'sine',i*2,1.8,0.04);
    }catch(e){}
  },

  stopMusic(){
    try{ if(this.musicCtx) this.musicCtx.close(); }catch(e){}
    this.musicCtx=null; this.musicNodes=[];
  },

  start(charId){
    this.charId=charId;
    this.char=CHARS[charId];
    this.running=true;
    this.t=0;
    this.phase=0;
    this.shownSubs=new Set();
    this.canvas=document.getElementById('cinematic-canvas');
    this.ctx=this.canvas.getContext('2d');
    this.overlay=document.getElementById('cinematic-overlay');
    this.subtitle=document.getElementById('cinematic-subtitle');
    this.overlay.style.display='block';
    this.lastT=performance.now();
    this.playMusic();
    this._loop();
  },

  _loop(){
    if(!this.running) return;
    const now=performance.now();
    const dt=Math.min((now-this.lastT)/1000,0.1);
    this.lastT=now;
    this.t+=dt;
    this._draw(dt);
    this._checkSubs();
    if(this.t>=30) { this.finish(); return; }
    this.raf=requestAnimationFrame(()=>this._loop());
  },

  _checkSubs(){
    for(const s of this.subs){
      if(!this.shownSubs.has(s.t) && this.t>=s.t){
        this.shownSubs.add(s.t);
        this.subtitle.textContent=s.txt;
        this.subtitle.style.opacity='1';
        clearTimeout(this._subTimer);
        this._subTimer=setTimeout(()=>{ if(this.subtitle) this.subtitle.style.opacity='0'; },2500);
      }
    }
  },

  _draw(dt){
    const c=this.ctx, t=this.t, W=1024, H=700;
    c.clearRect(0,0,W,H);

    // === SCENE BACKGROUNDS ===
    // 0-5s: dawn sky (madrugada, personaje tumbado)
    // 5-10s: el personaje empieza a moverse
    // 10-16s: se levanta y mira al cielo
    // 16-22s: se ve el campo, cabaña al fondo
    // 22-28s: zoom out del mapa completo
    // 28-30s: fade to black

    const fadeIn  = Math.min(t/1.5, 1);
    const fadeOut = t>27 ? Math.max(0, 1-(30-t)/3) : 0;

    // Sky gradient — dawn colors
    const skyPhase = Math.min(t/25, 1);
    const skyTop = lerpColor('#0d1b2a','#4f46e5','#f97316', skyPhase);
    const skyBot = lerpColor('#1e293b','#7c3aed','#fde68a', skyPhase);
    const sg=c.createLinearGradient(0,0,0,H);
    sg.addColorStop(0, skyTop); sg.addColorStop(1, skyBot);
    c.fillStyle=sg; c.fillRect(0,0,W,H);

    // Stars (fade out as day breaks)
    const starAlpha = Math.max(0, 1-skyPhase*2);
    if(starAlpha>0){
      c.fillStyle=`rgba(255,255,255,${starAlpha*0.9})`;
      for(let i=0;i<80;i++){
        const sx=(i*137.5)%W, sy=(i*89.3)%300;
        const tw=Math.sin(t*2+i*1.3)*0.5+0.5;
        c.globalAlpha=starAlpha*tw;
        c.beginPath(); c.arc(sx,sy,1+Math.sin(t+i)*0.5,0,Math.PI*2); c.fill();
      }
      c.globalAlpha=1;
    }

    // Moon (early scene)
    if(t<12){
      const moonA=Math.max(0, 1-t/10);
      c.globalAlpha=moonA;
      c.fillStyle='#e0e7ff'; c.beginPath(); c.arc(820,60,20,0,Math.PI*2); c.fill();
      c.fillStyle='rgba(13,27,42,0.6)'; c.beginPath(); c.arc(828,55,16,0,Math.PI*2); c.fill();
      c.globalAlpha=1;
    }

    // Sun rising
    if(t>10){
      const sunRise=Math.min((t-10)/15,1);
      const sunY=120-sunRise*80; const sunA=sunRise;
      const grd=c.createRadialGradient(180,sunY,5,180,sunY,90);
      grd.addColorStop(0,`rgba(253,224,71,${sunA*0.5})`);
      grd.addColorStop(1,'rgba(253,224,71,0)');
      c.fillStyle=grd; c.fillRect(90,sunY-90,180,180);
      c.globalAlpha=sunA;
      c.fillStyle='#fde047'; c.beginPath(); c.arc(180,sunY,28,0,Math.PI*2); c.fill();
      c.globalAlpha=1;
    }

    // Ground / campo
    c.fillStyle='#14532d'; c.fillRect(0,420,W,H-420);
    c.fillStyle='#15803d';
    c.beginPath(); c.moveTo(0,420);
    for(let x=0;x<=W;x+=12) c.lineTo(x, 420+Math.sin(x*0.01+t*0.2)*18+Math.sin(x*0.02+t*0.1)*8);
    c.lineTo(W,H); c.lineTo(0,H); c.closePath(); c.fill();

    // Trees silhouette (background)
    c.fillStyle='rgba(5,60,15,0.7)';
    for(let i=0;i<12;i++){
      const tx=50+i*80+Math.sin(i*2.3)*20, th=80+Math.sin(i*1.7)*30;
      c.beginPath(); c.moveTo(tx,420); c.lineTo(tx+20,420-th); c.lineTo(tx+40,420); c.closePath(); c.fill();
    }

    // Improvised cabin silhouette (far right)
    if(t>14){
      const cabA=Math.min((t-14)/4,1);
      c.globalAlpha=cabA*0.85;
      const cx=700, cy=390, cw=120, ch=80;
      c.fillStyle='#5c3317'; c.fillRect(cx,cy,cw,ch);
      // Roof
      c.fillStyle='#4a2c0e';
      c.beginPath(); c.moveTo(cx-10,cy); c.lineTo(cx+cw/2,cy-45); c.lineTo(cx+cw+10,cy); c.closePath(); c.fill();
      // Window glow
      c.fillStyle='rgba(253,224,71,0.4)';
      c.fillRect(cx+20,cy+15,28,22); c.fillRect(cx+cw-48,cy+15,28,22);
      c.globalAlpha=1;
    }

    // ====== CHARACTER — tumbado, despertando ======
    const charCX = t<18 ? 420 : 420+(t-18)*20;
    const charCY = 440;

    c.save();
    c.translate(charCX, charCY);

    if(t<7){
      // Fase 1: acostado boca arriba, inconsciente
      const breathe = Math.sin(t*1.8)*0.5;
      c.rotate(Math.PI*0.5); // tumbado
      c.translate(0, breathe);
      drawChar(c, this.char, t*2, 'idle', true, false, 1.3, 'fall');

      // ZZZs flotando
      const zzAlpha = Math.min(t/2,1);
      c.globalAlpha=zzAlpha;
      c.font='bold 16px Arial'; c.fillStyle='#93c5fd'; c.textAlign='center';
      [['Z',  -30 + Math.sin(t*0.7)*5,   -70+t*2],
       ['z',  -10 + Math.sin(t*0.9)*4,   -85+t*1.6],
       ['Z',   10 + Math.sin(t*1.1)*3,   -100+t*1.2]].forEach(([z,zx,zy])=>{
        if(zy > -120 && zy < -40) c.fillText(z, zx, zy);
      });
      c.globalAlpha=1;

    } else if(t<11){
      // Fase 2: se mueve, se retuerce
      const wk=(t-7)/4;
      const rotAng=Math.PI*0.5 - wk*Math.PI*0.5;
      c.rotate(rotAng);
      const wobble=Math.sin(t*6)*0.08*(1-wk);
      c.rotate(wobble);
      const liftY = wk*20;
      c.translate(0, -liftY);
      drawChar(c, this.char, t*4, 'idle', true, false, 1.3, t>9?'wiggle':'fall');

      // Partículas de despertar
      if(Math.random()<0.3){
        c.font='18px Arial'; c.textAlign='center'; c.globalAlpha=0.8;
        const stars=['✨','💫','⭐'];
        c.fillText(stars[Math.floor(Math.random()*3)], (Math.random()-0.5)*80, -60-Math.random()*40);
        c.globalAlpha=1;
      }

    } else if(t<16){
      // Fase 3: de pie, mirando alrededor con asombro
      const lookAround=Math.sin(t*0.8)*0.15;
      c.rotate(lookAround);
      const bounceY=-Math.abs(Math.sin((t-11)*2))*8;
      c.translate(0, bounceY);
      drawChar(c, this.char, t*3, 'idle', t%4<2, false, 1.4,
        t>13 ? 'celebrate' : 'dizzy');

      // Burbuja de pensamiento
      if(t>12 && t<15.5){
        c.save();
        const bx=60, by=-90;
        c.fillStyle='rgba(0,0,0,0.8)';
        rr(c, bx-50, by-18, 130, 36, 12); c.fill();
        c.strokeStyle='rgba(253,224,71,0.8)'; c.lineWidth=1.5; c.stroke();
        c.font='bold 13px Arial'; c.fillStyle='#fde047'; c.textAlign='center';
        c.fillText(t<14?'¿D... dónde estoy?':'¡Tengo que construir!', bx+15, by+7);
        c.restore();
      }

    } else {
      // Fase 4: corriendo / explorando
      const runT = (t-16)*2;
      c.translate(Math.sin(t)*3, -Math.abs(Math.sin(t*6))*5);
      drawChar(c, this.char, runT, 'walk', true, false, 1.4, 'celebrate');
    }

    c.restore();

    // Grass details cerca del personaje
    c.fillStyle='#22c55e';
    for(let i=0;i<20;i++){
      const gx=(i*61+200)%600+100;
      const gh=8+Math.sin(i*1.7+t*0.5)*4;
      c.fillRect(gx, 435, 3, -gh);
    }

    // Overlay de fade-in / fade-out
    const totalAlpha = Math.max(0, Math.min(1, (1-fadeIn) + fadeOut));
    if(totalAlpha>0){
      c.fillStyle=`rgba(0,0,0,${totalAlpha})`;
      c.fillRect(0,0,W,H);
    }
  },

  finish(){
    this.running=false;
    cancelAnimationFrame(this.raf);
    this.stopMusic();
    clearTimeout(this._subTimer);
    if(this.overlay) this.overlay.style.display='none';
    // Iniciar juego real
    game.start(this.charId);
    // Pequeño delay y luego tutorial
    setTimeout(()=>tutorialStart(), 1200);
  }
};

function lerpColor(a,b,c, t){
  // t in [0,1]: lerps a->b for t in [0,0.5], b->c for t in [0.5,1]
  const hex2r=h=>{const r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),bl=parseInt(h.slice(5,7),16);return[r,g,bl];};
  const lerp1=(c1,c2,f)=>c1.map((v,i)=>Math.round(v+(c2[i]-v)*f));
  const toHex=([r,g,b])=>'#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
  const c1=hex2r(a),c2=hex2r(b),c3=hex2r(c);
  if(t<0.5) return toHex(lerp1(c1,c2,t*2));
  return toHex(lerp1(c2,c3,(t-0.5)*2));
}

function skipCinematic(){
  if(!CIN.running) return;
  CIN.finish();
}

