  addFuel(type){
    if(!(inventory[type]>0)){this._msg('¡No tienes '+ITEMS[type].name+'!');return;}
    inventory[type]--;
    updateInventoryUI();
    const gain = type==='log' ? 30 : type==='volcanic' ? 45 : type==='tumbleweed' ? 20 : 60; // coal=60s, volcanic=45s, log=30s, tumbleweed=20s
    campfire.fuel = Math.min(campfire.maxFuel, campfire.fuel + gain);
    if(!campfire.lit){ campfire.lit=true; sfx.fireCrackle(); this._msg('🔥 ¡Fogata encendida!'); }
    else { sfx.boing(); this._msg('🔥 Combustible añadido (+'+gain+'s)'); }
    this._updateCampUI();
    this._refreshRecipeGrid();
  }
  cookRecipe(recipeId){
    if(!campfire.lit || campfire.fuel<=0){ this._msg('⚠️ La fogata está apagada'); return; }
    if(campfire.cooking){ this._msg('⏳ Ya hay algo cocinándose'); return; }
    const r=RECIPES.find(x=>x.id===recipeId);
    if(!r) return;
    // check ingredients
    for(const [item,qty] of Object.entries(r.ingredients)){
      if((inventory[item]||0)<qty){ this._msg('❌ Faltan ingredientes: '+ITEMS[item].emoji+' x'+qty); return; }
    }
    // consume ingredients
    for(const [item,qty] of Object.entries(r.ingredients)) inventory[item]-=qty;
    updateInventoryUI();
    campfire.cooking={recipe:r, progress:0, total:r.time};
    sfx.chirp();
    this._msg('🍳 Cocinando: '+r.name+'...');
    this._updateCampUI();
    this._refreshRecipeGrid();
  }
  _updateCampFireState(dt){
    if(campfire.lit && campfire.fuel>0){
      campfire.fuel=Math.max(0,campfire.fuel-dt);
      if(campfire.fuel<=0){
        campfire.lit=false;
        this._msg('💨 La fogata se apagó');
        if(campfire.cooking){ campfire.cooking=null; this._msg('❌ Cocción cancelada: sin combustible'); }
        if(document.getElementById('camp-panel').style.display==='block'){ this._updateCampUI(); this._refreshRecipeGrid(); }
      }
    }
    if(campfire.cooking){
      campfire.cooking.progress+=dt;
      if(campfire.cooking.progress>=campfire.cooking.total){
        const r=campfire.cooking.recipe;
        addItem(r.id);
        if(this.player){ this.player.money+=r.value; document.getElementById('vm').textContent='$'+Math.floor(this.player.money); document.getElementById('inv-money-val').textContent=Math.floor(this.player.money); }
        sfx.cookDone();
        this._msg('✅ '+r.emoji+' '+r.name+' lista! +$'+r.value);
        campfire.cooking=null;
        if(this.player) this.player.danceTimer=2;
        if(document.getElementById('camp-panel').style.display==='block'){ this._updateCampUI(); this._refreshRecipeGrid(); }
      }
    }
    // update progress bar only if panel open
    if(document.getElementById('camp-panel').style.display==='block') this._updateCampUI();
  }
  _updateCampUI(){
    const pct=campfire.fuel/campfire.maxFuel*100;
    document.getElementById('fuel-bar-fill').style.width=pct+'%';
    document.getElementById('fuel-pct').textContent=Math.round(pct)+'%';
    // status text
    const statusEl=document.getElementById('camp-panel-status');
    if(campfire.lit) statusEl.textContent='🔥 Encendida — '+Math.ceil(campfire.fuel)+'s de combustible';
    else statusEl.textContent='💨 Apagada — agrega tronco o carbón para encender';
    // fuel button counts
    document.getElementById('log-count').textContent='(x'+(inventory.log||0)+')';
    document.getElementById('coal-count').textContent='(x'+(inventory.coal||0)+')';
    document.getElementById('btn-add-log').disabled=!(inventory.log>0);
    document.getElementById('btn-add-coal').disabled=!(inventory.coal>0);
    const volcBtn=document.getElementById('btn-add-volcanic');
    if(volcBtn){document.getElementById('volcanic-count').textContent='(x'+(inventory.volcanic||0)+')';volcBtn.disabled=!(inventory.volcanic>0);}
    // progress bar only (don't rebuild recipe grid every frame)
    const pw=document.getElementById('cook-progress-wrap');
    if(campfire.cooking){
      pw.style.display='block';
      const cp=campfire.cooking.progress/campfire.cooking.total*100;
      document.getElementById('cook-progress-fill').style.width=cp+'%';
      document.getElementById('cook-progress-txt').textContent=campfire.cooking.recipe.name+' — '+Math.ceil(campfire.cooking.total-campfire.cooking.progress)+'s';
      document.getElementById('cook-progress-title').textContent='⏳ Cocinando '+campfire.cooking.recipe.emoji;
    } else {
      pw.style.display='none';
    }
  }
  _refreshRecipeGrid(){
    // Only call this when campfire state meaningfully changes (lit/unlit, cooking start/end, fuel added)
    this._buildRecipeGrid();
  }
  _buildRecipeGrid(){
    const grid=document.getElementById('recipe-grid');
    if(!grid) return;
    grid.innerHTML='';
    const isLit=campfire.lit && campfire.fuel>0;
    const isCooking=!!campfire.cooking;
    RECIPES.forEach(r=>{
      const canAfford=Object.entries(r.ingredients).every(([item,qty])=>(inventory[item]||0)>=qty);
      const locked=!isLit||isCooking||!canAfford;
      const card=document.createElement('div');
      card.className='recipe-card'+(locked?' locked':'');
      // ingredient list display
      const ingList=Object.entries(r.ingredients).map(([item,qty])=>`${itemSVG(item,16)} x${qty}`).join(' ');
      card.innerHTML=`<span class="rc-icon">${itemSVG(r.id,28)}</span><div class="rc-name">${r.name}</div><div class="rc-ing" style="display:flex;gap:4px;flex-wrap:wrap;justify-content:center;align-items:center">${ingList}</div><div class="rc-time">⏱ ${r.time}s</div><div class="rc-val">💰 +$${r.value}</div>`;
      if(!locked) card.onclick=()=>this.cookRecipe(r.id);
      else if(!isLit) card.title='Enciende la fogata primero';
      else if(isCooking) card.title='Espera a que termine la cocción';
      else card.title='Ingredientes insuficientes: '+r.desc;
      grid.appendChild(card);
    });
  }
  interact(){
    if(!this.player||this.player.state==='interact')return;
    // Check placed buildings first — generosa distancia de 200px
    for(const bld of PLACED_BUILDINGS){
      const d=Math.hypot(this.player.x-(bld.x+bld.w/2),this.player.y-(bld.y+bld.h));
      if(d<200){
        if(bld.type==='tent') this.openShopInterior();
        else this.openCabinInterior();
        return;
      }
    }
    let best=null,bd=Infinity;
    for(const s of SPOTS){const d=Math.hypot(this.player.x-(s.x+s.w/2),this.player.y-(s.y+s.h/2));if(d<bd){bd=d;best=s;}}
    if(best&&bd<200)this.player.goToSpot(best);
    else this._msg('Acércate a un punto de interés 🌿');
  }

