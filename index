  zoomOut(){
    this.targetZoom=Math.max(0.4, this.targetZoom-0.25);
    this._updateZoomUI();
  }
  zoomReset(){
    this.targetZoom=1;
    this._updateZoomUI();
  }
  _updateZoomUI(){
    document.getElementById('zoom-level').textContent=Math.round(this.targetZoom*100)+'%';
  }

  toggleInventory(){
    this.invOpen=!this.invOpen;
    const overlay=document.getElementById('inv-overlay');
    const btn=document.getElementById('inv-toggle');
    if(this.invOpen){
      this._hookInventoryPlaceables();
      overlay.style.display='flex';
      btn.classList.add('active');
      btn.textContent='🎒 Cerrar';
      // update char name
      const nameEl=document.getElementById('inv-char-name');
      if(nameEl&&this.player) nameEl.textContent=this.player.char.name;
      updateEquipBar();
      updateInventoryUI();
      // start char animation loop
      this._startInvCharAnim();
    } else {
      overlay.style.display='none';
      btn.classList.remove('active');
      btn.textContent='🎒 Inventario';
      this._stopInvCharAnim();
    }
  }
  _startInvCharAnim(){
    if(this._invCharRaf) return;
    const cvs=document.getElementById('inv-char-canvas');
    if(!cvs||!this.player) return;
    const ctx=cvs.getContext('2d');
    let t=0;
    const loop=(ts)=>{
      t=ts/1000;
      ctx.clearRect(0,0,130,160);
      ctx.save();
      ctx.translate(65,140);
      ctx.scale(1.5,1.5);
      drawChar(ctx,this.player.char,t*8,'idle',true,true,1,'none',false);
      ctx.restore();
      this._invCharRaf=requestAnimationFrame(loop);
    };
    this._invCharRaf=requestAnimationFrame(loop);
  }
  _stopInvCharAnim(){
    if(this._invCharRaf){ cancelAnimationFrame(this._invCharRaf); this._invCharRaf=null; }
  }
  onAlbSlotClick(slotId){
    const slot=EQUIP_SLOTS[slotId];
    if(!slot) return;
    if(slot.item){
      // unequip: return item to inventory
      const type=slot.item;
      inventory[type]=(inventory[type]||0)+1;
