/* ---- NPC ---- */
class FieldNPC {
  constructor(index, charId){
    // charId is the explicit CHARS index to use (no repeats)
    const c = CHARS[charId !== undefined ? charId : index % CHARS.length];
    this.char=c;
    this.npcIndex = index||0;
    // Assign home
    const hp = NPC_HOME_POSITIONS[this.npcIndex % NPC_HOME_POSITIONS.length];
    this.homeX = hp.x + 40; // center of house
    this.homeY = hp.y + 60;
    // Start near home
    this.x = this.homeX + (Math.random()-0.5)*100;
    this.y = this.homeY + (Math.random()-0.5)*100;
    // Keep away from lakes
    let tries=0;
    while(tries++<20 && ALL_LAKES.some(lk=>Math.hypot(this.x-lk.cx,this.y-lk.cy)<300)){
      this.x=this.homeX+(Math.random()-0.5)*200;this.y=this.homeY+(Math.random()-0.5)*200;
    }
    this.tx=this.x;this.ty=this.y;this.frame=Math.random()*20;
    this.speed=35+Math.random()*30;
    this.facingRight=true;this.changeTimer=3+Math.random()*6;
    this.thought='';this.thoughtTimer=0;
    this.state='idle';
    this.danceTimer=0;this.spinAngle=0;
    this.funnyAnim='none';this.funnyTimer=0;
    // Routine
    this.routinePhase='idle';
    this.routineTimer=0;
    this.sleeping=false;
    this.socialTarget=null; // index of NPC being talked to
    this.socialTimer=0;
    this.isHome=false;
    this.walkTimer=2+Math.random()*4;
  }

  _getRoutinePhase(gameTime){
    const h=gameTime/60;
    if(h>=22||h<6) return 'sleep';
    if(h>=6&&h<10) return 'morning';
    if(h>=10&&h<14) return 'midday';
    if(h>=14&&h<18) return 'afternoon';
    return 'evening';
  }

  _getRoutineTarget(phase){
    const list = NPC_ROUTINE_SPOTS[phase] || NPC_ROUTINE_SPOTS.midday;
    const base = list[this.npcIndex % list.length];
    return {x: base.x+(Math.random()-0.5)*200, y: base.y+(Math.random()-0.5)*200};
  }

  update(dt){
    const gameTime = game ? game.gameTime : 600;
    const phase = this._getRoutinePhase(gameTime);
    this.frame+=dt*8;
    this.changeTimer-=dt;
    this.walkTimer-=dt;
    this.funnyAnim='none'; this.funnyTimer=0;
    if(this.danceTimer>0){this.danceTimer-=dt;this.state='dance';}
    if(this.socialTimer>0){
      this.socialTimer-=dt;
      if(this.socialTimer<=0) this.socialTarget=null;
    }

    // === ROUTINE LOGIC ===
    if(phase==='sleep'){
      this.sleeping=true;
      this.isHome=true;
      // Walk home
      const hdist=Math.hypot(this.tx-this.homeX, this.ty-this.homeY);
      if(hdist>80){this.tx=this.homeX;this.ty=this.homeY;}
      this.state='idle';
    } else {
      this.sleeping=false;
      this.isHome=false;
      // Routine phase changed?
      if(phase!==this.routinePhase){
        this.routinePhase=phase;
        this.routineTimer=0;
        const tgt=this._getRoutineTarget(phase);
        this.tx=Math.max(80,Math.min(WORLD.w-80,tgt.x));
        this.ty=Math.max(80,Math.min(WORLD.h-80,tgt.y));
        this.state='walk';
      }
      this.routineTimer+=dt;

      // Periodic wandering within routine zone
      if(this.changeTimer<=0 && this.danceTimer<=0){
        this.changeTimer=4+Math.random()*8;
        const chance=Math.random();
        if(chance<0.5){
          // Local wander
          const r=80+Math.random()*120,a=Math.random()*Math.PI*2;
          const tgt=this._getRoutineTarget(phase);
          this.tx=Math.max(80,Math.min(WORLD.w-80,tgt.x+Math.cos(a)*r));
          this.ty=Math.max(80,Math.min(WORLD.h-80,tgt.y+Math.sin(a)*r));
          this.state='walk';
        } else if(chance<0.7){
          // Return to home briefly
          this.tx=this.homeX+(Math.random()-0.5)*60;
          this.ty=this.homeY+(Math.random()-0.5)*60;
          this.state='walk';
        }
        // Thoughts — each character speaks in their own voice
        if(Math.random()<0.3){
          const v=getVoice(this.char.trait);
          const list=v.idle;
          this.thought=list[Math.floor(Math.random()*list.length)];
          this.thoughtTimer=2.5;
        }
      }

      // === SOCIAL INTERACTION ===
      if(Math.random()<0.008 && this.socialTarget===null && game?.npcs){
        // Find a nearby NPC to talk to
        for(let i=0;i<game.npcs.length;i++){
          const other=game.npcs[i];
          if(other===this||other.sleeping) continue;
          const d=Math.hypot(this.x-other.x, this.y-other.y);
          if(d<200 && d>30){
            this.socialTarget=i;
            this.socialTimer=3+Math.random()*4;
            const myV=getVoice(this.char.trait); const otherV=getVoice(other.char.trait);
            this.thought=myV.social[Math.floor(Math.random()*myV.social.length)];this.thoughtTimer=2;
            other.thought=otherV.social[Math.floor(Math.random()*otherV.social.length)];other.thoughtTimer=2;
            if(Math.random()<0.4){this.danceTimer=1.5;other.danceTimer=1.5;}
            this.facingRight=(other.x>this.x);
            other.facingRight=(this.x>other.x);
            break;
          }
        }
      }
    }

    // Move toward target
    if(this.danceTimer<=0 && !this.sleeping){
      const dx=this.tx-this.x,dy=this.ty-this.y,d=Math.hypot(dx,dy);
      if(d>5){this.x+=dx/d*this.speed*dt;this.y+=dy/d*this.speed*dt;this.facingRight=dx>0;this.state='walk';}
      else if(this.danceTimer<=0) this.state='idle';
    }
    this.thoughtTimer-=dt;
  }

  draw(ctx){
    if(this.sleeping) return; // hidden inside house
    ctx.save();ctx.translate(this.x,this.y);
    if(this.state==='dance'){
      const bounce=-Math.abs(Math.sin(this.frame*4))*8;
      ctx.translate(0,bounce);
    }
    const animState=this.state==='dance'?'dance':(this.funnyAnim==='none'?this.state:this.funnyAnim);
    drawChar(ctx,this.char,this.frame,animState,this.facingRight,false,0.75,this.funnyAnim!=='none'?this.funnyAnim:'none');
    // Social connection line
    if(this.socialTarget!==null && game?.npcs){
      const other=game.npcs[this.socialTarget];
      if(other && !other.sleeping){
        ctx.strokeStyle='rgba(253,224,71,0.4)';ctx.lineWidth=1.5;ctx.setLineDash([4,4]);
        ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(other.x-this.x,other.y-this.y);ctx.stroke();
        ctx.setLineDash([]);
      }
    }
    ctx.restore();
    if(this.thoughtTimer>0) bubble(ctx,this.x,this.y-68,this.thought,'#ffffcc');
    ctx.fillStyle='rgba(0,0,0,0.6)';ctx.strokeStyle='rgba(255,255,0,0.5)';ctx.lineWidth=1;
    ctx.font='bold 10px Arial';ctx.textAlign='center';
    const nw=ctx.measureText(this.char.name).width+8;
    rr(ctx,this.x-nw/2,this.y-72,nw,14,3);ctx.fill();ctx.stroke();
    ctx.fillStyle='#fff';ctx.fillText(this.char.name,this.x,this.y-62);
    // Phase indicator
    const phaseEmoji={morning:'🌅',midday:'☀️',afternoon:'🌤️',evening:'🌆',sleep:'😴'}[this.routinePhase]||'';
    if(phaseEmoji){ctx.font='10px Arial';ctx.textAlign='center';ctx.fillText(phaseEmoji,this.x+nw/2+2,this.y-62);}
  }
}

/* ---- PLAYER ---- */
class Player {
  constructor(charId){
    this.char=CHARS[charId];Object.assign(this,this.char);
    this.x=3100;this.y=1600;this.tx=this.x;this.ty=this.y;
    this.state='idle';this.frame=0;this.facingRight=true;this.speed=160;
    this.money=0;
    this.thought='';this.thoughtTimer=0;
    this.particles=[];this.interactTarget=null;this.interactTimer=0;
    this.jumpVel=0;this.jumpY=0;this.isJumping=false;
    this.danceTimer=0;
    // Funny anim
    this.funnyAnim='none';this.funnyTimer=0;
    this.carriedItem=null; // item sostenido en la mano
  }
  say(t){this.thought=t;this.thoughtTimer=3;}
  doJump(){if(!this.isJumping){this.isJumping=true;this.jumpVel=-12;sfx.funnyBounce();}}
  setFunnyAnim(anim,dur=3){
    this.funnyAnim=anim;this.funnyTimer=dur;
    sfx.silly();
    const _va=getVoice(this.char.trait);
    this.say(_va.anim[Math.floor(Math.random()*_va.anim.length)]);
  }
  update(dt){
    this.frame+=dt*10;
    this.thoughtTimer-=dt;
    // Jump physics
    if(this.isJumping){
      this.jumpVel+=40*dt;this.jumpY+=this.jumpVel;
      if(this.jumpY>=0){this.jumpY=0;this.isJumping=false;this.jumpVel=0;}
    }
    // Funny timer
    if(this.funnyTimer>0){this.funnyTimer-=dt;}
    else this.funnyAnim='none';
    // Dance
    if(this.danceTimer>0){this.danceTimer-=dt;this.state='dance';}
    if(this.state==='walk'){
      const dx=this.tx-this.x,dy=this.ty-this.y,d=Math.hypot(dx,dy);
      if(d<4){
        this.x=this.tx;this.y=this.ty;
        if(this.interactTarget){this.startInteract(this.interactTarget);}
        else this.state='idle';
      } else {
        this.x+=dx/d*this.speed*dt;this.y+=dy/d*this.speed*dt;
        this.facingRight=dx>0;
        if(Math.floor(this.frame)%4===0) sfx.step();
      }
    } else if(this.state==='interact'){
      this.interactTimer-=dt;
      if(Math.random()<0.12) this.particles.push({x:this.x+(Math.random()-.5)*20,y:this.y-40,t:this.interactTarget?.emoji||'✨',life:1,vy:-45,vx:(Math.random()-.5)*30,sz:16,rot:Math.random()*Math.PI*2});
      if(this.interactTimer<=0) this.finishInteract();
    }
    this.particles.forEach(p=>{p.life-=dt*0.7;p.y+=p.vy*dt;p.x+=p.vx*dt;p.rot=(p.rot||0)+dt*4;});
    this.particles=this.particles.filter(p=>p.life>0);
    if(Math.random()<0.003){
      const v=getVoice(this.char.trait);
      this.say(v.idle[Math.floor(Math.random()*v.idle.length)]);
    }
  }
  moveTo(x,y){if(this.state==='interact'){this.state='idle';this.interactTarget=null;}this.tx=x;this.ty=y;this.state='walk';this.interactTarget=null;}
  goToSpot(spot){if(this.state==='interact'){this.state='idle';this.interactTarget=null;}this.interactTarget=spot;this.tx=spot.x+spot.w/2;this.ty=spot.y+spot.h+10;this.state='walk';}
  startInteract(spot){
    this.state='interact';this.interactTimer=2.5;
    sfx.boing();this.say(spot.emoji+' ...');
    this.doJump();
  }
  finishInteract(){
    const s=this.interactTarget;
    if(!s){this.state='idle';return;}
    let money=0;
    let itemType=null;
    if(s.type==='cabin') {
      this.state='idle';this.interactTarget=null;
      game.openCabinInterior();
      return;
    }
    if(s.type==='fish')  {money=0;sfx.splash();this.say(getVoice(this.char.trait).res.fish||'🐟');itemType='fish';}
    else if(s.type==='apple'){money=0;sfx.eat();this.say(getVoice(this.char.trait).res.apple||'🍎');itemType='apple';}
    else if(s.type==='shroom'){money=0;sfx.rustle();this.say(getVoice(this.char.trait).res.shroom||'🍄');itemType='shroom';}
    else if(s.type==='flower'){money=0;sfx.chirp();this.say(bagEquipped?(getVoice(this.char.trait).res.flower||'🌸'):(getVoice(this.char.trait).res.flower||'🌸')+' ×2 needed');itemType='flower';}
    else if(s.type==='gem')  {money=0;sfx.coin();this.say(getVoice(this.char.trait).res.gem||'💎');itemType='gem';}
    else if(s.type==='honey'){money=0;sfx.eat();this.say(getVoice(this.char.trait).res.honey||'🍯');itemType='honey';}
    else if(s.type==='spring'){sfx.splash();this.say(getVoice(this.char.trait).res.spring||'💧');itemType='water';}
    else if(s.type==='log'){money=0;sfx.rustle();this.say(getVoice(this.char.trait).res.log||'🪵');itemType='log';}
    else if(s.type==='coal'){money=0;sfx.rustle();this.say(getVoice(this.char.trait).res.coal||'🪨');itemType='coal';}
    else if(s.type==='stone'){sfx.rustle();this.say(getVoice(this.char.trait).res.stone||'🪨');itemType='stone';}
    else if(s.type==='granite'){sfx.rustle();this.say(getVoice(this.char.trait).res.granite||'🪨');itemType='granite';}
    else if(s.type==='quartz'){sfx.coin();this.say(getVoice(this.char.trait).res.quartz||'💠');itemType='quartz';}
    else if(s.type==='volcanic'){sfx.rustle();this.say(getVoice(this.char.trait).res.volcanic||'🔴');itemType='volcanic';}
    else if(s.type==='clay_red'){sfx.rustle();this.say(getVoice(this.char.trait).res.clay_red||'🟫');itemType='clay_red';}
    else if(s.type==='clay_gray'){sfx.rustle();this.say(getVoice(this.char.trait).res.clay_gray||'🩶');itemType='clay_gray';}
    else if(s.type==='cactus'){sfx.eat();this.say(getVoice(this.char.trait).res.cactus||'🌵');itemType='cactus_fruit';}
    else if(s.type==='salt_crystal'){sfx.coin();this.say(getVoice(this.char.trait).res.salt||'🧂');itemType='salt_crystal';}
    else if(s.type==='fossil'){sfx.coin();this.say(getVoice(this.char.trait).res.fossil||'🦕');itemType='fossil';}
    else if(s.type==='desert_gem'){sfx.coin();this.say(getVoice(this.char.trait).res.desert_gem||'💛');itemType='desert_gem';}
    else if(s.type==='bone'){sfx.rustle();this.say(getVoice(this.char.trait).res.bone||'🦴');itemType='bone';}
    else if(s.type==='tumbleweed'){sfx.rustle();this.say(getVoice(this.char.trait).res.tumbleweed||'🌾');itemType='tumbleweed';}
    else if(s.type==='ancient_coin'){sfx.coin();this.say(getVoice(this.char.trait).res.ancient_coin||'🪙');itemType='ancient_coin';}
    // --- MINERALES SUELTOS ---
    else if(s.type==='iron_nugget'){sfx.rustle();this.say('🔩 Pepita de hierro');itemType='iron_nugget';}
    else if(s.type==='copper_nugget'){sfx.coin();this.say('🪙 Pepita de cobre');itemType='copper_nugget';}
    else if(s.type==='silver_nugget'){sfx.coin();this.say('🩵 Pepita de plata!');itemType='silver_nugget';}
    else if(s.type==='gold_nugget'){sfx.coin();this.say('✨ ¡Pepita de ORO!');itemType='gold_nugget';}
    // --- VENAS DE MINERAL (requieren pico) ---
    else if(s.type==='iron_vein'||s.type==='copper_vein'||s.type==='silver_vein'||s.type==='gold_vein'){
      const tier = s.toolTier||1;
      if(!_playerHasPickaxe(tier)){
        const needed = tier>=2 ? 'Pico de Hierro ⛏️' : 'Pico de Piedra ⛏️';
        sfx.trombone();
        this.say('🔒 Necesito un '+needed);
        game._msg('⛏️ Necesitás un '+needed+' para minar esta vena — crafteala primero');
        this.state='idle';this.interactTarget=null;
        return;
      }
      const oreMap={iron_vein:'iron_ore',copper_vein:'copper_ore',silver_vein:'silver_ore',gold_vein:'gold_ore'};
      itemType=oreMap[s.type];
      sfx.rustle();sfx.boing();
      const oreNames={iron_ore:'⛏️ ¡Mineral de hierro!',copper_ore:'⛏️ ¡Cobre!',silver_ore:'⛏️ ¡Plata!',gold_ore:'⛏️ ¡¡ORO!!'};
      this.say(oreNames[itemType]||'⛏️ ¡Mineral!');
    }
    // Ocultar spot con respawn timer (30s de juego)
    if(itemType && s.type!=='cabin'){
      s.hidden=true;
      // Las venas de mineral tardan más en respawnear (60s) que los recursos normales (30s)
      s.respawnTimer = s.requiresTool ? 60 : 30;
    }
    // Item va a la mano del personaje
    if(itemType){
      if(this.carriedItem){
        // si ya tiene algo en la mano, lo suelta al suelo (con su count completo)
        const prevCount = this.carriedItem.count||1;
        const near=DROPPED_ITEMS.find(d=>d.type===this.carriedItem.type&&Math.hypot(d.x-this.x,d.y-this.y)<60);
        if(near) near.count+=prevCount;
        else DROPPED_ITEMS.push({id:Date.now(),type:this.carriedItem.type,x:this.x+30,y:this.y,count:prevCount,bobOffset:Math.random()*Math.PI*2});
      }
      this.carriedItem={type:itemType, count:1};
      game._showCarryHUD(itemType, 1);
      if(!bagEquipped) game._updateBagCraftHUD();
    }
    sfx.collect();
    this.danceTimer=1.5;this.state='idle';this.interactTarget=null;
  }
  draw(ctx){
    ctx.save();
    ctx.translate(this.x, this.y+this.jumpY);
    const drawState=this.state==='dance'?'dance':(this.funnyAnim!=='none'?this.funnyAnim:this.state);
    drawChar(ctx,this.char,this.frame,drawState,this.facingRight,true,1,this.funnyAnim,!!this.carriedItem);
    // Dibujar item sostenido entre los brazos
    if(this.carriedItem){
      ctx.save();
      ctx.translate(0, -12);
      ctx.scale(0.6, 0.6);
      // Sombra bajo el recurso
      ctx.fillStyle='rgba(0,0,0,0.18)';ctx.beginPath();ctx.ellipse(0,18,14,5,0,0,Math.PI*2);ctx.fill();
      drawSpotIcon(ctx, this.carriedItem.type, this.frame);
      ctx.restore();
    }
    ctx.restore();
    this.particles.forEach(p=>{
      ctx.save();ctx.globalAlpha=Math.max(0,p.life);
      ctx.translate(p.x,p.y);if(p.rot)ctx.rotate(p.rot);
      ctx.font=`bold ${p.sz}px Arial`;ctx.textAlign='center';
      ctx.fillText(p.t,0,0);ctx.restore();
    });
    if(this.thoughtTimer>0) bubble(ctx,this.x,this.y-100+this.jumpY,this.thought,'#ffffcc');
    ctx.fillStyle='rgba(0,0,0,0.65)';ctx.strokeStyle='rgba(255,255,255,0.5)';ctx.lineWidth=1;
    ctx.font='bold 12px Arial';ctx.textAlign='center';
    const nw=ctx.measureText(this.char.name).width+10;
    rr(ctx,this.x-nw/2,this.y-106,nw,16,4);ctx.fill();ctx.stroke();
    ctx.fillStyle='#fff';ctx.fillText(this.char.name,this.x,this.y-94);
  }
}

/* ---- TOOL TIER CHECK ---- */
// tier 1 = pico de piedra o superior, tier 2 = solo pico de hierro
function _playerHasPickaxe(tier){
  const weaponItem = EQUIP_SLOTS?.arma?.item;
  if(!weaponItem) return false;
  if(tier<=1) return weaponItem==='pickaxe_stone'||weaponItem==='pickaxe_iron';
  if(tier===2) return weaponItem==='pickaxe_iron';
  return false;
}

