      ctx.beginPath();ctx.moveTo(-9,-1);ctx.lineTo(-1,4);ctx.stroke();
      // Partícula de brillo
      ctx.fillStyle=`rgba(253,224,71,${0.7+Math.sin(gv*1.3)*0.3})`;
      ctx.beginPath();ctx.arc(-8,0,2.5,0,Math.PI*2);ctx.fill();
      ctx.font='14px Arial';ctx.textAlign='center';ctx.fillText('⛏️',14,-14);
      break;
    }

    // Pickaxe ítems
    case 'pickaxe_stone':
    case 'pickaxe_iron': {
      const isIron = type==='pickaxe_iron';
      // Mango de madera
      ctx.lineCap='round';
      ctx.strokeStyle='#7c2d12';ctx.lineWidth=5;
      ctx.beginPath();ctx.moveTo(-10,16);ctx.lineTo(10,-12);ctx.stroke();
      ctx.strokeStyle='#b45309';ctx.lineWidth=2.5;ctx.globalAlpha=0.45;
      ctx.beginPath();ctx.moveTo(-10,16);ctx.lineTo(10,-12);ctx.stroke();
      ctx.globalAlpha=1;
      // Cabeza lado largo (derecha)
      ctx.fillStyle=isIron?'#374151':'#b0b8c4';
      ctx.beginPath();ctx.moveTo(4,-14);ctx.lineTo(18,-2);ctx.lineTo(14,6);ctx.lineTo(0,-6);ctx.closePath();ctx.fill();
      ctx.fillStyle=isIron?'#6b7280':'#e2e8f0';
      ctx.globalAlpha=0.75;
      ctx.beginPath();ctx.moveTo(4,-14);ctx.lineTo(18,-2);ctx.lineTo(17,-1);ctx.lineTo(3,-13);ctx.closePath();ctx.fill();
      ctx.globalAlpha=1;
      // Filo punta derecha
      ctx.fillStyle=isIron?'#6b7280':'#d1d5db';
      ctx.beginPath();ctx.moveTo(18,-2);ctx.lineTo(22,4);ctx.lineTo(14,6);ctx.closePath();ctx.fill();
      // Cabeza lado corto (gancho izquierda)
      ctx.fillStyle=isIron?'#4b5563':'#9ca3af';
      ctx.beginPath();ctx.moveTo(4,-14);ctx.lineTo(-6,-8);ctx.lineTo(-10,-2);ctx.lineTo(-2,4);ctx.lineTo(0,-6);ctx.closePath();ctx.fill();
      // Filo gancho
      ctx.fillStyle=isIron?'#6b7280':'#d1d5db';
      ctx.beginPath();ctx.moveTo(-6,-8);ctx.lineTo(-14,-6);ctx.lineTo(-10,-2);ctx.closePath();ctx.fill();
      // Brillo metálico
      ctx.strokeStyle=isIron?'rgba(156,163,175,0.7)':'rgba(255,255,255,0.6)';
      ctx.lineWidth=1.2;
      ctx.beginPath();ctx.moveTo(6,-12);ctx.lineTo(16,-2);ctx.stroke();
      break;
    }
  } // end switch
  ctx.restore();
}

function drawSpot(ctx, spot, hover, t){
  if(spot.hidden) return; // farmeado — invisible hasta que respawnee
  const pulse=1+Math.sin(t*2+spot.x)*0.05;
  ctx.save();ctx.translate(spot.x+spot.w/2, spot.y+spot.h/2);ctx.scale(pulse,pulse);
  // Sombra suave bajo el icono
  ctx.fillStyle='rgba(0,0,0,0.18)';
  ctx.beginPath();ctx.ellipse(0, spot.h/2-8, 18, 6, 0, 0, Math.PI*2);ctx.fill();
  // Highlight de hover (círculo sutil, sin caja)
  if(hover){
    ctx.fillStyle='rgba(255,255,255,0.12)';
    ctx.beginPath();ctx.arc(0, 0, 30, 0, Math.PI*2);ctx.fill();
  }
  // Icono SVG-style
  drawSpotIcon(ctx, spot.type, t);
  // Indicador de herramienta requerida en venas de mineral
  if(spot.requiresTool){
    const hasTool = _playerHasPickaxe(spot.toolTier||1);
    if(!hasTool){
      // Candado rojo pulsante
      const lockAlpha = 0.7 + Math.sin(t*3)*0.2;
      ctx.globalAlpha = lockAlpha;
      ctx.fillStyle = 'rgba(239,68,68,0.85)';
      ctx.beginPath(); ctx.arc(22,-18,10,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 11px Arial'; ctx.textAlign = 'center';
      ctx.fillText('🔒', 22, -14);
      ctx.globalAlpha = 1;
    } else {
      // Check verde — tiene herramienta
      ctx.fillStyle = 'rgba(74,222,128,0.85)';
      ctx.beginPath(); ctx.arc(22,-18,9,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 10px Arial'; ctx.textAlign = 'center';
      ctx.fillText('✓', 22, -14);
    }
  }
  // Nombre manejado por #tip HTML (soporta emojis correctamente)
  ctx.restore();
}

/* ---- DRAW IMPROVISED SHOP ---- */
function drawTent(ctx, x, y, t, isGhost, doorAnim){
  const w=140, h=110;
  ctx.save();
  ctx.translate(x, y);
  if(isGhost){ ctx.globalAlpha=0.52; }

  // Sombra elíptica
  ctx.fillStyle='rgba(0,0,0,0.22)';
  ctx.beginPath(); ctx.ellipse(w/2, h+6, w*0.44, 10, 0, 0, Math.PI*2); ctx.fill();

  // === BASE: suelo de tierra bajo la carpa ===
  ctx.fillStyle='rgba(101,67,33,0.25)';
  ctx.beginPath(); ctx.ellipse(w/2, h-4, w*0.46, 12, 0, 0, Math.PI*2); ctx.fill();

  // === LONA IZQUIERDA ===
  const lg1 = ctx.createLinearGradient(0, h*0.1, w/2, h);
  lg1.addColorStop(0,'#b45309'); lg1.addColorStop(0.5,'#92400e'); lg1.addColorStop(1,'#78350f');
  ctx.fillStyle = lg1;
  ctx.beginPath();
  ctx.moveTo(w/2, 8);          // punta
  ctx.lineTo(-6, h-8);         // esquina izq
  ctx.lineTo(w/2, h-4);        // base centro
  ctx.closePath(); ctx.fill();
  ctx.strokeStyle='#5c2d08'; ctx.lineWidth=1.5; ctx.stroke();

  // === LONA DERECHA ===
  const lg2 = ctx.createLinearGradient(w/2, h*0.1, w, h);
  lg2.addColorStop(0,'#d97706'); lg2.addColorStop(0.5,'#b45309'); lg2.addColorStop(1,'#92400e');
  ctx.fillStyle = lg2;
  ctx.beginPath();
  ctx.moveTo(w/2, 8);
  ctx.lineTo(w+6, h-8);
  ctx.lineTo(w/2, h-4);
  ctx.closePath(); ctx.fill();
  ctx.strokeStyle='#78350f'; ctx.lineWidth=1.5; ctx.stroke();

  // === COSTURAS / PLIEGUES de la lona ===
  ctx.strokeStyle='rgba(0,0,0,0.18)'; ctx.lineWidth=1;
  // Pliegues izq
  for(let i=1;i<4;i++){
    ctx.beginPath();
    ctx.moveTo(w/2, 8);
    ctx.lineTo(-6+(w/2+6)*i/4, h-8+(h-4-h+8)*0 + (h-4) * i/4 - (h-4)*0 );
    ctx.stroke();
  }
  // Pliegues der
  for(let i=1;i<4;i++){
    ctx.beginPath();
    ctx.moveTo(w/2, 8);
    ctx.lineTo(w/2 + (w+6-w/2)*i/4, h-8+(4)*i/4);
    ctx.stroke();
  }

  // === PALO CENTRAL (mástil) ===
  ctx.strokeStyle='#5c3317'; ctx.lineWidth=3; ctx.lineCap='round';
  ctx.beginPath(); ctx.moveTo(w/2, 4); ctx.lineTo(w/2, h-5); ctx.stroke();
  // Remate del palo
  ctx.fillStyle='#d97706';
  ctx.beginPath(); ctx.arc(w/2, 4, 4, 0, Math.PI*2); ctx.fill();
  ctx.strokeStyle='#92400e'; ctx.lineWidth=1; ctx.stroke();

  // === ENTRADA (abertura triangular) ===
  const entW = 36, entH = 44;
  const entX = w/2 - entW/2, entY = h - entH - 4;
  // Oscuridad interior
  ctx.fillStyle='rgba(10,5,0,0.75)';
  ctx.beginPath();
  ctx.moveTo(w/2, entY);
  ctx.lineTo(entX, h-5);
  ctx.lineTo(entX+entW, h-5);
  ctx.closePath(); ctx.fill();

  // Si la puerta está abierta, mostrar interior (marrón iluminado)
  if(doorAnim > 0.1){
    ctx.fillStyle=`rgba(80,40,10,${doorAnim*0.7})`;
    ctx.beginPath();
    ctx.moveTo(w/2, entY+10);
    ctx.lineTo(entX+6, h-5);
    ctx.lineTo(entX+entW-6, h-5);
    ctx.closePath(); ctx.fill();
  }

  // Borde de la entrada
  ctx.strokeStyle='#3d1a07'; ctx.lineWidth=2;
  ctx.beginPath();
  ctx.moveTo(w/2, entY);
  ctx.lineTo(entX, h-5);
  ctx.moveTo(w/2, entY);
  ctx.lineTo(entX+entW, h-5);
  ctx.stroke();

  // === CUERDAS TENSORAS ===
  ctx.strokeStyle='#92400e'; ctx.lineWidth=1; ctx.setLineDash([3,3]);
  // Izq
  ctx.beginPath(); ctx.moveTo(-6, h-10); ctx.lineTo(-18, h+12); ctx.stroke();
  // Der
  ctx.beginPath(); ctx.moveTo(w+6, h-10); ctx.lineTo(w+18, h+12); ctx.stroke();
  ctx.setLineDash([]);

  // === ESTACAS ===
  ctx.strokeStyle='#5c3317'; ctx.lineWidth=3; ctx.lineCap='round';
  ctx.beginPath(); ctx.moveTo(-16, h+10); ctx.lineTo(-14, h+18); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(w+16, h+10); ctx.lineTo(w+14, h+18); ctx.stroke();
  // Estacas delanteras
  ctx.strokeStyle='#5c3317'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(entX-8, h+2); ctx.lineTo(entX-6, h+10); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(entX+entW+8, h+2); ctx.lineTo(entX+entW+6, h+10); ctx.stroke();
  ctx.lineCap='butt';

  // === LABEL y PROMPT ===
  if(!isGhost){
    ctx.font='bold 9px Arial'; ctx.fillStyle='rgba(255,255,255,0.85)'; ctx.textAlign='center';
    ctx.fillText('[ Entrar ]', w/2, h+24);
  }

  // === GHOST BORDER ===
  if(isGhost){
    ctx.strokeStyle=`rgba(251,191,36,${0.7+Math.sin(t*5)*0.3})`; ctx.lineWidth=2.5;
    ctx.setLineDash([6,4]); rr(ctx,-2,-2,w+4,h+4,8); ctx.stroke(); ctx.setLineDash([]);
  }
  ctx.restore();
}


function drawGroundDetail(ctx, cx, cy, seed){
  ctx.strokeStyle='#4ade80';ctx.lineWidth=1.5;ctx.lineCap='round';
  for(let i=0;i<4;i++){const gx=Math.sin(seed+i*37.3)*20,gy=Math.cos(seed+i*17.7)*15;ctx.beginPath();ctx.moveTo(cx+gx,cy+gy);ctx.lineTo(cx+gx+Math.sin(i)*5,cy+gy-8);ctx.stroke();}
  if(seed%3<1){const fx=cx+Math.sin(seed*7)*25,fy=cy+Math.cos(seed*5)*20;ctx.fillStyle=['#f472b6','#fde047','#a78bfa','#fb923c'][Math.floor(seed)%4];ctx.beginPath();ctx.arc(fx,fy,3,0,Math.PI*2);ctx.fill();}
}

