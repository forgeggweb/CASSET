        if(rx<desertEdgeX(ry)+30||rx>cx+1100/z||ry<cy-50||ry>cy+750/z) continue;
        ctx.beginPath();ctx.ellipse(rx,ry,12+i%18,7+i%10,i*0.3,0,Math.PI*2);ctx.fill();
        ctx.fillStyle='rgba(255,255,255,0.15)';ctx.beginPath();ctx.ellipse(rx-4,ry-3,5+i%6,3,0,0,Math.PI*2);ctx.fill();
