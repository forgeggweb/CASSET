<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cartoon Campo 🌿</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#1a2e1a;display:flex;justify-content:center;align-items:center;min-height:100vh;font-family:'Segoe UI',sans-serif;overflow:hidden;color:#fff}
#wrap{position:relative;width:1024px;height:700px;border-radius:12px;overflow:hidden;box-shadow:0 0 60px rgba(0,0,0,0.8)}
canvas{display:block}

#ui{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
.panel{position:absolute;background:rgba(0,0,0,0.65);border:1.5px solid rgba(255,255,255,0.25);border-radius:10px;padding:10px;pointer-events:auto}
#hud-money{position:absolute;top:10px;left:10px;background:rgba(0,0,0,0.7);border:1.5px solid rgba(255,220,0,0.5);border-radius:22px;padding:6px 14px;font-size:15px;font-weight:700;text-shadow:1px 1px 2px #000;display:none;pointer-events:none;color:#fde047;white-space:nowrap}
/* MISSIONS HUD */
#missions-hud{position:absolute;top:10px;left:100px;display:none;pointer-events:auto;z-index:20}
#missions-toggle{background:rgba(0,0,0,0.75);border:1.5px solid rgba(168,85,247,0.7);border-radius:20px;
  padding:5px 11px;font-size:12px;font-weight:800;color:#c4b5fd;cursor:pointer;
  display:flex;align-items:center;gap:6px;white-space:nowrap;text-shadow:1px 1px 2px #000;
  transition:all 0.15s}
#missions-toggle:hover{background:rgba(168,85,247,0.2);border-color:#a855f7}
#missions-toggle .mt-dot{width:7px;height:7px;border-radius:50%;background:#a855f7;
  box-shadow:0 0 6px #a855f7;flex-shrink:0}
#missions-toggle .mt-dot.active{background:#4ade80;box-shadow:0 0 6px #4ade80}
#missions-panel{display:none;position:absolute;top:34px;left:0;
  background:rgba(5,10,5,0.96);border:1.5px solid rgba(168,85,247,0.6);
  border-radius:12px;padding:10px 14px;min-width:220px;
  box-shadow:0 4px 20px rgba(0,0,0,0.7),0 0 14px rgba(168,85,247,0.15)}
#missions-panel-title{font-size:10px;font-weight:900;color:rgba(168,85,247,0.8);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.mission-item{display:flex;align-items:flex-start;gap:8px;padding:7px 8px;
  background:rgba(255,255,255,0.04);border-radius:8px;border:1px solid rgba(255,255,255,0.08);margin-bottom:5px}
.mission-item:last-child{margin-bottom:0}
.mission-icon{font-size:16px;flex-shrink:0;margin-top:1px}
.mission-body{flex:1;min-width:0}
.mission-name{font-size:11px;font-weight:800;color:#fde047;margin-bottom:2px}
.mission-desc{font-size:10px;color:rgba(255,255,255,0.55);line-height:1.4}
.mission-progress{display:flex;gap:5px;margin-top:4px;flex-wrap:wrap}
.mp-chip{font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#d1fae5}
.mp-chip.done{background:rgba(74,222,128,0.2);border-color:#4ade80;color:#4ade80}
.mission-craft-btn{font-size:10px;font-weight:800;padding:4px 10px;border-radius:10px;
  background:rgba(74,222,128,0.15);border:1.5px solid #4ade80;color:#4ade80;cursor:pointer;
  margin-top:6px;transition:all 0.15s;display:none;width:100%}
.mission-craft-btn:hover{background:rgba(74,222,128,0.3)}
#clock{position:absolute;top:10px;right:10px;font-size:15px;font-weight:700;text-shadow:2px 2px 0 #000;padding:5px 12px;display:none;background:rgba(0,0,0,0.65);border:1.5px solid rgba(255,255,255,0.25);border-radius:10px;pointer-events:none;white-space:nowrap}
#explore-hud{position:absolute;top:48px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.7);border:1.5px solid rgba(100,220,100,0.5);border-radius:22px;padding:5px 14px;font-size:13px;font-weight:700;color:#4ade80;text-shadow:1px 1px 2px #000;pointer-events:none;display:none;white-space:nowrap}
#location{position:absolute;top:10px;left:50%;transform:translateX(-50%);font-size:13px;font-weight:700;background:rgba(0,0,0,0.7);padding:5px 14px;border-radius:20px;border:1px solid rgba(255,255,255,0.3);white-space:nowrap;display:none;pointer-events:none}
#msgs{position:absolute;bottom:70px;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none;z-index:10}
.msg{background:rgba(0,0,0,0.8);color:#fff;padding:7px 16px;border-radius:20px;margin-bottom:7px;font-size:14px;font-weight:700;text-shadow:2px 2px 0 #000;animation:popIn 0.3s cubic-bezier(.175,.885,.32,1.275);white-space:nowrap;border:1.5px solid rgba(255,255,255,0.4)}
@keyframes popIn{from{transform:scale(0) translateY(10px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
#tip{position:absolute;background:rgba(0,0,0,0.85);color:#fff;padding:6px 12px;border-radius:6px;font-size:13px;pointer-events:none;display:none;border:1px solid rgba(255,255,255,0.3);z-index:20}
/* old minimap hidden — replaced by big map overlay */
#minimap{display:none!important}

/* ===== BIG MAP OVERLAY ===== */
#bigmap-overlay{
  position:absolute;top:0;left:0;width:100%;height:100%;
  background:rgba(0,0,0,0.78);z-index:150;display:none;
  align-items:center;justify-content:center;pointer-events:auto;
}
#bigmap-wrap{
  position:relative;width:780px;height:560px;
  background:rgba(5,15,5,0.97);border:2px solid rgba(100,220,100,0.5);
  border-radius:16px;box-shadow:0 0 60px rgba(0,0,0,0.9);
  display:flex;flex-direction:column;overflow:hidden;
}
#bigmap-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 16px;border-bottom:1px solid rgba(255,255,255,0.12);
  flex-shrink:0;
}
#bigmap-title{font-size:15px;font-weight:900;color:#4ade80;letter-spacing:1px;}
#bigmap-stats{font-size:11px;color:rgba(255,255,255,0.5);}
#bigmap-close{background:none;border:none;color:rgba(255,255,255,0.5);font-size:18px;cursor:pointer;padding:2px 6px;border-radius:6px;}
#bigmap-close:hover{color:#fff;background:rgba(255,255,255,0.1);}
#bigmap-body{display:flex;flex:1;overflow:hidden;}
#bigmap-canvas-wrap{
  position:relative;flex:1;overflow:hidden;cursor:crosshair;
}
#bigmap-canvas{display:block;width:100%;height:100%;}

/* Pin mode cursor */
#bigmap-canvas-wrap.pin-mode{cursor:url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24'><text y='20' font-size='20'>📍</text></svg>") 12 22, crosshair;}

/* Sidebar */
#bigmap-sidebar{
  width:170px;border-left:1px solid rgba(255,255,255,0.1);
  display:flex;flex-direction:column;padding:10px;gap:8px;overflow-y:auto;
  background:rgba(0,0,0,0.3);flex-shrink:0;
}
#bigmap-sidebar-title{font-size:11px;font-weight:900;color:#fde047;letter-spacing:1px;text-align:center;}
#bigmap-pin-types{display:flex;flex-wrap:wrap;gap:4px;justify-content:center;}
.map-pin-type{
  background:rgba(0,0,0,0.5);border:1.5px solid rgba(255,255,255,0.2);
  border-radius:8px;padding:5px 7px;cursor:pointer;font-size:16px;
  transition:all 0.15s;title:'';display:flex;align-items:center;justify-content:center;
  position:relative;
}
.map-pin-type:hover{border-color:#fde047;background:rgba(253,224,71,0.15);}
.map-pin-type.selected{border-color:#fde047;background:rgba(253,224,71,0.25);box-shadow:0 0 8px rgba(253,224,71,0.4);}
#bigmap-mode-btn{
  background:rgba(253,224,71,0.15);border:1.5px solid rgba(253,224,71,0.5);
  color:#fde047;padding:7px 10px;border-radius:10px;cursor:pointer;
  font-size:11px;font-weight:700;text-align:center;transition:all 0.15s;
}
#bigmap-mode-btn:hover{background:rgba(253,224,71,0.3);}
#bigmap-mode-btn.placing{background:rgba(239,68,68,0.2);border-color:#ef4444;color:#ef4444;}
#bigmap-pins-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:4px;}
.bm-pin-item{
  background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.12);
  border-radius:6px;padding:5px 7px;display:flex;align-items:center;gap:5px;
  cursor:pointer;transition:all 0.12s;
}
.bm-pin-item:hover{border-color:rgba(253,224,71,0.5);background:rgba(253,224,71,0.08);}
.bm-pin-item .pin-icon{font-size:14px;flex-shrink:0;}
.bm-pin-item .pin-label{font-size:9px;color:rgba(255,255,255,0.8);flex:1;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bm-pin-item .pin-del{font-size:10px;color:rgba(255,100,100,0.6);cursor:pointer;flex-shrink:0;padding:0 2px;}
.bm-pin-item .pin-del:hover{color:#ef4444;}
#bigmap-legend{font-size:9px;color:rgba(255,255,255,0.3);text-align:center;padding-top:4px;border-top:1px solid rgba(255,255,255,0.08);}

/* Pin name input popup */
#pin-name-popup{
  position:absolute;background:rgba(5,15,5,0.97);border:2px solid rgba(253,224,71,0.7);
  border-radius:10px;padding:10px 12px;z-index:200;display:none;
  box-shadow:0 4px 20px rgba(0,0,0,0.8);min-width:180px;
}
#pin-name-popup input{
  background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.25);
  color:#fff;padding:5px 8px;border-radius:6px;font-size:12px;width:100%;
  margin-bottom:7px;outline:none;
}
#pin-name-popup input:focus{border-color:#fde047;}
#pin-name-btns{display:flex;gap:6px;}
.pnp-btn{flex:1;padding:5px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700;border:none;}
#pnp-ok{background:rgba(253,224,71,0.25);color:#fde047;border:1.5px solid rgba(253,224,71,0.5);}
#pnp-ok:hover{background:rgba(253,224,71,0.45);}
#pnp-cancel{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.15);}
#pnp-cancel:hover{background:rgba(255,255,255,0.15);}
#actions{position:absolute;bottom:14px;left:14px;display:none;gap:8px}
.btn{background:rgba(0,0,0,0.7);border:1.5px solid rgba(255,255,255,0.3);color:#fff;padding:7px 13px;border-radius:20px;cursor:pointer;font-size:12px;font-weight:700;pointer-events:auto;transition:all 0.15s;text-shadow:1px 1px 2px #000}
.btn:hover{background:rgba(255,255,255,0.2);border-color:#fff}
.btn.active{background:rgba(253,224,71,0.25);border-color:#fde047;color:#fde047}

/* ZOOM CONTROLS */
#zoom-controls{position:absolute;top:50px;right:10px;display:none;flex-direction:column;gap:4px;pointer-events:auto}
.zoom-btn{background:rgba(0,0,0,0.75);border:1.5px solid rgba(255,255,255,0.35);color:#fff;width:34px;height:34px;border-radius:10px;cursor:pointer;font-size:16px;font-weight:900;display:flex;align-items:center;justify-content:center;transition:all 0.15s;text-shadow:1px 1px 2px #000}
.zoom-btn:hover{background:rgba(255,255,255,0.25);border-color:#fff}
#zoom-level{font-size:10px;font-weight:700;text-align:center;color:rgba(255,255,255,0.6);text-shadow:1px 1px 2px #000}

/* INVENTORY PANEL */
#inv-toggle{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:none;pointer-events:auto}

/* EQUIP SLOTS BAR */
#equip-bar{position:absolute;bottom:10px;right:56px;display:none;gap:6px;pointer-events:auto;align-items:flex-end}
.eq-slot{
  width:48px;height:52px;border-radius:14px;border:2px solid;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;position:relative;transition:all 0.18s;
  box-shadow:0 3px 12px rgba(0,0,0,0.5),inset 0 1px 0 rgba(255,255,255,0.12);
  font-size:10px;font-weight:800;letter-spacing:0.3px;
}
.eq-slot:hover{transform:translateY(-4px) scale(1.08);}
.eq-slot:hover .eq-tooltip{opacity:1;transform:translateY(0)}
.eq-slot .eq-icon{font-size:20px;line-height:1;margin-bottom:1px}
.eq-slot .eq-label{font-size:8px;font-weight:700;opacity:0.7;text-transform:uppercase;letter-spacing:0.5px}
.eq-slot .eq-item-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center}
.eq-slot .eq-badge{position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;
  background:#22c55e;border:1.5px solid #000;display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:900;color:#fff}
.eq-slot .eq-tooltip{
  position:absolute;bottom:58px;left:50%;transform:translate(-50%,6px);
  background:rgba(10,10,10,0.92);border:1px solid rgba(255,255,255,0.2);
  border-radius:8px;padding:5px 9px;white-space:nowrap;font-size:10px;color:#fff;
  pointer-events:none;opacity:0;transition:all 0.15s;z-index:99;
}
/* slot colors */
.eq-slot.eq-bolsa  {background:rgba(139,92,246,0.25);border-color:#8b5cf6;color:#c4b5fd}
.eq-slot.eq-arma   {background:rgba(239,68,68,0.2); border-color:#ef4444;color:#fca5a5}
.eq-slot.eq-armadura{background:rgba(59,130,246,0.2);border-color:#3b82f6;color:#93c5fd}
.eq-slot.eq-accesorio{background:rgba(234,179,8,0.2);border-color:#eab308;color:#fde047}
.eq-slot.eq-especial{background:rgba(20,184,166,0.2);border-color:#14b8a6;color:#5eead4}
.eq-slot.eq-bolsa.equipped  {background:rgba(139,92,246,0.5);box-shadow:0 0 14px rgba(139,92,246,0.6),0 3px 12px rgba(0,0,0,0.5)}
.eq-slot.eq-arma.equipped   {background:rgba(239,68,68,0.45); box-shadow:0 0 14px rgba(239,68,68,0.55),0 3px 12px rgba(0,0,0,0.5)}
.eq-slot.eq-armadura.equipped{background:rgba(59,130,246,0.45);box-shadow:0 0 14px rgba(59,130,246,0.55),0 3px 12px rgba(0,0,0,0.5)}
.eq-slot.eq-accesorio.equipped{background:rgba(234,179,8,0.45);box-shadow:0 0 14px rgba(234,179,8,0.55),0 3px 12px rgba(0,0,0,0.5)}
.eq-slot.eq-especial.equipped{background:rgba(20,184,166,0.45);box-shadow:0 0 14px rgba(20,184,166,0.55),0 3px 12px rgba(0,0,0,0.5)}
/* ===== ALBION-STYLE INVENTORY OVERLAY ===== */
#inv-overlay{
  position:absolute;top:0;left:0;width:100%;height:100%;
  background:rgba(0,0,0,0.72);z-index:120;display:none;
  align-items:center;justify-content:center;pointer-events:auto;
}
#inv-wrap{
  position:relative;
  background:linear-gradient(160deg,#0d1f0d 0%,#091409 100%);
  border:2px solid rgba(100,220,100,0.45);border-radius:18px;
  box-shadow:0 0 60px rgba(0,0,0,0.9),0 0 30px rgba(74,222,128,0.08);
  width:660px;display:flex;flex-direction:column;overflow:hidden;
}
#inv-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 18px;border-bottom:1px solid rgba(255,255,255,0.1);
  background:rgba(0,0,0,0.3);flex-shrink:0;
}
#inv-header-title{font-size:14px;font-weight:900;color:#4ade80;letter-spacing:1.5px;text-transform:uppercase}
#inv-header-money{font-size:13px;font-weight:700;color:#fde047}
#inv-close-btn{background:none;border:none;color:rgba(255,255,255,0.45);font-size:17px;cursor:pointer;padding:2px 7px;border-radius:7px}
#inv-close-btn:hover{color:#fff;background:rgba(255,255,255,0.1)}
#inv-body{display:flex;flex:1;min-height:0}
#inv-equip-pane{
  width:240px;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;
  padding:14px 10px 12px;
  border-right:1px solid rgba(255,255,255,0.08);
  position:relative;
}
#inv-char-stage{
  position:relative;width:130px;height:160px;
  background:radial-gradient(ellipse at 50% 70%,rgba(74,222,128,0.1) 0%,transparent 70%);
  border-radius:14px;border:1px solid rgba(255,255,255,0.06);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:8px;flex-shrink:0;overflow:hidden;
}
#inv-char-canvas{display:block;}
#inv-char-name{font-size:10px;font-weight:800;color:rgba(255,255,255,0.5);letter-spacing:1px;margin-bottom:10px;text-transform:uppercase}
#inv-slots-grid{
  display:grid;
  grid-template-columns:56px 56px 56px;
  grid-template-rows:repeat(3,56px);
  gap:6px;
}
.alb-slot{
  width:56px;height:56px;border-radius:12px;
  border:2px solid rgba(255,255,255,0.15);
  background:rgba(0,0,0,0.45);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;position:relative;transition:all 0.15s;
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.07);
}
.alb-slot:hover{transform:scale(1.06);border-color:rgba(255,255,255,0.4);}
.alb-slot.equipped{box-shadow:0 0 12px rgba(74,222,128,0.5),inset 0 1px 0 rgba(255,255,255,0.1);}
.alb-slot .alb-icon{font-size:22px;line-height:1}
.alb-slot .alb-label{font-size:7px;font-weight:700;opacity:0.55;text-transform:uppercase;letter-spacing:0.5px;margin-top:2px;color:#fff}
.alb-slot .alb-tip{
  position:absolute;bottom:64px;left:50%;transform:translateX(-50%);
  background:rgba(5,15,5,0.97);border:1px solid rgba(255,255,255,0.2);
  border-radius:8px;padding:5px 9px;white-space:nowrap;font-size:10px;color:#fff;
  pointer-events:none;opacity:0;transition:all 0.12s;z-index:10;min-width:90px;text-align:center;
}
.alb-slot:hover .alb-tip{opacity:1;}
.alb-slot.sl-bolsa   {border-color:rgba(139,92,246,0.4);color:#c4b5fd}
.alb-slot.sl-arma    {border-color:rgba(239,68,68,0.4); color:#fca5a5}
.alb-slot.sl-armadura{border-color:rgba(59,130,246,0.4);color:#93c5fd}
.alb-slot.sl-accesorio{border-color:rgba(234,179,8,0.4);color:#fde047}
.alb-slot.sl-especial{border-color:rgba(20,184,166,0.4);color:#5eead4}
.alb-slot.sl-bolsa.equipped   {background:rgba(139,92,246,0.3);border-color:#8b5cf6;}
.alb-slot.sl-arma.equipped    {background:rgba(239,68,68,0.25);border-color:#ef4444;}
.alb-slot.sl-armadura.equipped{background:rgba(59,130,246,0.25);border-color:#3b82f6;}
.alb-slot.sl-accesorio.equipped{background:rgba(234,179,8,0.25);border-color:#eab308;}
.alb-slot.sl-especial.equipped{background:rgba(20,184,166,0.25);border-color:#14b8a6;}
#inv-grid-pane{
  flex:1;display:flex;flex-direction:column;padding:12px 14px;gap:10px;overflow:hidden;
}
#inv-grid-label{font-size:10px;font-weight:900;color:rgba(255,255,255,0.35);letter-spacing:1px;text-transform:uppercase}
#inv-grid{display:flex;flex-wrap:wrap;gap:6px;align-content:flex-start;overflow-y:auto;flex:1}
#inv-grid::-webkit-scrollbar{width:4px}
#inv-grid::-webkit-scrollbar-thumb{background:rgba(74,222,128,0.3);border-radius:4px}
.inv-slot{
  width:62px;height:68px;background:rgba(0,0,0,0.5);
  border:1.5px solid rgba(255,255,255,0.14);border-radius:10px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:24px;position:relative;transition:all 0.15s;cursor:default;
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);
}
.inv-slot.has-item{border-color:rgba(253,224,71,0.55);background:rgba(0,0,0,0.7);box-shadow:0 0 8px rgba(253,224,71,0.15),inset 0 1px 0 rgba(255,255,255,0.06)}
.inv-slot.has-item:hover{transform:scale(1.07);border-color:#fde047;cursor:pointer}
.inv-slot-name{font-size:8px;font-weight:700;color:rgba(255,255,255,0.65);margin-top:2px;text-shadow:1px 1px 2px #000;text-align:center;line-height:1.2;padding:0 2px}
.inv-count{position:absolute;top:3px;right:5px;font-size:10px;font-weight:900;color:#fde047;text-shadow:1px 1px 2px #000}
.inv-empty{font-size:12px;color:rgba(255,255,255,0.4);text-align:center;padding:14px;width:100%}
#inv-footer{padding:8px 14px;border-top:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,0.2);flex-shrink:0}
#inv-slots-count{font-size:10px;color:rgba(255,255,255,0.4)}
#inv-money-bar{font-size:13px;font-weight:700;color:#fde047}
#equip-bar{display:none!important}
/* keep legacy id for money compat */
#inv-panel{display:none!important}

/* ANIMATION MENU */
#anim-menu{position:absolute;bottom:54px;left:14px;display:none;pointer-events:auto;
  background:rgba(10,20,10,0.93);border:2px solid rgba(100,220,100,0.5);border-radius:16px;
  padding:12px 14px;width:340px;
  box-shadow:0 4px 30px rgba(0,0,0,0.7);z-index:30}
#anim-menu-title{font-size:14px;font-weight:900;color:#4ade80;text-shadow:1px 1px 3px #000;margin-bottom:10px;text-align:center;letter-spacing:1px}
#anim-grid{display:flex;flex-wrap:wrap;gap:6px;justify-content:center}
.anim-btn-item{background:rgba(0,0,0,0.55);border:1.5px solid rgba(255,255,255,0.2);border-radius:10px;
  padding:6px 10px;cursor:pointer;font-size:11px;font-weight:700;color:#fff;
  display:flex;flex-direction:column;align-items:center;gap:2px;min-width:72px;
  transition:all 0.15s;text-shadow:1px 1px 2px #000}
.anim-btn-item:hover{background:rgba(74,222,128,0.25);border-color:#4ade80;color:#4ade80}
.anim-btn-item.playing{background:rgba(253,224,71,0.25);border-color:#fde047;color:#fde047}
.anim-btn-icon{font-size:20px}

/* ===== CRAFT PANEL — VINTAGE STORY STYLE ===== */
#craft-panel{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  display:none;pointer-events:auto;
  background:linear-gradient(160deg,#2a1a0a 0%,#1a0f05 100%);
  border:3px solid #a0622a;
  border-radius:20px;
  padding:18px 20px 16px;
  width:560px;
  box-shadow:0 0 0 1px #6b3d12,0 8px 60px rgba(0,0,0,0.9),inset 0 1px 0 rgba(255,200,100,0.08);
  z-index:100;
}
#craft-panel *{pointer-events:auto}
#craft-panel-title{
  font-size:16px;font-weight:900;
  color:#f5c842;
  text-shadow:0 0 12px rgba(245,200,66,0.6),2px 2px 0 rgba(0,0,0,0.8);
  margin-bottom:2px;text-align:center;letter-spacing:2px;
  font-family:'Segoe UI',sans-serif;text-transform:uppercase;
}
#craft-panel-sub{font-size:10px;color:rgba(255,200,120,0.5);text-align:center;margin-bottom:14px;letter-spacing:1px}
#craft-close{
  position:absolute;top:10px;right:12px;
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.15);
  color:rgba(255,200,100,0.6);font-size:16px;cursor:pointer;
  padding:2px 7px;border-radius:8px;transition:all 0.15s;
}
#craft-close:hover{color:#fff;background:rgba(255,100,50,0.3);border-color:#ef4444}

/* — guide cell: shows ghost icon of required ingredient when cell is empty — */
.craft-cell.guide-cell{
  border-color:rgba(245,200,66,0.25);
  background:linear-gradient(135deg,rgba(55,35,8,0.7),rgba(28,16,4,0.8));
}
.craft-cell.guide-cell .cell-guide-icon{
  opacity:0.25;
  filter:grayscale(0.2);
  pointer-events:none;
}
.craft-cell.guide-cell .cell-guide-label{
  font-size:6px;font-weight:700;
  color:rgba(245,200,66,0.45);
  position:absolute;bottom:2px;left:0;right:0;text-align:center;
  line-height:1;pointer-events:none;
}

.craft-tab{
  background:rgba(0,0,0,0.4);border:1.5px solid rgba(255,255,255,0.12);
  color:rgba(255,200,100,0.6);padding:5px 14px;border-radius:20px;
  cursor:pointer;font-size:11px;font-weight:700;transition:all 0.15s;
}
.craft-tab:hover{border-color:#f5c842;color:#f5c842}
.craft-tab.active{background:rgba(245,200,66,0.18);border-color:#f5c842;color:#f5c842;box-shadow:0 0 8px rgba(245,200,66,0.25)}

/* — recipe list — */
#craft-recipe-list{
  display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-start;
  max-height:90px;overflow-y:auto;margin-bottom:14px;padding:2px;
}
#craft-recipe-list::-webkit-scrollbar{width:4px}
#craft-recipe-list::-webkit-scrollbar-track{background:rgba(0,0,0,0.2);border-radius:4px}
#craft-recipe-list::-webkit-scrollbar-thumb{background:rgba(245,200,66,0.3);border-radius:4px}

.craft-recipe-thumb{
  width:52px;height:54px;
  background:rgba(0,0,0,0.5);
  border:2px solid rgba(255,255,255,0.12);
  border-radius:10px;cursor:pointer;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:22px;transition:all 0.15s;position:relative;flex-shrink:0;
  pointer-events:auto;
}
.craft-recipe-thumb *{pointer-events:none}
.craft-recipe-thumb:hover:not(.locked-recipe){border-color:#f5c842;background:rgba(245,200,66,0.15);transform:scale(1.08)}
.craft-recipe-thumb.active-recipe{border-color:#f5c842;background:rgba(245,200,66,0.22);box-shadow:0 0 10px rgba(245,200,66,0.4)}
.craft-recipe-thumb.locked-recipe{opacity:0.55;filter:grayscale(0.4)}
.craft-recipe-thumb .rth-name{font-size:7px;font-weight:700;color:rgba(255,255,255,0.7);margin-top:1px;text-align:center;line-height:1.1}

/* — main craft area — */
#craft-workspace{display:flex;align-items:center;gap:14px;justify-content:center;margin-bottom:12px}

/* 3×3 grid */
#craft-grid-wrap{display:flex;flex-direction:column;gap:0}
#craft-grid-label{font-size:9px;font-weight:700;color:rgba(255,200,100,0.5);text-align:center;margin-bottom:5px;letter-spacing:1px;text-transform:uppercase}
#craft-grid{
  display:grid;grid-template-columns:repeat(3,54px);grid-template-rows:repeat(3,54px);
  gap:3px;
  background:rgba(0,0,0,0.45);border:2px solid #6b3d12;border-radius:10px;padding:5px;
  box-shadow:inset 0 2px 8px rgba(0,0,0,0.6);
}
.craft-cell{
  width:54px;height:54px;
  background:linear-gradient(135deg,rgba(60,35,10,0.8),rgba(30,18,5,0.9));
  border:1.5px solid rgba(160,98,42,0.35);
  border-radius:7px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;font-size:24px;
  transition:all 0.12s;
  box-shadow:inset 0 1px 3px rgba(0,0,0,0.5);
}
.craft-cell.has-item{
  border-color:#c8862e;
  background:linear-gradient(135deg,rgba(80,50,15,0.9),rgba(50,30,8,0.95));
  box-shadow:inset 0 1px 3px rgba(0,0,0,0.4),0 0 6px rgba(200,134,46,0.2);
}
.craft-cell.highlight-cell{
  border-color:#f5c842;
  background:linear-gradient(135deg,rgba(100,70,15,0.9),rgba(60,40,8,0.95));
  box-shadow:0 0 10px rgba(245,200,66,0.35);
  animation:cellPulse 1.2s infinite alternate;
}
@keyframes cellPulse{
  from{box-shadow:0 0 6px rgba(245,200,66,0.25)}
  to{box-shadow:0 0 14px rgba(245,200,66,0.55)}
}
.craft-cell .cell-count{
  position:absolute;bottom:2px;right:4px;
  font-size:9px;font-weight:900;
  color:#f5c842;text-shadow:1px 1px 2px #000;
}
.craft-cell .cell-need{
  position:absolute;top:2px;left:3px;
  font-size:8px;font-weight:700;
  color:rgba(255,120,60,0.9);text-shadow:1px 1px 1px #000;
}
.craft-cell .cell-have{
  position:absolute;top:2px;left:3px;
  font-size:8px;font-weight:700;
  color:rgba(100,220,100,0.9);text-shadow:1px 1px 1px #000;
}
.craft-cell .cell-name{
  font-size:7px;font-weight:700;
  color:rgba(255,220,150,0.7);
  margin-top:1px;text-align:center;line-height:1.1;
}

/* arrow */
#craft-arrow{font-size:28px;flex-shrink:0;filter:drop-shadow(0 0 6px rgba(245,200,66,0.5));animation:arrowBob 1s infinite alternate}
@keyframes arrowBob{from{transform:translateX(-2px)}to{transform:translateX(3px)}}

/* result area */
#craft-result-wrap{display:flex;flex-direction:column;align-items:center;gap:5px}
#craft-result-label{font-size:9px;font-weight:700;color:rgba(255,200,100,0.5);letter-spacing:1px;text-transform:uppercase}
#craft-result-cell{
  width:72px;height:72px;
  background:linear-gradient(135deg,rgba(40,60,20,0.85),rgba(20,35,10,0.95));
  border:2px solid rgba(100,180,60,0.35);
  border-radius:12px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:34px;position:relative;
  box-shadow:inset 0 2px 6px rgba(0,0,0,0.5);
  transition:all 0.2s;
}
#craft-result-cell.can-craft{
  border-color:#7bcf3a;
  background:linear-gradient(135deg,rgba(50,90,20,0.9),rgba(30,55,10,0.95));
  box-shadow:0 0 16px rgba(123,207,58,0.4),inset 0 2px 6px rgba(0,0,0,0.3);
  cursor:pointer;
  animation:resultGlow 1.4s infinite alternate;
}
@keyframes resultGlow{
  from{box-shadow:0 0 10px rgba(123,207,58,0.3)}
  to{box-shadow:0 0 22px rgba(123,207,58,0.65)}
}
#craft-result-cell.can-craft:hover{transform:scale(1.1)}
#craft-result-cell .res-name{font-size:9px;font-weight:700;color:rgba(180,255,100,0.85);margin-top:2px;text-align:center}
#craft-result-cell .res-empty-txt{font-size:9px;color:rgba(255,255,255,0.25);text-align:center;margin-top:3px;line-height:1.3}

.craft-cell.ghost-item{
  border-color:rgba(245,200,66,0.3);
  background:linear-gradient(135deg,rgba(60,35,10,0.6),rgba(30,18,5,0.7));
  opacity:0.55;
}
.craft-cell.placed-ok{
  border-color:#7bcf3a;
  background:linear-gradient(135deg,rgba(50,90,15,0.9),rgba(30,55,8,0.95));
  box-shadow:0 0 8px rgba(123,207,58,0.35),inset 0 1px 3px rgba(0,0,0,0.3);
}
.craft-cell.placed-wrong{
  border-color:#ef4444;
  background:linear-gradient(135deg,rgba(90,20,10,0.9),rgba(55,10,5,0.95));
  box-shadow:0 0 8px rgba(239,68,68,0.35);
  animation:shakeCell 0.3s ease;
}
@keyframes shakeCell{0%{transform:translateX(0)}25%{transform:translateX(-3px)}75%{transform:translateX(3px)}100%{transform:translateX(0)}}
.craft-cell.needed-empty{
  border-color:rgba(200,134,46,0.2);
  background:linear-gradient(135deg,rgba(40,25,8,0.7),rgba(20,12,3,0.8));
}
/* pattern hint overlay in cell */
.craft-cell .cell-ghost-icon{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  opacity:0.25;pointer-events:none;
}
/* inventory quick-select bar inside craft panel */
#craft-inv-bar{
  display:flex;gap:5px;justify-content:center;flex-wrap:wrap;
  margin-bottom:10px;
  padding:6px 8px;
  background:rgba(0,0,0,0.3);border:1px solid rgba(160,98,42,0.25);border-radius:10px;
}
#craft-inv-bar-label{
  font-size:9px;font-weight:700;color:rgba(255,200,100,0.45);
  text-align:center;margin-bottom:4px;letter-spacing:1px;text-transform:uppercase;
}
.craft-inv-slot{
  width:42px;height:44px;
  background:rgba(0,0,0,0.45);border:1.5px solid rgba(160,98,42,0.3);
  border-radius:8px;cursor:grab;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:20px;position:relative;transition:all 0.12s;flex-shrink:0;
}
.craft-inv-slot *{pointer-events:none}
.craft-inv-slot:hover{border-color:#f5c842;background:rgba(245,200,66,0.15);transform:scale(1.08)}
.craft-inv-slot.selected-item{border-color:#f5c842;background:rgba(245,200,66,0.22);box-shadow:0 0 8px rgba(245,200,66,0.4)}
.craft-inv-slot .cis-name{font-size:7px;font-weight:700;color:rgba(255,220,150,0.7);margin-top:1px;text-align:center}
.craft-inv-slot .cis-count{position:absolute;top:2px;right:3px;font-size:8px;font-weight:900;color:#f5c842;text-shadow:1px 1px 1px #000}
/* selected item cursor indicator */
#craft-cursor-item{
  font-size:11px;font-weight:700;color:rgba(245,200,66,0.8);
  text-align:center;margin-bottom:6px;min-height:14px;
}
#craft-do-btn{
  width:100%;padding:9px;
  background:linear-gradient(90deg,#5a9e1a,#7bcf3a);
  border:none;border-radius:12px;
  color:#fff;font-size:13px;font-weight:900;cursor:pointer;
  text-shadow:1px 1px 3px rgba(0,0,0,0.5);
  box-shadow:0 3px 12px rgba(90,158,26,0.5),0 1px 0 rgba(255,255,255,0.15) inset;
  transition:all 0.15s;letter-spacing:0.5px;
  display:none;
}
#craft-do-btn:hover{background:linear-gradient(90deg,#6ab820,#94e84a);transform:translateY(-1px);box-shadow:0 5px 16px rgba(90,158,26,0.6)}
#craft-do-btn:active{transform:translateY(1px)}
#craft-do-btn:disabled{background:rgba(80,80,80,0.5);color:rgba(255,255,255,0.4);cursor:not-allowed;box-shadow:none;transform:none}

/* materials bar */
#craft-materials{
  margin-top:8px;padding-top:8px;
  border-top:1px solid rgba(160,98,42,0.3);
  display:flex;gap:8px;justify-content:center;flex-wrap:wrap;
}
.mat-chip{
  background:rgba(0,0,0,0.45);
  border:1px solid rgba(160,98,42,0.4);
  border-radius:20px;
  padding:3px 11px;font-size:11px;font-weight:700;color:rgba(255,220,150,0.9);
}

/* CHEST PANEL (inside cabin) */
#chest-panel{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:none;pointer-events:auto;
  background:rgba(5,10,5,0.97);border:2px solid rgba(217,119,6,0.8);border-radius:16px;
  padding:18px 22px;width:560px;min-height:160px;
  box-shadow:0 4px 40px rgba(0,0,0,0.8);z-index:100}
#chest-panel *{pointer-events:auto}
#chest-panel-title{font-size:16px;font-weight:900;color:#fbbf24;text-align:center;margin-bottom:4px;letter-spacing:1px}
#chest-panel-sub{font-size:11px;color:rgba(255,255,255,0.5);text-align:center;margin-bottom:12px}
#chest-close{position:absolute;top:10px;right:14px;background:none;border:none;color:rgba(255,255,255,0.5);font-size:18px;cursor:pointer;padding:2px 6px;border-radius:6px}
#chest-close:hover{color:#fff;background:rgba(255,255,255,0.1)}
#chest-cols{display:flex;gap:10px}
.chest-col{flex:1}
.chest-col-title{font-size:11px;font-weight:900;color:#fbbf24;margin-bottom:7px;text-align:center}
.chest-col-grid{display:flex;flex-wrap:wrap;gap:4px;justify-content:flex-start;min-height:50px}
.ch-slot{width:48px;height:56px;background:rgba(0,0,0,0.5);border:1.5px solid rgba(255,255,255,0.2);
  border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:20px;cursor:pointer;transition:all 0.14s;position:relative}
.ch-slot:hover{border-color:#fbbf24;background:rgba(251,191,36,0.15);transform:scale(1.07)}
.ch-slot-name{font-size:7px;font-weight:700;color:rgba(255,255,255,0.7);margin-top:2px;text-align:center}
.ch-slot-count{position:absolute;top:3px;right:4px;font-size:9px;font-weight:900;color:#fde047}
.ch-empty{font-size:11px;color:rgba(255,255,255,0.3);text-align:center;width:100%;padding:8px 0}
.chest-divider{width:1px;background:rgba(255,255,255,0.12);margin:0 4px}
#chest-hint{font-size:9px;color:rgba(255,255,255,0.35);text-align:center;margin-top:10px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.08)}

/* ===== CINEMATIC INTRO ===== */
#cinematic-overlay{
  position:absolute;top:0;left:0;width:100%;height:100%;
  background:#000;z-index:999;pointer-events:auto;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;overflow:hidden;
}
#cinematic-canvas{
  position:absolute;top:0;left:0;width:100%;height:100%;
}
#cinematic-letterbox-top{
  position:absolute;top:0;left:0;width:100%;height:80px;
  background:#000;z-index:10;transition:height 1s ease;
}
#cinematic-letterbox-bot{
  position:absolute;bottom:0;left:0;width:100%;height:80px;
  background:#000;z-index:10;transition:height 1s ease;
}
#cinematic-subtitle{
  position:absolute;bottom:95px;left:50%;transform:translateX(-50%);
  z-index:20;text-align:center;
  background:rgba(0,0,0,0.75);padding:10px 28px;border-radius:8px;
  font-size:17px;font-weight:700;color:#fffbe6;
  text-shadow:2px 2px 6px #000;letter-spacing:0.5px;
  opacity:0;transition:opacity 0.5s;white-space:nowrap;
  border:1px solid rgba(255,255,255,0.15);
}
#cinematic-skip{
  position:absolute;bottom:16px;right:18px;z-index:30;
  background:rgba(0,0,0,0.6);border:1.5px solid rgba(255,255,255,0.3);
  color:rgba(255,255,255,0.7);padding:6px 18px;border-radius:20px;
  cursor:pointer;font-size:12px;font-weight:700;
  transition:all 0.2s;
}
#cinematic-skip:hover{background:rgba(255,255,255,0.2);color:#fff;border-color:#fff;}

/* ===== TUTORIAL OVERLAY ===== */
#tutorial-overlay{
  position:absolute;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:200;
}
#tutorial-box{
  position:absolute;bottom:145px;left:50%;transform:translateX(-50%);
  background:rgba(5,20,5,0.97);border:2px solid rgba(253,224,71,0.8);
  border-radius:16px;padding:16px 24px;max-width:620px;min-width:380px;
  pointer-events:auto;
  box-shadow:0 4px 40px rgba(0,0,0,0.8),0 0 20px rgba(253,224,71,0.2);
  display:none;
}
#tutorial-title{font-size:14px;font-weight:900;color:#fde047;margin-bottom:8px;
  letter-spacing:1px;display:flex;align-items:center;gap:8px;}
#tutorial-text{font-size:13px;color:#e5e7eb;line-height:1.7;margin-bottom:12px;}
#tutorial-progress{display:flex;gap:6px;justify-content:center;margin-bottom:10px;}
.tut-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.25);transition:all 0.3s;}
.tut-dot.active{background:#fde047;transform:scale(1.3);}
.tut-dot.done{background:#4ade80;}
#tutorial-btn{background:rgba(253,224,71,0.2);border:1.5px solid #fde047;
  color:#fde047;padding:7px 22px;border-radius:20px;cursor:pointer;
  font-size:13px;font-weight:900;pointer-events:auto;transition:all 0.15s;
  display:block;margin:0 auto;}
#tutorial-btn:hover{background:rgba(253,224,71,0.4);}
#tutorial-arrow{
  position:absolute;font-size:32px;animation:arrowPulse 1s infinite alternate;
  display:none;pointer-events:none;z-index:201;filter:drop-shadow(0 0 8px rgba(253,224,71,0.8));
}
@keyframes arrowPulse{from{transform:scale(1) translateY(0);}to{transform:scale(1.2) translateY(-8px);}}
#tutorial-highlight{
  position:absolute;border:3px solid rgba(253,224,71,0.9);border-radius:12px;
  pointer-events:none;display:none;z-index:200;
  animation:highlightPulse 1s infinite alternate;
  box-shadow:0 0 20px rgba(253,224,71,0.5);
}
@keyframes highlightPulse{from{box-shadow:0 0 10px rgba(253,224,71,0.4);}to{box-shadow:0 0 25px rgba(253,224,71,0.9);}}

/* ITEM DETAIL PANEL */
#item-detail{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:none;pointer-events:auto;
  background:rgba(5,15,5,0.97);border:2px solid rgba(253,224,71,0.7);border-radius:18px;
  width:300px;max-height:580px;flex-direction:column;overflow:hidden;
  box-shadow:0 4px 40px rgba(0,0,0,0.8),0 0 0 1px rgba(253,224,71,0.15);z-index:200}
#item-detail-header{padding:20px 26px 0;flex-shrink:0}
#item-detail-scroll{flex:1;overflow-y:auto;padding:0 26px 14px;scrollbar-width:thin;scrollbar-color:rgba(253,224,71,0.3) transparent}
#item-detail-scroll::-webkit-scrollbar{width:4px}
#item-detail-scroll::-webkit-scrollbar-track{background:transparent}
#item-detail-scroll::-webkit-scrollbar-thumb{background:rgba(253,224,71,0.3);border-radius:4px}
#item-detail-footer{padding:0 26px 16px;flex-shrink:0;border-top:1px solid rgba(255,255,255,0.07);padding-top:12px}
#item-detail *{pointer-events:auto}
#item-detail-close{position:absolute;top:10px;right:14px;background:none;border:none;color:rgba(255,255,255,0.5);font-size:18px;cursor:pointer;padding:2px 6px;border-radius:6px}
#item-detail-close:hover{color:#fff;background:rgba(255,255,255,0.1)}
