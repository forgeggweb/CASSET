  _cabinMsg(t){ this.cabinMsg=t; this.cabinMsgTimer=3; }

  /* Cabin room object hitboxes (screen coords, fixed 1024x700) */
  _cabinObjects(){
    // RX=200 RY=60 RW=624 RH=580; floorY = RY+RH*0.44 = 315
    // fogon: fX=RX+30=230, fY=floorY+20=335, fW=90, fH=60
    // bed: bX=RX+30=230, bY=floorY+110=425
    // chest: cX=RX+RW-180=644, cY=floorY+20=335
    // door: dX=RX+RW/2-52=460, dY=floorY+RH*0.38 ~= 555
    return {
      fogon: {x:230, y:335, w:90,  h:60,  emoji:'🔥', label:'Fogón'},
      bed:   {x:230, y:425, w:160, h:80,  emoji:'🛏️', label:'Camita de paja'},
      chest: {x:644, y:335, w:120, h:86,  emoji:'📦', label:'Cofre viejo'},
      door:  {x:460, y:555, w:104, h:85,  emoji:'🚪', label:'Salir'},
    };
  }

  updateCabin(dt){
    const cp=this.cabinPlayer;
    if(!cp) return;
    cp.frame+=dt*8;
    // El fogón sigue cocinando mientras estás dentro
    this._updateCampFireState(dt);
    if(this.cabinMsgTimer>0) this.cabinMsgTimer-=dt;
    if(this.cabinSleeping){
      this.cabinSleepTimer-=dt;
      if(this.cabinSleepTimer<=0){
        this.cabinSleeping=false;
        this.gameTime=8*60;
        this.gameDay++;
        this._cabinMsg(`☀️ ¡Buenos días! Día ${this.gameDay}`);
        sfx.tada();
      }
      return;
    }
    // Move player inside cabin
    const dx=cp.tx-cp.x, dy=cp.ty-cp.y, d=Math.hypot(dx,dy);
    const spd=180;
    if(d>4){
      cp.x+=dx/d*spd*dt; cp.y+=dy/d*spd*dt;
      cp.facingRight=dx>0; cp.state='walk';
    } else {
      cp.x=cp.tx; cp.y=cp.ty; cp.state='idle';
    }
    // Check proximity to target object — trigger when close enough
    if(this.cabinInteract){
      const obj=this._cabinObjects()[this.cabinInteract];
      if(obj){
        const od=Math.hypot(cp.x-(obj.x+obj.w/2), cp.y-(obj.y+obj.h));
        if(od<60){
          const action=this.cabinInteract;
          this.cabinInteract=null;
          if(action==='bed') this._startSleep();
          else if(action==='fogon') this.openFogon();
          else if(action==='chest') this.openChestPanel();
          else if(action==='door'){ this.closeCabinInterior(); return; }
        }
      }
    }
    // Clamp inside room — RX=200..824, floorY~315..640
    cp.x=Math.max(215,Math.min(810,cp.x));
    cp.y=Math.max(310,Math.min(635,cp.y));
  }
  _startSleep(){
    if(this.cabinSleeping) return;
    this.cabinSleeping=true;
    this.cabinSleepTimer=2.5;
    this._cabinMsg('😴 Durmiendo... zzzz');
    sfx.eat();
  }

