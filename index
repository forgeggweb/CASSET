  // Cuenta un tipo de item sumando dropped items cercanos + carriedItem
  _countNearby(type){
    const px=this.player?.x||0, py=this.player?.y||0;
    let total=0;
    for(const di of DROPPED_ITEMS){
      if(di.type===type && Math.hypot(di.x-px,di.y-py)<220) total+=di.count;
    }
    if(this.player?.carriedItem?.type===type) total+=(this.player.carriedItem.count||1);
    return total;
  }

