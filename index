  drawCabin(){
    const t=this.t;
    const W=1024, H=700;

    // === CARPA IMPROVISADA — interior ===
    // Solo se usa la mitad central de la pantalla
    const RX=200, RY=60, RW=624, RH=580; // room bounds

    // --- FONDO EXTERIOR (afuera de la carpa — pasto nocturno) ---
    ctx.fillStyle='#1a3a1a'; ctx.fillRect(0,0,W,H);
    // Pasto exterior rústico
    ctx.fillStyle='#2d5a1b';
    for(let i=0;i<40;i++){
      const gx=(i*137.5)%W, gy=50+(i*73)%600;
      if(gx<RX||gx>RX+RW||gy<RY||gy>RY+RH){
        ctx.fillRect(gx,gy,2,5+(i%4)*2);
      }
    }

    // --- LONA DE LA CARPA (paredes inclinadas de tela) ---
    // Sombra
    ctx.fillStyle='rgba(0,0,0,0.40)';
    ctx.fillRect(RX+8,RY+8,RW,RH);
    // Lona izquierda exterior
    const lonaLG = ctx.createLinearGradient(RX, RY, RX+RW*0.5, RY+RH*0.4);
    lonaLG.addColorStop(0,'#92400e'); lonaLG.addColorStop(0.6,'#78350f'); lonaLG.addColorStop(1,'#5c2d08');
    ctx.fillStyle=lonaLG;
    ctx.beginPath();
    ctx.moveTo(RX+RW/2, RY);       // pico central arriba
    ctx.lineTo(RX, RY+RH*0.38);    // esquina izq
    ctx.lineTo(RX, RY+RH);         // base izq
    ctx.lineTo(RX+RW/2, RY+RH);    // base centro
    ctx.closePath(); ctx.fill();
    // Lona derecha exterior
    const lonaRG = ctx.createLinearGradient(RX+RW, RY, RX+RW*0.5, RY+RH*0.4);
    lonaRG.addColorStop(0,'#b45309'); lonaRG.addColorStop(0.6,'#92400e'); lonaRG.addColorStop(1,'#78350f');
    ctx.fillStyle=lonaRG;
    ctx.beginPath();
    ctx.moveTo(RX+RW/2, RY);
    ctx.lineTo(RX+RW, RY+RH*0.38);
    ctx.lineTo(RX+RW, RY+RH);
    ctx.lineTo(RX+RW/2, RY+RH);
    ctx.closePath(); ctx.fill();
    // Línea de costuras verticales en la lona
    ctx.strokeStyle='rgba(0,0,0,0.12)'; ctx.lineWidth=1.5;
    for(let i=0;i<5;i++){
      ctx.beginPath();
      ctx.moveTo(RX+RW/2, RY+8);
      ctx.lineTo(RX+i*(RW/4), RY+RH);
      ctx.stroke();
    }
    // Costura central (mástil)
    ctx.strokeStyle='rgba(0,0,0,0.2)'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.moveTo(RX+RW/2, RY); ctx.lineTo(RX+RW/2, RY+RH); ctx.stroke();
    // Borde exterior de la lona
    ctx.strokeStyle='#3d1a07'; ctx.lineWidth=5;
    ctx.beginPath();
    ctx.moveTo(RX+RW/2, RY);
    ctx.lineTo(RX, RY+RH*0.38);
    ctx.moveTo(RX+RW/2, RY);
    ctx.lineTo(RX+RW, RY+RH*0.38);
    ctx.stroke();
    ctx.strokeStyle='#2d1206'; ctx.lineWidth=3;
    ctx.strokeRect(RX, RY+RH*0.38, RW, RH*(1-0.38));

    // --- INTERIOR: suelo de tierra apisonada ---
    const floorY=RY+RH*0.44;
    const floorG=ctx.createLinearGradient(RX,floorY,RX,RY+RH);
    floorG.addColorStop(0,'#6b4423'); floorG.addColorStop(0.5,'#5a3618'); floorG.addColorStop(1,'#3d2009');
    ctx.fillStyle=floorG; ctx.fillRect(RX,floorY,RW,RH-(floorY-RY));
    // Textura de tierra
    ctx.strokeStyle='rgba(0,0,0,0.12)'; ctx.lineWidth=1;
    for(let i=0;i<8;i++){
      ctx.beginPath();ctx.moveTo(RX,floorY+i*28+8);ctx.lineTo(RX+RW,floorY+i*28+(i%3===0?14:4));ctx.stroke();
    }
    // Piedritas
    [[RX+60,floorY+30],[RX+RW-100,floorY+50],[RX+RW/2+80,floorY+80],[RX+150,floorY+100]].forEach(([px,py])=>{
      ctx.fillStyle='#6b7280'; ctx.globalAlpha=0.5;
      ctx.beginPath();ctx.ellipse(px,py,5,3,0.3,0,Math.PI*2);ctx.fill();
      ctx.globalAlpha=1;
    });

    // --- INTERIOR: paredes de lona (por dentro, más cálidas) ---
    const wallG=ctx.createLinearGradient(RX,RY,RX,floorY);
    wallG.addColorStop(0,'#7c3a12'); wallG.addColorStop(1,'#a05020');
    ctx.fillStyle=wallG; ctx.fillRect(RX,RY,RW,floorY-RY);
    // Pliegues interiores de la lona
    ctx.strokeStyle='rgba(0,0,0,0.10)'; ctx.lineWidth=1.5;
    for(let i=0;i<6;i++){
      ctx.beginPath();
      ctx.moveTo(RX+RW/2, RY+10);
      ctx.lineTo(RX + i*(RW/5), floorY);
      ctx.stroke();
    }
    // Costuras horizontales
    ctx.strokeStyle='rgba(0,0,0,0.08)'; ctx.lineWidth=1;
    for(let i=0;i<5;i++){ ctx.beginPath();ctx.moveTo(RX,RY+i*44+20);ctx.lineTo(RX+RW,RY+i*44+20);ctx.stroke(); }
    // Zócalo (donde la lona toca el suelo)
    ctx.fillStyle='#3d1a07'; ctx.fillRect(RX,floorY-6,RW,8);

    // --- MÁSTIL CENTRAL (el palo que sostiene la carpa) ---
    ctx.strokeStyle='#4a2c0e'; ctx.lineWidth=8; ctx.lineCap='round';
    ctx.beginPath(); ctx.moveTo(RX+RW/2, RY+10); ctx.lineTo(RX+RW/2, floorY-10); ctx.stroke();
    ctx.lineCap='butt';
    // Remate del mástil
    ctx.fillStyle='#d97706';
    ctx.beginPath(); ctx.arc(RX+RW/2, RY+12, 10, 0, Math.PI*2); ctx.fill();
    ctx.strokeStyle='#92400e'; ctx.lineWidth=2; ctx.stroke();

    // --- VENTILACIÓN superior (agujero en el pico de la carpa) ---
    ctx.fillStyle='rgba(180,220,255,0.12)';
    ctx.beginPath(); ctx.ellipse(RX+RW/2, RY+20, 30, 14, 0, 0, Math.PI*2); ctx.fill();
    // Luz que entra por arriba (rayo de luz tenue)
    ctx.save(); ctx.globalAlpha=0.06; ctx.fillStyle='#fde047';
    ctx.beginPath();
    ctx.moveTo(RX+RW/2-20, RY+28);
    ctx.lineTo(RX+RW/2-50, floorY-10);
    ctx.lineTo(RX+RW/2+50, floorY-10);
    ctx.lineTo(RX+RW/2+20, RY+28);
    ctx.closePath(); ctx.fill();
    ctx.globalAlpha=1; ctx.restore();

    // --- FOGONCITO en la esquina de la carpa ---
    const fX=RX+30, fY=floorY+20, fW=90, fH=60;
    const fogonLit = campfire.lit && campfire.fuel>0;
    const fogonNear = this.cabinPlayer&&Math.hypot(this.cabinPlayer.x-(fX+fW/2),this.cabinPlayer.y-(fY+fH))<100;
    // Piedras del fogón
    const stoneColors=['#6b7280','#4b5563','#9ca3af','#374151'];
    [[fX+5,fY+fH-14,32,14],[fX+fW-37,fY+fH-14,32,14],[fX+10,fY+fH-24,25,12],[fX+fW-35,fY+fH-22,28,12],[fX+25,fY+fH-8,fW-50,10]].forEach(([sx,sy,sw,sh],i)=>{
      ctx.fillStyle=stoneColors[i%4]; ctx.globalAlpha=0.85;
      ctx.beginPath();ctx.ellipse(sx+sw/2,sy+sh/2,sw/2,sh/2,0,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;ctx.stroke();
      ctx.globalAlpha=1;
    });
    // Brasas — solo rojas si está encendido, grises si apagado
    if(fogonLit){
      ctx.fillStyle='#7f1d1d'; ctx.beginPath();ctx.ellipse(fX+fW/2,fY+fH-8,22,7,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#dc2626'; ctx.globalAlpha=0.7;
      ctx.beginPath();ctx.ellipse(fX+fW/2,fY+fH-9,14,4,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#f97316'; ctx.globalAlpha=0.8;
      ctx.beginPath();ctx.ellipse(fX+fW/2,fY+fH-10,8,3,0,0,Math.PI*2);ctx.fill();
      ctx.globalAlpha=1;
      // Llamas animadas
      const fl=Math.sin(t*6)*3;
      [[fX+fW/2-8,24,0.6,'#f97316'],[fX+fW/2,32,0.8,'#fde047'],[fX+fW/2+8,20,0.55,'#f97316']].forEach(([fx,fh,op,fc])=>{
        ctx.fillStyle=fc; ctx.globalAlpha=op*(0.7+Math.sin(t*7+fx)*0.25);
        ctx.beginPath();
        ctx.moveTo(fx,fY+fH-10);
        ctx.quadraticCurveTo(fx+fl-4,fY+fH-10-fh*0.5,fx,fY+fH-10-fh);
        ctx.quadraticCurveTo(fx-fl+4,fY+fH-10-fh*0.5,fx,fY+fH-10);
        ctx.fill(); ctx.globalAlpha=1;
      });
      // Humo
      ctx.strokeStyle='rgba(180,180,180,0.18)'; ctx.lineWidth=2;
      for(let s=0;s<3;s++){
        const sy=(t*18+s*22)%55;
        ctx.globalAlpha=0.12+0.06*s;
        ctx.beginPath();ctx.moveTo(fX+fW/2+Math.sin(t*2+s)*4,fY+fH-10-sy);
        ctx.lineTo(fX+fW/2+Math.sin(t*2+s+1)*8,fY+fH-10-sy-12);ctx.stroke();
        ctx.globalAlpha=1;
      }
      // Barra de combustible encima del fogón
      const fuelPct=campfire.fuel/campfire.maxFuel;
      ctx.fillStyle='rgba(0,0,0,0.45)'; rr(ctx,fX,fY-18,fW,10,4); ctx.fill();
      ctx.fillStyle=fuelPct>0.4?'#f97316':'#ef4444';
      rr(ctx,fX+1,fY-17,Math.max(2,(fW-2)*fuelPct),8,3); ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.2)'; ctx.lineWidth=1; ctx.strokeRect(fX,fY-18,fW,10);
      // Si hay algo cocinándose, mostrar progreso
      if(campfire.cooking){
        const cp2=campfire.cooking.progress/campfire.cooking.total;
        ctx.fillStyle='rgba(0,0,0,0.45)'; rr(ctx,fX,fY-32,fW,10,4); ctx.fill();
        ctx.fillStyle='#fde047';
        rr(ctx,fX+1,fY-31,Math.max(2,(fW-2)*cp2),8,3); ctx.fill();
        ctx.strokeStyle='rgba(255,220,0,0.3)'; ctx.lineWidth=1; ctx.strokeRect(fX,fY-32,fW,10);
        ctx.font='bold 9px Arial'; ctx.fillStyle='#fde047'; ctx.textAlign='center';
        ctx.fillText(campfire.cooking.recipe.emoji+' '+(campfire.cooking.recipe.name.split(' ')[0])+'...',fX+fW/2,fY-35);
      }
    } else {
      // Apagado — cenizas grises
      ctx.fillStyle='#6b7280'; ctx.globalAlpha=0.5;
      ctx.beginPath();ctx.ellipse(fX+fW/2,fY+fH-9,16,5,0,0,Math.PI*2);ctx.fill();
      ctx.globalAlpha=1;
    }
    // Label fogón con estado
    ctx.font='bold 10px Arial';
    ctx.fillStyle=fogonLit?'rgba(255,180,60,0.9)':'rgba(180,180,180,0.7)';
    ctx.textAlign='center';
    ctx.fillText(fogonLit?'🔥 Fogón':'💨 Fogón (apagado)',fX+fW/2,fY+fH+14);
    // Prompt de interacción
    if(fogonNear && document.getElementById('camp-panel').style.display!=='block'){
      ctx.font='bold 10px Arial'; ctx.fillStyle='rgba(255,255,255,0.85)'; ctx.textAlign='center';
      ctx.fillText('[ Clic para usar ]',fX+fW/2,fY+fH+26);
    }

    // --- CAMA HUMILDE (colchón de paja en el suelo!) ---
    const bX=RX+30, bY=floorY+110, bW=160, bH=80;
    // Sombra
    ctx.fillStyle='rgba(0,0,0,0.2)'; ctx.beginPath();ctx.ellipse(bX+bW/2,bY+bH+4,bW*0.42,7,0,0,Math.PI*2);ctx.fill();
    // Base de paja (colchón en el suelo, sin patas!)
    const hayG=ctx.createLinearGradient(bX,bY,bX,bY+bH);
    hayG.addColorStop(0,'#d97706'); hayG.addColorStop(0.6,'#b45309'); hayG.addColorStop(1,'#92400e');
    ctx.fillStyle=hayG; rr(ctx,bX,bY+10,bW,bH-10,5); ctx.fill();
    ctx.strokeStyle='#78350f'; ctx.lineWidth=1.5; ctx.stroke();
    // Líneas de paja
    ctx.strokeStyle='rgba(255,220,80,0.25)'; ctx.lineWidth=1;
    for(let i=0;i<8;i++){ctx.beginPath();ctx.moveTo(bX+4,bY+14+i*8);ctx.lineTo(bX+bW-4,bY+14+i*8+(i%2===0?2:-2));ctx.stroke();}
    // Manta raída — solo una manta simple sin almohada lujosa
    const blanketG=ctx.createLinearGradient(bX,bY,bX,bY+bH-20);
    blanketG.addColorStop(0,'#854d0e'); blanketG.addColorStop(1,'#713f12');
    ctx.fillStyle=blanketG; rr(ctx,bX+4,bY,bW-8,bH-22,4); ctx.fill();
    ctx.strokeStyle='#5c3a1a'; ctx.lineWidth=1; ctx.stroke();
    // Parches en la manta (humildad!)
    [[bX+20,bY+12,28,14,'#7c2d12'],[bX+bW-60,bY+8,30,16,'#6b3a1f']].forEach(([px,py,pw,ph,pc])=>{
      ctx.fillStyle=pc; ctx.globalAlpha=0.6;
      rr(ctx,px,py,pw,ph,3); ctx.fill();
      ctx.strokeStyle='rgba(0,0,0,0.2)'; ctx.lineWidth=0.8; ctx.stroke();
      ctx.globalAlpha=1;
    });
    // Almohada improvisada (un bulto de tela)
    ctx.fillStyle='#92400e'; rr(ctx,bX+bW-50,bY+2,44,22,8); ctx.fill();
    ctx.strokeStyle='#5c3317'; ctx.lineWidth=1; ctx.stroke();
    // Costuras visibles de la almohada
    ctx.strokeStyle='rgba(255,255,255,0.15)'; ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(bX+bW-28,bY+4);ctx.lineTo(bX+bW-28,bY+22);ctx.stroke();
    // Zzz si está durmiendo
    if(this.cabinSleeping){
      const zz=['z','z','Z'];
      zz.forEach((z,i)=>{
        const ox=Math.sin(t*2+i)*4;
        ctx.save();ctx.globalAlpha=0.5+Math.sin(t*3+i)*0.3;
        ctx.font=`bold ${12+i*3}px Arial`;ctx.fillStyle='#a5f3fc';ctx.textAlign='center';
        ctx.fillText(z,bX+bW/2+15+i*12+ox,bY-8-i*12-((t*18+i*35)%50));
        ctx.restore();
      });
    }
    // Prompt cama
    const bedObj=this._cabinObjects().bed;
    const pnear=this.cabinPlayer&&Math.hypot(this.cabinPlayer.x-(bedObj.x+bedObj.w/2),this.cabinPlayer.y-(bedObj.y+bedObj.h))<120;
    if(pnear&&!this.cabinSleeping){ctx.font='bold 10px Arial';ctx.fillStyle='rgba(255,255,255,0.8)';ctx.textAlign='center';ctx.fillText('[ Clic para dormir ]',bX+bW/2,bY+bH+16);}

    // --- COFRE viejo y desgastado ---
    const cX=RX+RW-180, cY=floorY+20, cW=120, cH=86;
    // Sombra
    ctx.fillStyle='rgba(0,0,0,0.2)'; ctx.beginPath();ctx.ellipse(cX+cW/2,cY+cH+4,cW*0.38,6,0,0,Math.PI*2);ctx.fill();
    // Cuerpo del cofre (madera vieja, más oscura y con rayaduras)
    const chG=ctx.createLinearGradient(cX,cY,cX,cY+cH);
    chG.addColorStop(0,'#5c3317'); chG.addColorStop(0.5,'#4a2c0e'); chG.addColorStop(1,'#2d1206');
    ctx.fillStyle=chG; rr(ctx,cX,cY+cH*0.4,cW,cH*0.6,4); ctx.fill();
    ctx.strokeStyle='#1a0a04'; ctx.lineWidth=2; ctx.stroke();
    // Rayaduras en el cofre
    ctx.strokeStyle='rgba(0,0,0,0.25)'; ctx.lineWidth=1;
    [[cX+10,cY+cH*0.45,cX+30,cY+cH*0.7],[cX+50,cY+cH*0.5,cX+45,cY+cH*0.8],[cX+cW-20,cY+cH*0.42,cX+cW-30,cY+cH*0.65]].forEach(([x1,y1,x2,y2])=>{
      ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
    });
    // Tapa del cofre
    const chObj=this._cabinObjects().chest;
    const cnear=this.cabinPlayer&&Math.hypot(this.cabinPlayer.x-(chObj.x+chObj.w/2),this.cabinPlayer.y-(chObj.y+chObj.h))<120;
    const chestOpen=document.getElementById('chest-panel').style.display==='block';
    const lidAngle=chestOpen?-0.6:0;
    ctx.save();ctx.translate(cX,cY+cH*0.4);ctx.rotate(lidAngle);
    const lidG=ctx.createLinearGradient(0,-cH*0.42,0,0);
    lidG.addColorStop(0,'#6b3f1a'); lidG.addColorStop(1,'#5c3317');
    ctx.fillStyle=lidG; rr(ctx,0,-cH*0.42,cW,cH*0.42,4); ctx.fill();
    ctx.strokeStyle='#1a0a04'; ctx.lineWidth=2; ctx.stroke();
    // Rayaduras en la tapa
    ctx.strokeStyle='rgba(0,0,0,0.2)'; ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(15,-cH*0.35);ctx.lineTo(10,-cH*0.1);ctx.stroke();
    ctx.restore();
    // Bisagras oxidadas (en vez de banda metálica brillante)
    ctx.fillStyle='#78716c'; ctx.globalAlpha=0.7;
    [[cX+12,cY+cH*0.4-3],[cX+cW-20,cY+cH*0.4-3]].forEach(([hx,hy])=>{
      ctx.fillRect(hx,hy,8,7);
    });
    ctx.globalAlpha=1;
    // Cerrojo oxidado (sin brillo dorado)
    ctx.fillStyle='#78716c'; rr(ctx,cX+cW/2-8,cY+cH*0.4-5,16,10,3); ctx.fill();
    ctx.strokeStyle='#57534e'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='#44403c'; ctx.beginPath();ctx.arc(cX+cW/2,cY+cH*0.4+1,2.5,0,Math.PI*2);ctx.fill();
    if(cnear&&!chestOpen){ctx.font='bold 10px Arial';ctx.fillStyle='rgba(255,255,255,0.8)';ctx.textAlign='center';ctx.fillText('[ Clic para abrir ]',cX+cW/2,cY+cH+18);}

    // --- PUERTA (más pequeña, rústica, sin paneles elaborados) ---
    const dX=RX+RW/2-52, dY=floorY+RH*0.38, dW=104, dH=RY+RH-dY-4;
    // Marco tosco
    ctx.fillStyle='#2d1206'; ctx.fillRect(dX-6,dY-4,dW+12,dH+4);
    // Tabla de la puerta (tablones verticales simples)
    for(let i=0;i<3;i++){
      const pDoor=ctx.createLinearGradient(dX+i*(dW/3),dY,dX+i*(dW/3),dY+dH);
      pDoor.addColorStop(0,'#5c3317'); pDoor.addColorStop(1,'#3d1f08');
      ctx.fillStyle=pDoor;
      ctx.fillRect(dX+i*(dW/3)+1,dY,dW/3-2,dH);
    }
    ctx.strokeStyle='#2d1206'; ctx.lineWidth=1.5;
    for(let i=1;i<3;i++){ctx.beginPath();ctx.moveTo(dX+i*(dW/3),dY);ctx.lineTo(dX+i*(dW/3),dY+dH);ctx.stroke();}
    // Refuerzo horizontal (travesaño)
    ctx.fillStyle='#3d1a07'; ctx.fillRect(dX,dY+dH*0.35,dW,7);
    ctx.fillRect(dX,dY+dH*0.7,dW,7);
    // Manija simple (palito de madera)
    ctx.fillStyle='#78350f'; ctx.beginPath();ctx.arc(dX+14,dY+dH/2,5,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='#2d1206'; ctx.lineWidth=1; ctx.stroke();
    // Borde de la puerta
    ctx.strokeStyle='#1a0a04'; ctx.lineWidth=2; ctx.strokeRect(dX,dY,dW,dH);
    ctx.font='bold 10px Arial'; ctx.fillStyle='rgba(255,255,255,0.75)'; ctx.textAlign='center';
    ctx.fillText('[ Salir ]',dX+dW/2,dY+dH+16);

    // --- PLAYER inside cabin ---
    if(this.cabinPlayer){
      const cp=this.cabinPlayer;
      ctx.save();ctx.translate(cp.x, cp.y);
      drawChar(ctx,this.player.char,cp.frame,cp.state,cp.facingRight,true,1,this.player.funnyAnim!=='none'?this.player.funnyAnim:'none');
      ctx.restore();
      // Name tag
      ctx.fillStyle='rgba(0,0,0,0.65)';ctx.strokeStyle='rgba(255,255,255,0.4)';ctx.lineWidth=1;
      const nw=ctx.measureText(this.player.char.name).width+14;
      ctx.font='bold 12px Arial';ctx.textAlign='center';
      rr(ctx,cp.x-nw/2,cp.y-108,nw,17,4);ctx.fill();ctx.stroke();
      ctx.fillStyle='#fff';ctx.fillText(this.player.char.name,cp.x,cp.y-95);
    }

    // --- HUD: top bar ---
    ctx.fillStyle='rgba(0,0,0,0.55)'; rr(ctx,8,8,240,36,10); ctx.fill();
    ctx.strokeStyle='rgba(217,119,6,0.6)'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.font='bold 13px Arial'; ctx.fillStyle='#fbbf24'; ctx.textAlign='left';
    ctx.fillText('⛺ Carpa Improvisada  · Día '+this.gameDay,18,31);
    // Exit button (always visible)
    ctx.fillStyle='rgba(0,0,0,0.7)'; rr(ctx,W-130,8,120,36,10); ctx.fill();
    ctx.strokeStyle='rgba(239,68,68,0.7)'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.font='bold 13px Arial'; ctx.fillStyle='#fca5a5'; ctx.textAlign='center';
    ctx.fillText('🚪 Salir  [ESC]',W-70,31);

    // --- MSG ---
    if(this.cabinMsgTimer>0){
      ctx.font='bold 14px Arial'; ctx.textAlign='center';
      const mw=ctx.measureText(this.cabinMsg).width+24;
      ctx.fillStyle='rgba(0,0,0,0.82)'; rr(ctx,W/2-mw/2,H-80,mw,34,18); ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.3)'; ctx.lineWidth=1.5; ctx.stroke();
      ctx.fillStyle='#fff'; ctx.fillText(this.cabinMsg,W/2,H-57);
    }

    // --- SLEEP OVERLAY ---
    if(this.cabinSleeping){
      const alpha=Math.min(1,(2.5-this.cabinSleepTimer)/1.2)*0.7;
      ctx.fillStyle=`rgba(10,5,30,${alpha})`; ctx.fillRect(0,0,W,H);
      if(alpha>0.3){
        ctx.font='bold 28px Arial'; ctx.fillStyle='rgba(165,243,252,0.9)'; ctx.textAlign='center';
        ctx.fillText('😴 Durmiendo... zzzZ',W/2,H/2);
      }
    }
  }

  /* ---- CHEST PANEL ---- */
  openChestPanel(){
    const panel=document.getElementById('chest-panel');
    panel.style.display='block';
    document.getElementById('c').style.pointerEvents='none';
    this._buildChestGrids();
    sfx.coin();
  }
  closeChestPanel(){
    document.getElementById('chest-panel').style.display='none';
    document.getElementById('c').style.pointerEvents='auto';
  }
  _buildChestGrids(){
    // --- Columna inventario del jugador ---
    const invG=document.getElementById('chest-inv-grid');
    invG.innerHTML='';
    const filledInv=Object.entries(inventory).filter(([,c])=>c>0);
    for(const [type,count] of filledInv){
      const it=ITEMS[type]; if(!it) continue;
      const s=document.createElement('div'); s.className='ch-slot';
      s.innerHTML=`${itemSVG(type,22)}<div class="ch-slot-name">${it.name}</div><span class="ch-slot-count">x${count}</span>`;
      s.title='Guardar '+it.name+' en cofre';
      s.onclick=()=>{
        // Verificar si cabe en el baúl (slot nuevo o ya existe)
        if((chestStorage[type]||0)===0 && chestSlotCount()>=CHEST_MAX_SLOTS){
          this._cabinMsg('📦 ¡Baúl lleno! ('+CHEST_MAX_SLOTS+' slots)'); return;
        }
        inventory[type]--; chestStorage[type]=(chestStorage[type]||0)+1;
        updateInventoryUI(); this._buildChestGrids(); sfx.collect(); this._cabinMsg('📦 '+it.emoji+' guardado');
      };
      invG.appendChild(s);
    }
    // Slots vacíos del inventario
    for(let i=0;i<INV_MAX_SLOTS-filledInv.length;i++){
      const s=document.createElement('div'); s.className='ch-slot';
      s.style.opacity='0.25'; s.style.cursor='default';
      s.innerHTML=`<span style="font-size:14px">—</span>`;
      invG.appendChild(s);
    }
    // Capacidad inventario
    const invCap=document.createElement('div');
    invCap.style.cssText='width:100%;text-align:center;font-size:9px;color:rgba(255,220,100,0.5);margin-top:4px';
    invCap.textContent=`${filledInv.length}/${INV_MAX_SLOTS} slots`;
    invG.appendChild(invCap);

    // --- Columna baúl ---
    const chG=document.getElementById('chest-stored-grid');
    chG.innerHTML='';
    const filledCh=Object.entries(chestStorage).filter(([,c])=>c>0);
    for(const [type,count] of filledCh){
      const it=ITEMS[type]; if(!it) continue;
      const s=document.createElement('div'); s.className='ch-slot';
      s.style.borderColor='rgba(251,191,36,0.45)';
      s.innerHTML=`${itemSVG(type,22)}<div class="ch-slot-name">${it.name}</div><span class="ch-slot-count">x${count}</span>`;
      s.title='Tomar '+it.name+' del cofre';
      s.onclick=()=>{
        // Verificar si cabe en el inventario
        if((inventory[type]||0)===0 && invSlotCount()>=INV_MAX_SLOTS){
          this._cabinMsg('🎒 ¡Mochila llena! ('+INV_MAX_SLOTS+' slots)'); return;
        }
        chestStorage[type]--; addItem(type); this._buildChestGrids(); sfx.collect(); this._cabinMsg('🎒 '+it.emoji+' tomado');
      };
      chG.appendChild(s);
    }
    // Slots vacíos del baúl hasta 20
    for(let i=0;i<CHEST_MAX_SLOTS-filledCh.length;i++){
      const s=document.createElement('div'); s.className='ch-slot';
      s.style.opacity='0.18'; s.style.cursor='default';
      s.innerHTML=`<span style="font-size:12px">—</span>`;
      chG.appendChild(s);
    }
    // Capacidad baúl
    const chCap=document.createElement('div');
    chCap.style.cssText='width:100%;text-align:center;font-size:9px;color:rgba(255,220,100,0.5);margin-top:4px';
    chCap.textContent=`${filledCh.length}/${CHEST_MAX_SLOTS} slots`;
    chG.appendChild(chCap);
  }

  /* ---- SHOP INTERIOR ---- */
  openShopInterior(){
    // La "tienda" ahora es una carpa — entra físicamente como la cabaña
    this.openCabinInterior();
    this._cabinMsg('⛺ Tu carpa improvisada... descansa, guarda y cocina aquí');
  }
  closeShopInterior(){
    this.closeCabinInterior();
  }
  _buildShopGrid(){
    const grid=document.getElementById('shop-items-grid');
    if(!grid)return;
    grid.innerHTML='';
    SHOP_CATALOG.forEach(item=>{
      const it=ITEMS[item.id]; if(!it)return;
      // Buy card
      const buyCard=document.createElement('div');
      buyCard.className='shop-item';
      buyCard.innerHTML=`<span class="si-icon">${itemSVG(item.id,28)}</span><span class="si-name">${it.name}</span><span class="si-price">Comprar $${item.buy}</span>`;
      buyCard.onclick=()=>this._shopBuy(item.id,item.buy);
      grid.appendChild(buyCard);
      // Sell card (if player has it)
      if((inventory[item.id]||0)>0){
        const sellCard=document.createElement('div');
        sellCard.className='shop-item';
        sellCard.style.borderColor='rgba(74,222,128,0.4)';
        sellCard.innerHTML=`<span class="si-icon">${itemSVG(item.id,28)}</span><span class="si-name">Vender x${inventory[item.id]}</span><span class="si-price" style="color:#4ade80">+$${item.sell} c/u</span>`;
        sellCard.onclick=()=>this._shopSell(item.id,item.sell);
        grid.appendChild(sellCard);
      }
    });
    document.getElementById('shop-money-val').textContent=Math.floor(this.player?.money||0);
  }
  _shopBuy(itemId, price){
    if(!this.player||this.player.money<price){ this._msg('💸 No tienes suficiente dinero'); return; }
    this.player.money-=price;
    addItem(itemId);
    sfx.coin();
    this._msg(`🛒 Compraste ${ITEMS[itemId]?.emoji} ${ITEMS[itemId]?.name}`);
    document.getElementById('vm').textContent='$'+Math.floor(this.player.money);
    this._buildShopGrid();
  }
  _shopSell(itemId, price){
    if(!this.player||(inventory[itemId]||0)<=0){ this._msg('❌ No tienes ese item'); return; }
    inventory[itemId]--;
    this.player.money+=price;
    updateInventoryUI();
    sfx.coin();
    this._msg(`💰 Vendiste ${ITEMS[itemId]?.emoji} por $${price}`);
    document.getElementById('vm').textContent='$'+Math.floor(this.player.money);
    this._buildShopGrid();
  }
  _updateBuildings(dt){
    for(const bld of PLACED_BUILDINGS){
      if(!bld.data)continue;
