function updateMissionsHUD(){
  const hud = document.getElementById('missions-hud');
  if(!hud) return;
  // Show hud once game started
  if(!game?.player){ hud.style.display='none'; return; }
  hud.style.display='block';

  const active = MISSIONS.filter(m => m.visible() && !m.done());
  // dot: green if any craftable, purple otherwise
  const dot = document.getElementById('mt-dot');
  if(dot) dot.className = 'mt-dot' + (active.some(m=>m.canCraft()) ? ' active' : '');

  const list = document.getElementById('missions-list');
  if(!list) return;
  list.innerHTML='';

  if(active.length===0){
    list.innerHTML='<div style="font-size:11px;color:#4ade80;text-align:center;padding:6px">✅ ¡Sin misiones pendientes!</div>';
    return;
  }
  active.forEach(m=>{
    const chips = m.progress().map(p=>
      '<span class="mp-chip'+(p.done?' done':'')+'">' + p.label + '</span>'
    ).join('');
    const craftBtnHtml = m.canCraft() && m.craftLabel
      ? '<button class="mission-craft-btn" onclick="'+m.id+'_craft()" style="display:block">'+m.craftLabel+'</button>'
      : '';
    list.innerHTML +=
      '<div class="mission-item">' +
        '<div class="mission-icon">'+m.icon+'</div>' +
        '<div class="mission-body">' +
          '<div class="mission-name">'+m.name+'</div>' +
          '<div class="mission-desc">'+m.desc+'</div>' +
          '<div class="mission-progress">'+chips+'</div>' +
          craftBtnHtml +
        '</div>' +
      '</div>';
  });
}

function tutorialStart(){
