        cardY=cy-10-Math.abs(Math.sin(selAnim*8))*18;
        // Glow dorado
        ctx.shadowColor='rgba(253,224,71,0.8)';
        ctx.shadowBlur=28;
      }

      // Relleno de la card
      const cardGrad=ctx.createLinearGradient(cx-cardW/2,cardY-cardH/2,cx-cardW/2,cardY+cardH/2);
