      const recSection = document.createElement('div');
      recSection.style.cssText = 'margin-top:12px;padding-top:10px;border-top:1px solid rgba(255,255,255,0.1)';
      recSection.innerHTML = `<div style="font-size:9px;font-weight:900;color:rgba(245,200,66,0.6);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px">⚒️ Se usa en recetas</div>`;
      usedIn.forEach(r => {
        const needed = {};
        r.pattern.forEach(s => { if(s) needed[s] = (needed[s]||0)+1; });
        const canMake = Object.entries(needed).every(([id,qty]) => (inventory[id]||0) >= qty);
        const qtyNeeded = needed[type] || 1;

        // Build mini 3x3 pattern grid HTML
        const miniGridCells = r.pattern.map(s => {
          if(!s) return `<div style="width:22px;height:22px;background:rgba(30,15,3,0.7);border:1px solid rgba(160,98,42,0.2);border-radius:3px"></div>`;
          const isHighlighted = s === type;
          return `<div style="width:22px;height:22px;background:${isHighlighted?'rgba(245,200,66,0.2)':'rgba(60,35,10,0.8)'};border:1px solid ${isHighlighted?'rgba(245,200,66,0.6)':'rgba(160,98,42,0.4)'};border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0">${itemSVG(s,16)}</div>`;
        }).join('');

        const row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:10px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:8px 10px;margin-bottom:6px';
        row.innerHTML = `
          <div style="flex-shrink:0;display:grid;grid-template-columns:repeat(3,22px);grid-template-rows:repeat(3,22px);gap:2px">${miniGridCells}</div>
          <div style="width:1px;align-self:stretch;background:rgba(255,255,255,0.08);flex-shrink:0"></div>
          <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:4px">
            <div style="display:flex;align-items:center;gap:5px">
              <div style="width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center">${itemSVG(r.result.id,18)}</div>
              <div style="font-size:12px;font-weight:800;color:#fde047;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.name}</div>
            </div>
            <div style="font-size:9px;color:rgba(255,255,255,0.45)">Necesitás <span style="color:rgba(245,200,66,0.9);font-weight:700">${qtyNeeded}×</span> de este ítem</div>
            <div style="font-size:10px;font-weight:700;color:${canMake?'#4ade80':'#f87171'}">${canMake?'✅ Podés craftear':'❌ Te faltan materiales'}</div>
          </div>
        `;
        // no onclick — solo informativo
        recSection.appendChild(row);
      });
      descEl.appendChild(recSection);
    }
    const actDiv=document.getElementById('item-detail-actions');
    actDiv.innerHTML='';
    // Drop button
    const dropBtn=document.createElement('button');
    dropBtn.className='id-btn danger';
    dropBtn.innerHTML='🗑️ Soltar en suelo';
    dropBtn.onclick=()=>{
      if((inventory[type]||0)<=0){this._msg('¡No tienes ese ítem!');return;}
      const wx=this.player.x+(Math.random()-0.5)*60;
      const wy=this.player.y+(Math.random()-0.5)*40;
      inventory[type]--;
      updateInventoryUI();
      // merge with existing drop nearby
      const near=DROPPED_ITEMS.find(d=>d.type===type&&Math.hypot(d.x-wx,d.y-wy)<50);
      if(near){near.count++;}
      else DROPPED_ITEMS.push({id:Date.now(),type,x:wx,y:wy,count:1,bobOffset:Math.random()*Math.PI*2});
      sfx.boing();
      this._msg(`🗑️ ${it.name} soltado en el suelo`);
      this.closeItemDetail();
    };
    actDiv.appendChild(dropBtn);
    // Generic equip button for any item that has a mapped slot
    const targetSlot = ITEM_EQUIP_SLOT[type];
    if(targetSlot && count>0){
      const slot=EQUIP_SLOTS[targetSlot];
      const equipBtn=document.createElement('button');
      equipBtn.className='id-btn';
      if(slot && slot.item===type){
        // Already equipped
        equipBtn.innerHTML='✅ Equipado — clic para quitar';
        equipBtn.style.borderColor='#4ade80'; equipBtn.style.color='#4ade80';
        equipBtn.onclick=()=>{
          slot.item=null;
          inventory[type]=(inventory[type]||0)+1;
          if(type==='bag'){ bagEquipped=false; INV_MAX_SLOTS=5; }
          updateInventoryUI(); updateEquipBar(); sfx.boing();
          this._msg(`${ITEMS[type]?.name||type} desequipado`);
          this.closeItemDetail();
        };
      } else {
        const iName=ITEMS[type]?.name||type;
        equipBtn.innerHTML=`⚔️ Equipar — ${iName}`;
        equipBtn.onclick=()=>{
          // Return current item in that slot
          if(slot.item){
            inventory[slot.item]=(inventory[slot.item]||0)+1;
            if(slot.item==='bag'){ bagEquipped=false; INV_MAX_SLOTS=5; }
          }
          slot.item=type;
          inventory[type]--;
          if(type==='bag'){ bagEquipped=true; INV_MAX_SLOTS=10; STARTER_ZONE.visible=false; }
          updateInventoryUI(); updateEquipBar(); sfx.tada();
          this._msg(`⚔️ ¡${iName} equipado!`);
          this.closeItemDetail();
        };
      }
      actDiv.appendChild(equipBtn);
    }
    // Craft item shortcut if has placeable recipe
    const cr=CRAFT_RECIPES.find(r=>r.id===type&&r.placeable);
    if(cr&&count>0){
      const placeBtn=document.createElement('button');
      placeBtn.className='id-btn';
      placeBtn.innerHTML='⚒️ Colocar';
      placeBtn.onclick=()=>{this.startGhostPlacement(type);this.closeItemDetail();if(this.invOpen)this.toggleInventory();};
      actDiv.appendChild(placeBtn);
    }
    document.getElementById('item-detail').style.display='flex';
  }
