      this._nearbyDropped=null;
      return;
    }
    // Encontrar el item más cercano en el suelo
    let closest=null, bestDist=80;
    for(const di of DROPPED_ITEMS){
      const d=Math.hypot(this.player.x-di.x, this.player.y-di.y);
      if(d<bestDist){bestDist=d;closest=di;}
    }
    const hud=document.getElementById('pickup-hud');
    if(closest){
      this._drawHudIcon(document.getElementById('pickup-hud-icon'), closest.type);
      const name=ITEMS[closest.type]?.name||closest.type;
      document.getElementById('pickup-hud-label').textContent=name+(closest.count>1?' x'+closest.count:'');
      hud.style.display='flex';
      this._nearbyDropped=closest;
    } else {
      hud.style.display='none';
      this._nearbyDropped=null;
