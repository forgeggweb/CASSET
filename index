  startGhostPlacement(itemType){
    this.ghostMode={ itemType, wx: this.player?.x||3100, wy: this.player?.y||1600 };
    document.getElementById('ghost-hud').style.display='block';
    document.getElementById('ghost-cancel').style.display='block';
