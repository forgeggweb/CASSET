  craftBagFromGround(){
    if(bagEquipped){ this._msg('¡Ya tenés una bolsa equipada!'); return; }
    const px=this.player?.x||0, py=this.player?.y||0;
    // Collect nearby flowers (need 2)
    let flowersNeeded=2, logsNeeded=3;
    // First put carriedItem on ground temporarily for counting, then consume
    if(this.player.carriedItem){
      const ct=this.player.carriedItem.type;
      const cc=this.player.carriedItem.count||1;
      const near=DROPPED_ITEMS.find(d=>d.type===ct&&Math.hypot(d.x-px,d.y-py)<60);
      if(near) near.count+=cc;
      else DROPPED_ITEMS.push({id:Date.now(),type:ct,x:px,y:py,count:cc,bobOffset:0});
      this.player.carriedItem=null;
      this._hideCarryHUD();
    }
    // Verify we have enough
    const flowers=this._countNearby('flower'), logs=this._countNearby('log');
    if(flowers<2||logs<3){
      this._msg(`❌ Faltan materiales: 🌸 ${flowers}/2  🪵 ${logs}/3`);
      this._updateBagCraftHUD();
      return;
    }
    // Consume from DROPPED_ITEMS nearby
    const consume=(type, qty)=>{
      let left=qty;
      for(const di of DROPPED_ITEMS){
        if(di.type===type && Math.hypot(di.x-px,di.y-py)<220 && left>0){
          const take=Math.min(di.count,left);
          di.count-=take; left-=take;
        }
      }
      // Remove empty stacks
      for(let i=DROPPED_ITEMS.length-1;i>=0;i--){ if(DROPPED_ITEMS[i].count<=0) DROPPED_ITEMS.splice(i,1); }
    };
    consume('flower',2);
    consume('log',3);
    // Equip bag!
    bagEquipped=true;
    INV_MAX_SLOTS=5;
    sfx.tada();
    setTimeout(()=>sfx.funnyBounce(),300);
    this._msg('🎉 ¡Bolsa artesanal lista! Ahora podés guardar hasta 5 cosas 🎒');
    if(this.player) this.player.say(getVoice(this.player.char.trait).anim[0]||'🎒✨');
    STARTER_ZONE.visible=false;
    EQUIP_SLOTS.bolsa.item='bag';
    updateEquipBar();
    updateMissionsHUD();
    document.getElementById('inv-toggle').style.display='block';
    const saveBtn=document.getElementById('carry-save-btn');
    if(saveBtn) saveBtn.style.display='inline-block';
    updateInventoryUI();
  }

  loop(){
    const now=performance.now();const dt=Math.min((now-this.lastTime)/1000,0.1);this.lastTime=now;this.t+=dt;
    // Smooth zoom
    this.zoom=lerp(this.zoom,this.targetZoom,0.1);
    ctx.clearRect(0,0,1024,700);
    if(this.state==='title') this.drawTitle(dt);
    else if(this.state==='menu') { if(this.menuSelected>=0) this.menuSelTimer+=dt; this.drawMenu(); }
    else if(this.state==='cinematic') { /* CIN has its own canvas */ this.drawMenu(); }
    else if(this.state==='cabin'){
      this.updateCabin(dt);
      this.t+=dt;
      this.drawCabin();
    } else {
      if(this.player){
        this.player.update(dt);
        // Auto-pickup desactivado — se usa HUD de acción
        game._updatePickupHUD();
        // Redibujar íconos animados del HUD en cada frame
        if(document.getElementById('pickup-hud').style.display!=='none' && this._nearbyDropped){
          this._drawHudIcon(document.getElementById('pickup-hud-icon'), this._nearbyDropped.type);
        }
        if(document.getElementById('carry-hud').style.display!=='none' && this.player?.carriedItem){
          this._drawHudIcon(document.getElementById('carry-hud-icon'), this.player.carriedItem.type);
        }
        // Reveal fog around player each frame
        revealFog(this.player.x, this.player.y, 320);
        // Update exploration %
        const explored = fogGrid.filter(v=>v>0).length;
        const explPct = Math.floor(explored / fogGrid.length * 100);
        const pctEl = document.getElementById('explore-pct');
        if(pctEl) pctEl.textContent = explPct;
        this.gameTime+=dt*6;
        if(this.gameTime>=24*60){this.gameTime=0;this.gameDay++;this._msg(`☀️ ¡Día ${this.gameDay}!`);}
        const h=Math.floor(this.gameTime/60),m=Math.floor(this.gameTime%60);
        document.getElementById('day').textContent=this.gameDay;
        document.getElementById('time').textContent=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
        // Biome detection
        const locEl=document.getElementById('location');
        if(this.player.x>desertEdgeX(this.player.y)){
          locEl.textContent='🏜️ Bioma Desierto';locEl.style.borderColor='rgba(212,168,85,0.6)';
        } else if(this.player.y>5000){
          locEl.textContent='🌿 Campo del Sur';locEl.style.borderColor='rgba(74,222,128,0.4)';
        } else {
          locEl.textContent='🌿 Llanura del Valle';locEl.style.borderColor='rgba(255,255,255,0.3)';
        }
        this._updateCampFireState(dt);
        this._updateBuildings(dt);
        this.updateWeather(dt);
        // Respawn de spots farmeados
        for(const sp of SPOTS){if(sp.hidden&&sp.respawnTimer!==undefined){sp.respawnTimer-=dt;if(sp.respawnTimer<=0){sp.hidden=false;sp.respawnTimer=undefined;}}}
        this.tcam.x=this.player.x-512/this.zoom;this.tcam.y=this.player.y-350/this.zoom;
        this.tcam.x=Math.max(0,Math.min(WORLD.w-1024/this.zoom,this.tcam.x));
        this.tcam.y=Math.max(0,Math.min(WORLD.h-700/this.zoom,this.tcam.y));
        this.cam.x=lerp(this.cam.x,this.tcam.x,0.1);this.cam.y=lerp(this.cam.y,this.tcam.y,0.1);
        this.npcs.forEach(n=>n.update(dt));FAUNA.forEach(a=>a.update(dt));
      }
      this.drawField();
    }
    // === TENT TRANSITION OVERLAY (iris wipe) ===
    if(this.tentTrans){
      const tr=this.tentTrans;
      const speed=2.6; // duración total ~0.38s por mitad
      tr.t = Math.min(1, tr.t + dt * speed);

      // Al llegar al 50% (pantalla totalmente negra) → disparar cambio de estado
      if(tr.t >= 0.5 && !tr.midFired){
        tr.midFired = true;
        if(tr.onMid) tr.onMid();
      }
      // Al llegar al 100% → limpiar
      if(tr.t >= 1){ this.tentTrans = null; }
      else {
        // Iris circular: radio máximo cubre toda la pantalla
        const maxR = Math.sqrt(512*512 + 350*350) + 20;
        // dir 'in': empieza con pantalla visible (radio grande) → se cierra hasta 0
        //           t=0→radio=maxR, t=0.5→radio=0, t=0.5..1 →radio abre desde 0 a maxR
        let phase, r;
        if(tr.t < 0.5){
          phase = tr.t / 0.5; // 0→1 cierre
          r = maxR * (1 - phase);
        } else {
          phase = (tr.t - 0.5) / 0.5; // 0→1 apertura
          r = maxR * phase;
        }
        // Dibujar máscara circular negra
        ctx.save();
        ctx.fillStyle = '#000';
        ctx.beginPath();
        ctx.rect(0, 0, 1024, 700);
        // "recortar" el iris — usamos fillRule evenodd
        ctx.arc(512, 380, Math.max(0, r), 0, Math.PI * 2, true);
        ctx.fill('evenodd');

        // Partículas de tela volando (solo en la primera mitad)
        if(tr.t < 0.5 && !tr._particles){
          tr._particles = Array.from({length:12}, (_,i)=>({
            x: 512 + Math.cos(i/12*Math.PI*2)*80,
            y: 380 + Math.sin(i/12*Math.PI*2)*60,
            vx: (Math.random()-0.5)*300,
            vy: (Math.random()-0.5)*200 - 80,
            life: 0.5, emoji: ['✨','🍂','💨'][i%3]
          }));
        }
        if(tr._particles){
          tr._particles.forEach(p=>{
            p.x+=p.vx*dt; p.y+=p.vy*dt; p.life-=dt*2;
            if(p.life>0){
              ctx.globalAlpha = p.life;
              ctx.font='14px Arial'; ctx.textAlign='center';
              ctx.fillStyle='#fff';
              ctx.fillText(p.emoji, p.x, p.y);
            }
          });
          ctx.globalAlpha=1;
        }
        ctx.restore();
      }
    }
    requestAnimationFrame(()=>this.loop());
  }

