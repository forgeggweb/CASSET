/* ---- DRAG & DROP FROM INVENTORY TO WORLD ---- */
let _dragState = null; // {type, name, startX, startY}
const _dragGhost = ()=>document.getElementById('drag-ghost');
const _dragGhostIcon = ()=>document.getElementById('drag-ghost-icon');
const _dragGhostLabel = ()=>document.getElementById('drag-ghost-label');

function _addDragDrop(el, type, name){
  el.addEventListener('mousedown', e=>{
    if(e.button!==0) return;
    if(game.state!=='field') return;
    e.preventDefault(); e.stopPropagation();
    _dragState={type, name, active:false};
    const startX=e.clientX, startY=e.clientY;
    const onMove=ev=>{
      if(!_dragState) return;
      if(!_dragState.active){
        if(Math.hypot(ev.clientX-startX,ev.clientY-startY)<6) return;
        _dragState.active=true;
        const gh=_dragGhost();
        gh.style.display='flex';
        _dragGhostIcon().innerHTML=itemSVG(type,32);
        _dragGhostLabel().textContent=name;
      }
      const gh=_dragGhost();
      gh.style.left=ev.clientX+'px'; gh.style.top=ev.clientY+'px';
    };
    const onUp=ev=>{
      document.removeEventListener('mousemove',onMove);
      document.removeEventListener('mouseup',onUp);
      const gh=_dragGhost(); gh.style.display='none';
      if(!_dragState||!_dragState.active){ _dragState=null; return; }
      const type2=_dragState.type; _dragState=null;
      // Dropped on the canvas? Convert to world coords
      const wrap=document.getElementById('wrap');
      const rect=wrap.getBoundingClientRect();
      const mx=ev.clientX-rect.left, my=ev.clientY-rect.top;
      if(mx<0||mx>1024||my<0||my>700){ return; }
      if(game.state!=='field'||!game.player) return;
      if(!(inventory[type2]>0)){ game._msg('¡No tienes ese ítem!'); return; }
      const wx=mx/game.zoom+game.cam.x;
      const wy=my/game.zoom+game.cam.y;
      inventory[type2]--;
      updateInventoryUI();
      // Merge or create drop
      const near=DROPPED_ITEMS.find(d=>d.type===type2&&Math.hypot(d.x-wx,d.y-wy)<60);
      if(near){near.count++;}
      else DROPPED_ITEMS.push({id:Date.now(),type:type2,x:wx,y:wy,count:1,bobOffset:Math.random()*Math.PI*2});
      sfx.boing();
      game._msg(`🗑️ ${ITEMS[type2]?.name||type2} soltado en el campo`);
      // Close inv panel
      if(game.invOpen) game.toggleInventory();
    };
    document.addEventListener('mousemove',onMove);
    document.addEventListener('mouseup',onUp);
  });
  // Touch support
  el.addEventListener('touchstart', e=>{
    if(game.state!=='field') return;
    const touch=e.touches[0];
    _dragState={type, name, active:false, startX:touch.clientX, startY:touch.clientY};
  },{passive:true});
  el.addEventListener('touchmove', e=>{
    if(!_dragState) return;
    const touch=e.touches[0];
    if(!_dragState.active){
      if(Math.hypot(touch.clientX-_dragState.startX,touch.clientY-_dragState.startY)<10) return;
      _dragState.active=true;
      const gh=_dragGhost(); gh.style.display='flex';
      _dragGhostIcon().innerHTML=itemSVG(type,32);
      _dragGhostLabel().textContent=name;
    }
    e.preventDefault();
    const gh=_dragGhost(); gh.style.left=touch.clientX+'px'; gh.style.top=touch.clientY+'px';
  },{passive:false});
  el.addEventListener('touchend', e=>{
    if(!_dragState||!_dragState.active){ _dragState=null; return; }
    const touch=e.changedTouches[0];
    const type2=_dragState.type; _dragState=null;
    const gh=_dragGhost(); gh.style.display='none';
    const wrap=document.getElementById('wrap');
    const rect=wrap.getBoundingClientRect();
    const mx=touch.clientX-rect.left, my=touch.clientY-rect.top;
    if(mx<0||mx>1024||my<0||my>700) return;
    if(game.state!=='field'||!game.player) return;
    if(!(inventory[type2]>0)){ game._msg('¡No tienes ese ítem!'); return; }
    const wx=mx/game.zoom+game.cam.x;
    const wy=my/game.zoom+game.cam.y;
    inventory[type2]--;
    updateInventoryUI();
    const near=DROPPED_ITEMS.find(d=>d.type===type2&&Math.hypot(d.x-wx,d.y-wy)<60);
    if(near){near.count++;}
    else DROPPED_ITEMS.push({id:Date.now(),type:type2,x:wx,y:wy,count:1,bobOffset:Math.random()*Math.PI*2});
    sfx.boing();
    game._msg(`🗑️ ${ITEMS[type2]?.name||type2} soltado en el campo`);
    if(game.invOpen) game.toggleInventory();
  });
}

function updateInventoryUI(){
  const grid=document.getElementById('inv-grid');
  if(!grid)return;
  grid.innerHTML='';
  const filled = Object.entries(inventory).filter(([,c])=>c>0);
  // Mostrar slots llenos
  for(const [type,count] of filled){
    const it=ITEMS[type];if(!it)continue;
    const slot=document.createElement('div');
    slot.className='inv-slot has-item';
    slot.title=it.name+' x'+count+' — Clic para detalles · Arrastra al mundo para soltar';
    slot.style.cursor='grab';
    slot.innerHTML=`${itemSVG(type,36)}<span class="inv-slot-name">${it.name}</span><span class="inv-count">x${count}</span>`;
    // Click → detail panel
    slot.onclick=(e)=>{ e.stopPropagation(); game.openItemDetail(type); };
    // Drag → world drop
    _addDragDrop(slot, type, it.name);
    grid.appendChild(slot);
  }
  // Slots vacíos hasta completar INV_MAX_SLOTS
  const emptyCount = INV_MAX_SLOTS - filled.length;
  for(let i=0;i<emptyCount;i++){
    const slot=document.createElement('div');
    slot.className='inv-slot';
    slot.innerHTML=`<span style="opacity:0.2;font-size:18px">—</span>`;
    grid.appendChild(slot);
  }
  // Contador de capacidad
  const cap=document.createElement('div');
  cap.style.cssText='width:100%;text-align:center;font-size:10px;color:rgba(255,255,255,0.4);margin-top:4px';
  cap.textContent=`${filled.length} / ${INV_MAX_SLOTS} slots`;
  grid.appendChild(cap);
  // update money
  const moneyVal=document.getElementById('inv-money-val');
  if(moneyVal&&game.player) moneyVal.textContent=Math.floor(game.player.money);
}

