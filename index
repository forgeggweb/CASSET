/* ---- FOG OF WAR ---- */
const FOG_CELL = 32; // world units per fog cell
const FOG_COLS = Math.ceil(WORLD.w / FOG_CELL);
const FOG_ROWS = Math.ceil(WORLD.h / FOG_CELL);
// 0 = unseen, 1 = seen (dimmed), 2 = visible (clear)
const fogGrid = new Uint8Array(FOG_COLS * FOG_ROWS);

// Offscreen canvas for fog rendering (scaled down)
const fogCanvas = document.createElement('canvas');
fogCanvas.width  = FOG_COLS;
fogCanvas.height = FOG_ROWS;
const fogCtx = fogCanvas.getContext('2d');
let fogDirty = true;

function revealFog(wx, wy, radius) {
  const cx = Math.floor(wx / FOG_CELL);
  const cy = Math.floor(wy / FOG_CELL);
  const r  = Math.ceil(radius / FOG_CELL);
  const r2 = r * r;
  let changed = false;
  for (let dy = -r; dy <= r; dy++) {
    for (let dx = -r; dx <= r; dx++) {
      if (dx*dx + dy*dy > r2) continue;
      const gx = cx + dx, gy = cy + dy;
      if (gx < 0 || gx >= FOG_COLS || gy < 0 || gy >= FOG_ROWS) continue;
      const idx = gy * FOG_COLS + gx;
      // inner bright zone
      const dist2 = dx*dx + dy*dy;
      const newVal = dist2 < (r*0.65)*(r*0.65) ? 2 : 1;
      if (fogGrid[idx] < newVal) { fogGrid[idx] = newVal; changed = true; }
    }
  }
  if (changed) fogDirty = true;
}

function rebuildFogCanvas() {
  const idata = fogCtx.createImageData(FOG_COLS, FOG_ROWS);
  const d = idata.data;
  for (let i = 0; i < fogGrid.length; i++) {
    const v = fogGrid[i];
    // RGBA: we draw the fog as black with varying alpha
    d[i*4]   = 10;   // R (very dark)
    d[i*4+1] = 15;   // G
    d[i*4+2] = 5;    // B
    d[i*4+3] = v === 0 ? 245 : v === 1 ? 140 : 0; // unseen=very dark, seen=dim, visible=clear
  }
  fogCtx.putImageData(idata, 0, 0);
  fogDirty = false;
}

function drawFogMinimap(mctx, sx, sy) {
  // Draw a darkened overlay on minimap for unvisited areas
  const mw = FOG_COLS, mh = FOG_ROWS;
  const idata = mctx.createImageData(Math.ceil(FOG_COLS * sx), Math.ceil(FOG_ROWS * sy));
  // Scale down: just sample fog grid for minimap
  const outW = Math.ceil(FOG_COLS * sx), outH = Math.ceil(FOG_ROWS * sy);
  for (let py = 0; py < outH; py++) {
    for (let px = 0; px < outW; px++) {
      const gx = Math.floor(px / sx), gy = Math.floor(py / sy);
      const idx = gy * FOG_COLS + gx;
      const v = (gx < FOG_COLS && gy < FOG_ROWS) ? fogGrid[idx] : 0;
      const pi = (py * outW + px) * 4;
      idata.data[pi]   = 10;
      idata.data[pi+1] = 15;
      idata.data[pi+2] = 5;
      idata.data[pi+3] = v === 0 ? 230 : v === 1 ? 100 : 0;
    }
  }
  mctx.putImageData(idata, 0, 0);
}

function drawFog(ctx, cam, zoom) {
  if (fogDirty) rebuildFogCanvas();
  ctx.save();
  ctx.imageSmoothingEnabled = true;
  ctx.imageSmoothingQuality = 'medium';
  ctx.drawImage(fogCanvas, 0, 0, WORLD.w, WORLD.h);
  ctx.restore();
}

function drawTree(ctx, tree, t){
  const {x, y, type, size} = tree;
  const sway = Math.sin(t*tree.swaySpeed+tree.sway)*0.04;
  ctx.save();ctx.translate(x, y);
  if(type==='oak'){
    ctx.fillStyle='#78350f';ctx.fillRect(-6*size,-20*size,12*size,30*size);
    ctx.save();ctx.rotate(sway);
    ctx.fillStyle='#16a34a';ctx.beginPath();ctx.arc(0,-44*size,36*size,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#15803d';ctx.beginPath();ctx.arc(-12*size,-56*size,26*size,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(14*size,-58*size,24*size,0,Math.PI*2);ctx.fill();
    ctx.restore();
  } else if(type==='pine'){
    ctx.fillStyle='#78350f';ctx.fillRect(-4*size,-10*size,8*size,20*size);
    ctx.save();ctx.rotate(sway*0.5);
    ctx.fillStyle='#166534';ctx.beginPath();ctx.moveTo(0,-70*size);ctx.lineTo(28*size,0);ctx.lineTo(-28*size,0);ctx.closePath();ctx.fill();
    ctx.fillStyle='#14532d';ctx.beginPath();ctx.moveTo(0,-48*size);ctx.lineTo(22*size,-10*size);ctx.lineTo(-22*size,-10*size);ctx.closePath();ctx.fill();
    ctx.fillStyle='#15803d';ctx.beginPath();ctx.moveTo(0,-28*size);ctx.lineTo(16*size,-4*size);ctx.lineTo(-16*size,-4*size);ctx.closePath();ctx.fill();
    ctx.restore();
  } else if(type==='willow'){
    ctx.fillStyle='#92400e';ctx.fillRect(-5*size,-25*size,10*size,40*size);
    ctx.save();ctx.rotate(sway*0.7);
    ctx.fillStyle='#4ade80';ctx.beginPath();ctx.arc(0,-50*size,30*size,0,Math.PI*2);ctx.fill();
    for(let i=-3;i<=3;i++){const bx=i*10*size;ctx.strokeStyle='#22c55e';ctx.lineWidth=2*size;ctx.lineCap='round';ctx.beginPath();ctx.moveTo(bx,-40*size);ctx.quadraticCurveTo(bx+sway*80*size,-10*size,bx+sway*120*size,10*size);ctx.stroke();}
    ctx.restore();
  } else if(type==='apple'){
    ctx.fillStyle='#78350f';ctx.fillRect(-5*size,-18*size,10*size,28*size);
    ctx.save();ctx.rotate(sway*0.6);
    ctx.fillStyle='#15803d';ctx.beginPath();ctx.arc(0,-38*size,28*size,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#16a34a';ctx.beginPath();ctx.arc(-10*size,-48*size,18*size,0,Math.PI*2);ctx.fill();
    [[8*size,-34*size,'#ef4444'],[-8*size,-44*size,'#dc2626'],[14*size,-46*size,'#f59e0b']].forEach(([ax,ay,col])=>{ctx.fillStyle=col;ctx.beginPath();ctx.arc(ax,ay,5*size,0,Math.PI*2);ctx.fill();ctx.strokeStyle='#78350f';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(ax,ay-5*size);ctx.lineTo(ax,ay-9*size);ctx.stroke();});
    ctx.restore();
  }
  ctx.restore();
}

function drawLake(ctx, t){
  function _drawOneLake(lk, deepCol, shallowCol){
    const dc=deepCol||'#0c4a6e', sc=shallowCol||'#0369a1';
    const pts=lk.points;
    ctx.fillStyle=dc;ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(p=>ctx.lineTo(p.x,p.y));ctx.closePath();ctx.fill();
    ctx.fillStyle=sc;ctx.globalAlpha=0.7;ctx.beginPath();
    for(let i=0;i<pts.length;i++){const p=pts[i],ox=(p.x-lk.cx)*0.75+lk.cx,oy=(p.y-lk.cy)*0.75+lk.cy;i===0?ctx.moveTo(ox,oy):ctx.lineTo(ox,oy);}
    ctx.closePath();ctx.fill();ctx.globalAlpha=1;
    const rCount=Math.round(8*(lk.rx/260));
    for(let i=0;i<rCount;i++){const sx=lk.cx-lk.rx*0.55+i*(lk.rx*1.1/rCount)+Math.sin(t*1.2+i)*10,sy=lk.cy-lk.ry*0.35+i*((lk.ry*0.7)/rCount)+Math.cos(t*0.8+i*0.5)*8;ctx.strokeStyle='rgba(186,230,253,0.5)';ctx.lineWidth=2;ctx.lineCap='round';ctx.beginPath();ctx.moveTo(sx,sy);ctx.lineTo(sx+20+Math.sin(t+i)*8,sy);ctx.stroke();}
    ctx.strokeStyle=sc;ctx.lineWidth=3;ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(p=>ctx.lineTo(p.x,p.y));ctx.closePath();ctx.stroke();
    for(let i=0;i<3;i++){const rx=lk.cx-lk.rx*0.3+i*lk.rx*0.3,ry=lk.cy-lk.ry*0.1+i*lk.ry*0.2,rs=(t*0.5+i)%3/3;ctx.strokeStyle=`rgba(186,230,253,${0.6*(1-rs)})`;ctx.lineWidth=1.5;ctx.beginPath();ctx.ellipse(rx,ry,20*rs+5,10*rs+3,0,0,Math.PI*2);ctx.stroke();}
  }
  _drawOneLake(LAKE);
  _drawOneLake(LAKE2);
  _drawOneLake(LAKE3);
  // Oasis lakes (turquoise tint)
  _drawOneLake(LAKE_OASIS, '#22d3ee', '#67e8f9');
  _drawOneLake(LAKE_OASIS2, '#22d3ee', '#67e8f9');
}

