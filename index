  _hookInventoryPlaceables(){
    // Re-render inventory with click handlers for placeables
    const grid=document.getElementById('inv-grid');
    if(!grid)return;
    grid.innerHTML='';
    const filled=Object.entries(inventory).filter(([,c])=>c>0);
    for(const [type,count] of filled){
      const it=ITEMS[type]; if(!it) continue;
      const slot=document.createElement('div');
      slot.className='inv-slot has-item';
      const craftRecipe=CRAFT_RECIPES.find(r=>r.id===type&&r.placeable);
      if(craftRecipe){
        slot.style.borderColor='#d97706';
        slot.style.boxShadow='0 0 12px rgba(217,119,6,0.4)';
        slot.title=it.name+' x'+count+' — Clic para detalles · Arrastra al mundo para soltar';
        slot.style.cursor='grab';
        slot.innerHTML=`${itemSVG(type,36)}<span class="inv-slot-name">${it.name}</span><span class="inv-count">x${count}</span><div style="font-size:8px;color:#fbbf24;margin-top:2px">⚒️ Colocar</div>`;
        slot.onclick=(e)=>{ e.stopPropagation(); game.openItemDetail(type); };
        _addDragDrop(slot, type, it.name);
      } else {
        slot.title=it.name+' x'+count+' — Clic para detalles · Arrastra al mundo para soltar';
        slot.style.cursor='grab';
        slot.innerHTML=`${itemSVG(type,36)}<span class="inv-slot-name">${it.name}</span><span class="inv-count">x${count}</span>`;
        slot.onclick=(e)=>{ e.stopPropagation(); game.openItemDetail(type); };
        _addDragDrop(slot, type, it.name);
      }
      grid.appendChild(slot);
    }
    // Slots vacíos hasta INV_MAX_SLOTS
    for(let i=0;i<INV_MAX_SLOTS-filled.length;i++){
      const slot=document.createElement('div');
      slot.className='inv-slot';
      slot.innerHTML=`<span style="opacity:0.2;font-size:18px">—</span>`;
      grid.appendChild(slot);
    }
    const cap=document.createElement('div');
    cap.style.cssText='width:100%;text-align:center;font-size:10px;color:rgba(255,255,255,0.4);margin-top:4px';
    cap.textContent=`${filled.length} / ${INV_MAX_SLOTS} slots`;
    grid.appendChild(cap);
    const moneyVal=document.getElementById('inv-money-val');
    if(moneyVal&&this.player) moneyVal.textContent=Math.floor(this.player.money);
  }

