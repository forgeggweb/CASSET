const BigMap = {
  canvas: null,
  ctx: null,
  wrap: null,
  pins: [],      // {id, wx, wy, type, label, icon}
  pinMode: false,
  selectedPinType: 0,
  pendingPin: null, // {wx, wy, type, icon} — esperando nombre
  _viewX: 0, _viewY: 0, // pan del mapa (en px del canvas)
  _zoom: 1,
  _dragging: false, _dragSX: 0, _dragSY: 0, _dragVX: 0, _dragVY: 0,
  _nextId: 1,

  PIN_TYPES: [
    {icon:'📍', label:'Señal'},
    {icon:'⭐', label:'Favorito'},
    {icon:'🏕️', label:'Campamento'},
    {icon:'💎', label:'Gemas'},
    {icon:'🐟', label:'Pesca'},
    {icon:'🍄', label:'Setas'},
    {icon:'🌸', label:'Flores'},
    {icon:'⚠️', label:'Peligro'},
    {icon:'🏠', label:'Casa'},
    {icon:'🗺️', label:'Explorar'},
    {icon:'💰', label:'Tesoro'},
    {icon:'❓', label:'Misterio'},
  ],

  init(){
    this.canvas = document.getElementById('bigmap-canvas');
    this.ctx    = this.canvas.getContext('2d');
    this.wrap   = document.getElementById('bigmap-canvas-wrap');

    // Build pin type selector
    const grid = document.getElementById('bigmap-pin-types');
    this.PIN_TYPES.forEach((pt,i)=>{
      const btn = document.createElement('div');
      btn.className = 'map-pin-type' + (i===0?' selected':'');
      btn.textContent = pt.icon;
      btn.title = pt.label;
      btn.onclick = ()=>{
        this.selectedPinType = i;
        grid.querySelectorAll('.map-pin-type').forEach((b,j)=>b.classList.toggle('selected',j===i));
      };
      grid.appendChild(btn);
    });

    // Canvas click — place pin or pan
    this.canvas.addEventListener('mousedown', e=>{
      if(this.pinMode){
        // Scale offsetX/Y from CSS pixels to canvas pixels
        const rect = this.canvas.getBoundingClientRect();
        const scaleX = this.canvas.width / rect.width;
        const scaleY = this.canvas.height / rect.height;
        const cx = e.offsetX * scaleX;
        const cy = e.offsetY * scaleY;
        const {wx,wy} = this._canvasToCWorld(cx, cy);
        // Only allow placing in revealed areas
        const gx = Math.floor(wx/FOG_CELL), gy = Math.floor(wy/FOG_CELL);
        const idx = gy*FOG_COLS+gx;
        if(gx<0||gx>=FOG_COLS||gy<0||gy>=FOG_ROWS||fogGrid[idx]===0){
          this._showMsg('🌫️ ¡Debes explorar esta zona primero!'); return;
        }
        this.pendingPin = {wx, wy, typeIdx: this.selectedPinType, icon: this.PIN_TYPES[this.selectedPinType].icon};
        this._showNamePopup(e.offsetX, e.offsetY);
        return;
      }
      this._dragging=true; this._dragSX=e.clientX; this._dragSY=e.clientY;
      this._dragVX=0; this._dragVY=0;
    });
    this.canvas.addEventListener('mousemove', e=>{
      if(!this._dragging) return;
      const rect2=this.canvas.getBoundingClientRect();
      const sX2=this.canvas.width/rect2.width, sY2=this.canvas.height/rect2.height;
      const dx=(e.clientX-this._dragSX)*sX2, dy=(e.clientY-this._dragSY)*sY2;
      this._dragSX=e.clientX; this._dragSY=e.clientY;
      this._dragVX=dx; this._dragVY=dy;
      this._viewX=Math.max(0,Math.min(this.canvas.width*(this._zoom-1),this._viewX-dx));
      this._viewY=Math.max(0,Math.min(this.canvas.height*(this._zoom-1),this._viewY-dy));
      this.render();
    });
    this.canvas.addEventListener('mouseup', ()=>{ this._dragging=false; });
    this.canvas.addEventListener('wheel', e=>{
      e.preventDefault();
      const oldZ=this._zoom;
      this._zoom=Math.max(1,Math.min(4,this._zoom-(e.deltaY>0?0.3:-0.3)));
      // Center zoom on mouse (scale to canvas pixels)
      const rect3=this.canvas.getBoundingClientRect();
      const mx=e.offsetX*(this.canvas.width/rect3.width), my=e.offsetY*(this.canvas.height/rect3.height);
      this._viewX=(this._viewX+mx)*this._zoom/oldZ - mx;
      this._viewY=(this._viewY+my)*this._zoom/oldZ - my;
      this._clampView();
      this.render();
    }, {passive:false});
  },

  _clampView(){
    const cw=this.canvas.width, ch=this.canvas.height;
    this._viewX=Math.max(0,Math.min(cw*(this._zoom-1),this._viewX));
    this._viewY=Math.max(0,Math.min(ch*(this._zoom-1),this._viewY));
  },

  _canvasToCWorld(cx,cy){
    // Canvas pixel → world coords
    const cw=this.canvas.width, ch=this.canvas.height;
    const sx=WORLD.w/cw, sy=WORLD.h/ch;
    // Accounting for zoom+pan
    const mapX=(cx+this._viewX)/this._zoom;
    const mapY=(cy+this._viewY)/this._zoom;
    return {wx: mapX*sx, wy: mapY*sy};
  },
  _worldToCanvas(wx,wy){
    const cw=this.canvas.width, ch=this.canvas.height;
    const sx=cw/WORLD.w, sy=ch/WORLD.h;
    return {cx: wx*sx*this._zoom-this._viewX, cy: wy*sy*this._zoom-this._viewY};
  },

  togglePinMode(){
    this.pinMode=!this.pinMode;
    const btn=document.getElementById('bigmap-mode-btn');
    const wrap=document.getElementById('bigmap-canvas-wrap');
    if(this.pinMode){
      btn.textContent='🚫 Cancelar señal';
      btn.classList.add('placing');
      wrap.classList.add('pin-mode');
    } else {
      btn.textContent='📍 Colocar señal';
      btn.classList.remove('placing');
      wrap.classList.remove('pin-mode');
      this._hideNamePopup();
    }
  },

  _showNamePopup(cx,cy){
    const popup=document.getElementById('pin-name-popup');
    const input=document.getElementById('pin-name-input');
    const wrapRect=this.wrap.getBoundingClientRect();
    // Position popup near click, clamp to wrap bounds
    let px=cx+10, py=cy-30;
    if(px+200>this.wrap.offsetWidth) px=cx-210;
    if(py+90>this.wrap.offsetHeight) py=cy-100;
    popup.style.left=px+'px'; popup.style.top=py+'px';
    popup.style.display='block';
    input.value=this.PIN_TYPES[this.pendingPin.typeIdx].label;
    input.focus(); input.select();
    input.onkeydown=e=>{ if(e.key==='Enter') this.confirmPin(); if(e.key==='Escape') this.cancelPin(); };
  },
  _hideNamePopup(){
    document.getElementById('pin-name-popup').style.display='none';
    this.pendingPin=null;
  },
  confirmPin(){
    if(!this.pendingPin) return;
    const label=document.getElementById('pin-name-input').value.trim() || this.PIN_TYPES[this.pendingPin.typeIdx].label;
    this.pins.push({
      id: this._nextId++,
      wx: this.pendingPin.wx, wy: this.pendingPin.wy,
      typeIdx: this.pendingPin.typeIdx,
      icon: this.pendingPin.icon,
      label,
    });
    sfx.boing();
    this._hideNamePopup();
    this.togglePinMode();
    this._rebuildPinList();
    this.render();
    this._updateStats();
  },
  cancelPin(){
    this._hideNamePopup();
    if(this.pinMode) this.togglePinMode();
  },

  removePin(id){
    this.pins=this.pins.filter(p=>p.id!==id);
    this._rebuildPinList();
    this.render();
    this._updateStats();
  },

  centerOnPin(pin){
    const cw=this.canvas.width, ch=this.canvas.height;
    const sx=cw/WORLD.w, sy=ch/WORLD.h;
    this._zoom=2.5;
    this._viewX=pin.wx*sx*this._zoom - cw/2;
    this._viewY=pin.wy*sy*this._zoom - ch/2;
    this._clampView();
    this.render();
  },

  _rebuildPinList(){
    const list=document.getElementById('bigmap-pins-list');
    list.innerHTML='';
    if(this.pins.length===0){
      const empty=document.createElement('div');
      empty.style.cssText='font-size:10px;color:rgba(255,255,255,0.3);text-align:center;padding:12px 4px;';
      empty.textContent='Sin señales aún';
      list.appendChild(empty);
      return;
    }
    [...this.pins].reverse().forEach(pin=>{
      const el=document.createElement('div');
      el.className='bm-pin-item';
      el.innerHTML=`<span class="pin-icon">${pin.icon}</span><span class="pin-label">${pin.label}</span><span class="pin-del" title="Borrar">✕</span>`;
      el.querySelector('.pin-del').onclick=e=>{ e.stopPropagation(); this.removePin(pin.id); };
      el.onclick=()=>this.centerOnPin(pin);
      list.appendChild(el);
    });
  },

  _updateStats(){
    const explored=fogGrid.filter(v=>v>0).length;
    const pct=Math.floor(explored/fogGrid.length*100);
    document.getElementById('bm-explored').textContent=pct;
    document.getElementById('bm-pin-count').textContent=this.pins.length;
    const pctEl=document.getElementById('explore-pct');
    if(pctEl) pctEl.textContent=pct;
  },

  _showMsg(txt){ if(game) game._msg(txt); },

  _buildBgCache(){
    // Dibuja el fondo estático una sola vez en un offscreen canvas
    const bmc=this.canvas;
    const cw=bmc.width, ch=bmc.height;
    const oc=document.createElement('canvas');
    oc.width=cw; oc.height=ch;
    const ox=oc.getContext('2d');

    ox.fillStyle='#14532d'; ox.fillRect(0,0,cw,ch);

    ox.fillStyle='#b07030';
    ox.beginPath();
    ox.moveTo(desertEdgeX(0)/WORLD.w*cw, 0);
    for(let wy=0;wy<=WORLD.h;wy+=400){
      ox.lineTo(desertEdgeX(wy)/WORLD.w*cw, wy/WORLD.h*ch);
    }
    ox.lineTo(cw,ch); ox.lineTo(cw,0); ox.closePath(); ox.fill();

    const drawMapLake=(lk,col)=>{
      ox.fillStyle=col||'#0369a1';
      ox.beginPath();
      ox.ellipse(lk.cx/WORLD.w*cw, lk.cy/WORLD.h*ch, lk.rx/WORLD.w*cw, lk.ry/WORLD.h*ch, 0, 0, Math.PI*2);
      ox.fill();
    };
    drawMapLake(LAKE); drawMapLake(LAKE2); drawMapLake(LAKE3);
    drawMapLake(LAKE_OASIS,'#22d3ee'); drawMapLake(LAKE_OASIS2,'#22d3ee');

    for(const tr of TREES){
      ox.fillStyle=tr.type==='apple'?'#15803d':'#166534';
      ox.fillRect(tr.x/WORLD.w*cw-0.8, tr.y/WORLD.h*ch-0.8, 1.6, 1.6);
    }

    for(const sp of SPOTS){
      ox.fillStyle='#fde047';
      ox.beginPath();
      ox.arc((sp.x+sp.w/2)/WORLD.w*cw, (sp.y+sp.h/2)/WORLD.h*ch, 2.5, 0, Math.PI*2);
      ox.fill();
    }

    (game?.npcs||[]).forEach((npc,i)=>{
      const hp=NPC_HOME_POSITIONS[i];if(!hp) return;
      ox.fillStyle='#d97706';
      ox.fillRect(hp.x/WORLD.w*cw-2, hp.y/WORLD.h*ch-2, 4, 4);
    });

    ox.strokeStyle='rgba(255,200,50,0.4)'; ox.lineWidth=0.8;
    ox.beginPath();
    ox.moveTo(desertEdgeX(0)/WORLD.w*cw, 0);
    for(let wy=0;wy<=WORLD.h;wy+=400){
      ox.lineTo(desertEdgeX(wy)/WORLD.w*cw, wy/WORLD.h*ch);
    }
    ox.stroke();

    this._bgCache=oc;
  },

  render(){
    const bmc=this.canvas, bx=this.ctx;
    const cw=bmc.width, ch=bmc.height;
    const z=this._zoom, vx=this._viewX, vy=this._viewY;
    const sx=cw/WORLD.w*z, sy=ch/WORLD.h*z;

    // Construir cache de fondo la primera vez
    if(!this._bgCache) this._buildBgCache();

    bx.clearRect(0,0,cw,ch);
    bx.save();
    bx.translate(-vx,-vy);
    bx.scale(z,z);
    const msw=cw/z, msh=ch/z;

    // Fondo desde cache (una sola drawImage)
    bx.drawImage(this._bgCache, 0, 0, cw, ch);

    // ===== FOG OF WAR =====
    // Usamos fogCanvas cacheado — una drawImage en vez de 120k fillRect
    if(fogDirty) rebuildFogCanvas();
    bx.save();
    bx.imageSmoothingEnabled=false;
    bx.drawImage(fogCanvas, 0, 0, cw, ch);
    bx.restore();

    // ===== PLAYER position =====
    if(game?.player){
      const px=game.player.x/WORLD.w*cw;
      const py=game.player.y/WORLD.h*ch;
      // Pulso animado
      const pulse=0.7+Math.sin(Date.now()*0.006)*0.3;
      bx.save();
      bx.globalAlpha=0.35*pulse;
      bx.fillStyle='#f472b6';
      bx.beginPath();bx.arc(px,py,6,0,Math.PI*2);bx.fill();
      bx.globalAlpha=1;
      bx.fillStyle='#f472b6';
      bx.beginPath();bx.arc(px,py,3,0,Math.PI*2);bx.fill();
      bx.strokeStyle='#fff';bx.lineWidth=1;bx.stroke();
      bx.restore();
    }

    // ===== PINS (señales) =====
    this.pins.forEach(pin=>{
      const px=pin.wx/WORLD.w*cw;
      const py=pin.wy/WORLD.h*ch;
      // Verificar si está en zona revelada
      const gx=Math.floor(pin.wx/FOG_CELL), gy=Math.floor(pin.wy/FOG_CELL);
      const idx=gy*FOG_COLS+gx;
      if(gx>=0&&gx<FOG_COLS&&gy>=0&&gy<FOG_ROWS&&fogGrid[idx]===0) return; // oculta en niebla
      bx.save();
      bx.font=`${Math.max(10,12/z)}px Arial`;
      bx.textAlign='center';
      // Sombra del pin
      bx.fillStyle='rgba(0,0,0,0.5)';
      bx.beginPath();bx.ellipse(px,py+1.5,4,2,0,0,Math.PI*2);bx.fill();
      // Icono
      bx.font=`${Math.max(8,14/z)}px Arial`;
      bx.fillText(pin.icon, px, py);
      // Label
      if(z>=1.5){
        bx.font=`bold ${Math.max(6,8/z)}px Arial`;
        bx.fillStyle='rgba(0,0,0,0.75)';
        const tw=bx.measureText(pin.label).width+4;
        bx.fillRect(px-tw/2, py+1, tw, 8/z);
        bx.fillStyle='#fff';
        bx.fillText(pin.label, px, py+8/z);
      }
      bx.restore();
    });

    bx.restore(); // fin de translate+scale

    // ===== LEYENDA (fuera del transform) =====
    bx.save();
    const legItems=[
      {col:'#166534',label:'Campo'},
      {col:'#b07030',label:'Desierto'},
      {col:'#0369a1',label:'Lago'},
      {col:'#fde047',label:'Recurso'},
      {col:'#d97706',label:'Casa NPC'},
      {col:'#f472b6',label:'Jugador'},
    ];
    let lx=6;
    legItems.forEach(li=>{
      bx.fillStyle=li.col;bx.beginPath();bx.arc(lx+4,ch-8,4,0,Math.PI*2);bx.fill();
      bx.strokeStyle='rgba(255,255,255,0.4)';bx.lineWidth=0.5;bx.stroke();
      bx.fillStyle='rgba(255,255,255,0.8)';bx.font='bold 8px Arial';bx.textAlign='left';
      bx.fillText(li.label,lx+10,ch-5);
      lx+=bx.measureText(li.label).width+20;
    });
    bx.restore();

    this._updateStats();

    // Re-render loop si el mapa está visible (para el pulso del jugador)
    // Throttled a ~12fps para no desperdiciar CPU
    if(game?.showMapFlag){
      const now=performance.now();
      if(!this._lastRenderTime || now-this._lastRenderTime >= 80){
        this._lastRenderTime=now;
        requestAnimationFrame(()=>{ if(game?.showMapFlag) this.render(); });
      } else {
        setTimeout(()=>{ if(game?.showMapFlag) this.render(); }, 80);
      }
    }
  },
};

const game = new Game();

C.addEventListener('click', e=>{
  sfx.ac?.resume();
  if(game.tentTrans) return; // bloquear input durante transición
  const rect=C.getBoundingClientRect();
  const mx=e.clientX-rect.left, my=e.clientY-rect.top;
  if(game.state==='title'){sfx.titleFanfare();game.state='menu';return;}
  if(game.state==='menu'){
    const cols=5,cardW=176,cardH=228,startX=32,startY=148,gapX=5;
    for(let i=0;i<10;i++){
      const col=i%cols,row=Math.floor(i/cols);const cx=startX+col*(cardW+gapX),cy=startY+row*(cardH+10);
      if(mx>=cx&&mx<=cx+cardW&&my>=cy&&my<=cy+cardH){
        if(game.menuSelected===i) return; // ya seleccionado, esperando animación
        game.menuSelected=i;
        game.menuSelTimer=0;
        // Sonido de alegría
        sfx.tada();
        setTimeout(()=>sfx.funnyBounce(),200);
        // Lanzar cinemática después de la animación (1.2s)
        setTimeout(()=>{
          game.state='cinematic';
          game.menuSelected=-1;
          CIN.start(i);
        }, 1200);
        return;
      }
    }
  } else if(game.state==='cabin'&&game.cabinPlayer){
    // Exit button top-right
    if(mx>=894&&mx<=1014&&my>=8&&my<=44){ game.closeCabinInterior(); return; }
    // If chest panel or fogon panel open, ignore canvas click
    if(document.getElementById('chest-panel').style.display==='block') return;
    if(document.getElementById('camp-panel').style.display==='block') return;
    const objs=game._cabinObjects();
    // Check click on objects
    for(const [key,obj] of Object.entries(objs)){
      if(mx>=obj.x&&mx<=obj.x+obj.w&&my>=obj.y&&my<=obj.y+obj.h){
        // Walk toward object center bottom
        game.cabinPlayer.tx=obj.x+obj.w/2;
        game.cabinPlayer.ty=obj.y+obj.h;
        game.cabinInteract=key;
        return;
      }
    }
    // Walk to clicked position
    game.cabinPlayer.tx=mx; game.cabinPlayer.ty=my;
    game.cabinInteract=null;
  } else if(game.state==='field'&&game.player){
    // Ghost mode: place building
    if(game.ghostMode){
      const wx=mx/game.zoom+game.cam.x, wy=my/game.zoom+game.cam.y;
      game.placeBuilding(wx,wy);
      return;
    }
    // Close anim menu on canvas click
    const menu=document.getElementById('anim-menu');
    if(menu.style.display==='block'){menu.style.display='none';document.getElementById('anim-toggle-btn')?.classList.remove('active');}
    // Convert screen coords to world coords accounting for zoom
    const wx=mx/game.zoom+game.cam.x,wy=my/game.zoom+game.cam.y;
    // Check click on placed buildings
    for(const bld of PLACED_BUILDINGS){
      if(wx>=bld.x&&wx<=bld.x+bld.w&&wy>=bld.y&&wy<=bld.y+bld.h){
        // Walk toward the building then open
        game.player.moveTo(bld.x+bld.w/2, bld.y+bld.h-10);
        // Schedule open after player arrives
        const _tryOpen=()=>{
          const d=Math.hypot(game.player.x-(bld.x+bld.w/2),game.player.y-(bld.y+bld.h));
          if(d<200){ if(bld.type==='tent') game.openShopInterior(); else game.openCabinInterior(); }
          else setTimeout(_tryOpen, 200);
        };
        setTimeout(_tryOpen, 400);
        return;
      }
    }
    // Check click on dropped item
    for(let i=DROPPED_ITEMS.length-1;i>=0;i--){
      const di=DROPPED_ITEMS[i];
      if(Math.hypot(wx-di.x,wy-di.y)<28){
        game.player.moveTo(di.x,di.y);
        return;
      }
    }
    for(const s of SPOTS){if(!s.hidden&&wx>=s.x&&wx<=s.x+s.w&&wy>=s.y&&wy<=s.y+s.h){game.player.goToSpot(s);return;}}
    game.player.moveTo(wx,wy);
    game.clickMarker={wx,wy,t:0};
  }
});

C.addEventListener('mousemove',e=>{
  const rect=C.getBoundingClientRect();
  const mx=e.clientX-rect.left,my=e.clientY-rect.top;
  window.gMX=mx;window.gMY=my;
  if(game.ghostMode){ game.ghostMouseX=mx; game.ghostMouseY=my; }
  if(game.state==='menu'){
    const cols=5,cardW=176,cardH=228,startX=32,startY=148,gapX=5;
    game.menuHover=-1;
    for(let i=0;i<10;i++){const col=i%cols,row=Math.floor(i/cols);const cx=startX+col*(cardW+gapX),cy=startY+row*(cardH+10);if(mx>=cx&&mx<=cx+cardW&&my>=cy&&my<=cy+cardH)game.menuHover=i;}
  } else if(game.state==='field'){
    const wx=mx/game.zoom+game.cam.x,wy=my/game.zoom+game.cam.y;
    game.hoveredSpot=null;
    game.hoveredItem=false;
    for(const s of SPOTS){if(!s.hidden&&wx>=s.x&&wx<=s.x+s.w&&wy>=s.y&&wy<=s.y+s.h){game.hoveredSpot=s;break;}}
    for(const di of DROPPED_ITEMS){if(Math.hypot(wx-di.x,wy-di.y)<32){game.hoveredItem=true;break;}}
    // cursor
    const hovering = game.hoveredSpot || game.hoveredItem;
    C.style.cursor = hovering ? 'pointer' : 'default';
  }
});

// Double-click = jump
C.addEventListener('dblclick',e=>{
  if(game.state==='field'&&game.player){
    sfx.funnyBounce();
    game.player.doJump();
    game.player.danceTimer=2;
  }
});

// Mouse wheel zoom
C.addEventListener('wheel', e=>{
  if(game.state!=='field') return;
  e.preventDefault();
  if(e.deltaY<0) game.zoomIn();
  else game.zoomOut();
}, {passive:false});

// Keyboard shortcuts
window.addEventListener('keydown',e=>{
  if(game.state==='cabin'){
    if(e.key==='Escape'){
      if(document.getElementById('camp-panel').style.display==='block') game.closeFogon();
      else if(document.getElementById('chest-panel').style.display==='block') game.closeChestPanel();
      else game.closeCabinInterior();
    }
    return;
  }
  if(game.state!=='field') return;
  if(e.key==='Escape'){ if(game.ghostMode){game.cancelGhostPlacement();return;} if(game.showMapFlag){game.toggleMap();return;} }
  if(e.key==='i'||e.key==='I') game.toggleInventory();
  if(e.key==='m'||e.key==='M') game.toggleMap();
  if(e.key==='+'||e.key==='=') game.zoomIn();
  if(e.key==='-') game.zoomOut();
  if(e.key==='0') game.zoomReset();
  if(e.key===' ') {e.preventDefault();game.toggleAnimMenu();}
  if(e.key==='Enter'&&game.player) {game.player.doJump();}
});

game.loop();

/* ================================================================
   MODO COOPERATIVO — Photon Realtime JS SDK
   ================================================================
   Usa Photon con el App ID de demo de Photon (funciona para
   desarrollo/testing sin cuenta propia).
   Para producción: registrarse en photonengine.com y reemplazar
   el APP_ID con tu propio ID de aplicación gratuito.
   ================================================================ */

const COOP = (function(){
  // Photon demo app ID — funciona sin cuenta para testing
  // Para producción: reemplazá con tu App ID de photonengine.com (gratis hasta 20 CCU)
  const APP_ID   = 'a81832cb-c16e-464c-b2e7-5d15ba85c9f7'; // cartoon campo
  const APP_VER  = '1.0';
  const REGION   = 'us'; // us, eu, asia, au, etc.

  let client       = null;
  let myActorNr    = -1;
  let myName       = 'Jugador';
  let roomCode     = '';
  let connected    = false;
  let inRoom       = false;
  let remotePlayers= {}; // actorNr → {x,y,charId,facingRight,state,funnyAnim,name,frame}
  let sendTimer    = 0;
  const SEND_INTERVAL = 0.05; // 50ms = 20 updates/seg

  // Event codes
  const EV_MOVE    = 1;
  const EV_ANIM    = 2;
  const EV_CHAT    = 3;

  function _log(msg){
    const el = document.getElementById('coop-log');
    if(!el) return;
    el.innerHTML += msg + '<br>';
    el.scrollTop = el.scrollHeight;
  }

  function _setStatus(text, cls){
    const el = document.getElementById('coop-status');
    if(!el) return;
    el.textContent = text;
    el.className   = cls || '';
    el.style.display = 'block';
  }

  function _updatePlayerChips(){
    const el = document.getElementById('coop-players-list');
    if(!el) return;
    el.innerHTML = '';
    // Myself
    const me = document.createElement('div');
    me.className = 'coop-player-chip me';
    me.innerHTML = `<span class="cp-dot"></span>${myName} (yo)`;
    el.appendChild(me);
    // Remote
    for(const [nr, rp] of Object.entries(remotePlayers)){
      const chip = document.createElement('div');
      chip.className = 'coop-player-chip';
      const cname = CHARS[rp.charId]?.name || '?';
      chip.innerHTML = `<span class="cp-dot"></span>${rp.name} (${cname})`;
      el.appendChild(chip);
    }
  }

  function init(){
    if(typeof Photon === 'undefined'){
      _log('⚠️ Photon SDK no cargado. Verificá tu conexión a internet.');
      return;
    }

    client = new Photon.LoadBalancing.LoadBalancingClient(
      Photon.ConnectionProtocol.Wss,
      APP_ID,
      APP_VER
    );

    // Callbacks
    client.onStateChange = function(state){
      const names = Photon.LoadBalancing.LoadBalancingClient.StateToName;
      _log('Estado: ' + (names ? names[state] : state));
    };

    client.onError = function(errorCode, errorMsg){
      _log('❌ Error ' + errorCode + ': ' + errorMsg);
      _setStatus('● Error', 'disconnected');
    };

    client.onEvent = function(code, content, actorNr){
      if(code === EV_MOVE){
        if(!remotePlayers[actorNr]) remotePlayers[actorNr] = {};
        const rp = remotePlayers[actorNr];
        rp.x          = content.x;
        rp.y          = content.y;
        rp.charId     = content.c;
        rp.facingRight= content.f;
        rp.state      = content.s;
        rp.frame      = content.fr;
        rp.name       = content.n || ('Actor'+actorNr);
      }
      if(code === EV_ANIM){
        if(!remotePlayers[actorNr]) remotePlayers[actorNr] = {};
        remotePlayers[actorNr].funnyAnim = content.a;
      }
      if(code === EV_CHAT){
        game._msg(`💬 ${content.n}: ${content.m}`);
      }
    };

    client.onJoinRoom = function(){
      inRoom     = true;
      myActorNr  = client.myActor().actorNr;
      roomCode   = client.myRoom().name;
      connected  = true;
      _log(`✅ Sala "${roomCode}" — sos el actor #${myActorNr}`);
      _setStatus(`● ${roomCode} (${Object.keys(remotePlayers).length+1}j)`, '');
      _updatePlayerChips();
      game._msg(`🌐 ¡Conectado a sala ${roomCode}! Comparti el código con amigos.`);
    };

    client.onActorJoin = function(actor){
      if(actor.actorNr === myActorNr) return;
      remotePlayers[actor.actorNr] = {x:512,y:350,charId:0,facingRight:true,state:'idle',frame:0,funnyAnim:'none',name:actor.name||('Actor'+actor.actorNr)};
      _log(`👋 ${actor.name || 'Jugador'} se unió`);
      game._msg(`👋 ${actor.name || 'Jugador'} se unió a la sala`);
      _setStatus(`● ${roomCode} (${Object.keys(remotePlayers).length+1}j)`, '');
      _updatePlayerChips();
    };

    client.onActorLeave = function(actor){
      delete remotePlayers[actor.actorNr];
      _log(`🚪 ${actor.name || 'Jugador'} salió`);
      game._msg(`🚪 ${actor.name || 'Jugador'} dejó la sala`);
      _setStatus(`● ${roomCode} (${Object.keys(remotePlayers).length+1}j)`, '');
      _updatePlayerChips();
    };

    client.onDisconnected = function(){
      connected = false; inRoom = false;
      remotePlayers = {};
      _log('🔌 Desconectado');
      _setStatus('● Sin conexión', 'disconnected');
      _updatePlayerChips();
    };
  }

  function connect(name, mode, room){
    if(!client){ init(); }
    if(!client){ return; }
    myName = name || 'Jugador';
    roomCode = (room || '').toUpperCase() || ('CAMPO' + Math.floor(Math.random()*9000+1000));

    _log('⏳ Conectando a Photon Cloud…');
    _setStatus('● Conectando…', 'connecting');

    client.setCustomAuthentication('', Photon.LoadBalancing.Constants.CustomAuthenticationType.Custom);
    client.connectToRegionMaster(REGION);

    // Wait for connection then join/create room
    const _waitAndJoin = setInterval(()=>{
      if(client.isInLobby()){
        clearInterval(_waitAndJoin);
        if(mode === 'create'){
          client.createRoom(roomCode, {maxPlayers:4, isVisible:true, isOpen:true});
          _log(`📦 Creando sala "${roomCode}"…`);
        } else {
          client.joinRoom(roomCode);
          _log(`🔗 Uniéndose a "${roomCode}"…`);
        }
      }
    }, 200);

    // Timeout
    setTimeout(()=>{
      clearInterval(_waitAndJoin);
      if(!inRoom){
        _log('⏱️ Timeout. Verificá tu conexión.');
        _setStatus('● Error', 'disconnected');
      }
    }, 15000);
  }

  function sendMyPosition(){
    if(!client || !inRoom || !game.player) return;
    const p = game.player;
    client.raiseEvent(EV_MOVE, {
      x:  Math.round(p.x),
      y:  Math.round(p.y),
      c:  p.char.id,
      f:  p.facingRight ? 1 : 0,
      s:  p.state,
      fr: Math.round(p.frame * 100) / 100,
      n:  myName
    }, {receivers: Photon.LoadBalancing.Constants.ReceiverGroup.Others, cache: Photon.LoadBalancing.Constants.EventCaching.DoNotCache});
  }

  function sendAnim(animId){
    if(!client || !inRoom) return;
    client.raiseEvent(EV_ANIM, {a: animId},
      {receivers: Photon.LoadBalancing.Constants.ReceiverGroup.Others});
  }

  function sendChat(msg){
    if(!client || !inRoom) return;
    client.raiseEvent(EV_CHAT, {n: myName, m: msg},
      {receivers: Photon.LoadBalancing.Constants.ReceiverGroup.Others});
  }

  function tick(dt){
    if(!client || !inRoom) return;
    sendTimer += dt;
    if(sendTimer >= SEND_INTERVAL){
      sendTimer = 0;
      sendMyPosition();
    }
    // Service Photon
    if(client.service) client.service();
  }

  function drawRemotePlayers(ctx){
    if(!inRoom) return;
    const cam = game.cam;
    const zoom = game.zoom;
    for(const [nr, rp] of Object.entries(remotePlayers)){
      if(rp.charId === undefined) continue;
      const char = CHARS[rp.charId];
      if(!char) continue;
      const sx = (rp.x - cam.x) * zoom;
      const sy = (rp.y - cam.y) * zoom;
      // Skip if off-screen
      if(sx < -80 || sx > 1104 || sy < -80 || sy > 780) continue;

      ctx.save();
      ctx.translate(sx, sy);
      ctx.scale(zoom, zoom);
      // Draw shadow
      ctx.fillStyle = 'rgba(0,0,0,0.2)';
      ctx.beginPath(); ctx.ellipse(0, 4, 20, 7, 0, 0, Math.PI*2); ctx.fill();
      // Draw character (reuse existing drawChar function)
      drawChar(ctx, char, rp.frame||0, rp.state||'idle', rp.facingRight||true, false, 1, rp.funnyAnim||'none', false);
      // Name tag with "remote" indicator
      ctx.fillStyle = 'rgba(74,222,128,0.85)';
      ctx.strokeStyle = 'rgba(0,0,0,0.6)';
      ctx.lineWidth = 1;
      const tag = rp.name + ' 🌐';
      ctx.font = 'bold 11px Arial';
      ctx.textAlign = 'center';
      const tw = ctx.measureText(tag).width + 10;
      // Rounded rect
      ctx.beginPath();
      const tx=-tw/2, ty=-110, th=15;
      ctx.moveTo(tx+4,ty); ctx.lineTo(tx+tw-4,ty);
      ctx.quadraticCurveTo(tx+tw,ty,tx+tw,ty+4);
      ctx.lineTo(tx+tw,ty+th-4); ctx.quadraticCurveTo(tx+tw,ty+th,tx+tw-4,ty+th);
      ctx.lineTo(tx+4,ty+th); ctx.quadraticCurveTo(tx,ty+th,tx,ty+th-4);
      ctx.lineTo(tx,ty+4); ctx.quadraticCurveTo(tx,ty,tx+4,ty);
      ctx.closePath();
      ctx.fill(); ctx.stroke();
      ctx.fillStyle = '#fff';
      ctx.fillText(tag, 0, ty + 11);
      ctx.restore();
    }
  }

  function getRemotePlayers(){ return remotePlayers; }
  function isConnected(){ return connected && inRoom; }
  function getMyName(){ return myName; }
  function disconnect(){
    if(client) client.disconnect();
  }

  return { init, connect, tick, drawRemotePlayers, sendAnim, sendChat, isConnected, getMyName, getRemotePlayers, disconnect };
})();

/* ---- COOP UI controller ---- */
const coopUI = (function(){
  function open(){
    document.getElementById('coop-overlay').style.display = 'flex';
    // Prepopulate name with character name if in game
    const nameEl = document.getElementById('coop-name-input');
    if(nameEl && game.player && !nameEl.value){
      nameEl.value = game.player.char.name;
    }
  }
  function close(){
    document.getElementById('coop-overlay').style.display = 'none';
  }
  function init(){
    document.getElementById('coop-close-btn').onclick = close;
    document.getElementById('coop-overlay').onclick = function(e){ if(e.target===this) close(); };

    document.getElementById('coop-create-btn').onclick = function(){
      const name = document.getElementById('coop-name-input').value.trim() || 'Jugador';
      const room = document.getElementById('coop-room-input').value.trim().toUpperCase();
      COOP.connect(name, 'create', room);
    };

    document.getElementById('coop-join-btn').onclick = function(){
      const name  = document.getElementById('coop-name-input').value.trim() || 'Jugador';
      const room  = document.getElementById('coop-room-input').value.trim().toUpperCase();
      if(!room){ document.getElementById('coop-log').innerHTML += '⚠️ Ingresá un código de sala para unirte.<br>'; return; }
      COOP.connect(name, 'join', room);
    };

    // Room input uppercase
    document.getElementById('coop-room-input').oninput = function(){
      this.value = this.value.toUpperCase();
    };
  }
  return { open, close, init };
})();

/* ---- Hook into game: show coop button when field starts, tick coop, draw remote players ---- */
(function(){
  // Patch game.start to show coop button
  const _origStart = game.start.bind(game);
  game.start = function(charId){
    _origStart(charId);
    document.getElementById('coop-open-btn').style.display = 'inline-block';
    document.getElementById('coop-status').style.display = 'block';
  };

  // Patch game.loop to inject coop tick + draw
  const _origLoop = game.loop.bind(game);
  // We'll patch via the render pipeline — hook into the game's update
  // Since game.loop uses requestAnimationFrame internally, we wrap the draw method
  const _origDrawField = game._drawField ? game._drawField.bind(game) : null;

  // Alternative: patch the canvas render by monkey-patching the main loop
  const origGameLoop = game.loop;
  let lastCoopT = performance.now();
  game.loop = function(){
    // We don't override, instead we run our own RAF alongside
  };
  // Restore original loop
  game.loop = origGameLoop;

  // Use a separate RAF to tick COOP and draw remote players after the main render
  const C = document.getElementById('c');
  const ctx = C.getContext('2d');

  // Wrap the main render by intercepting requestAnimationFrame at a higher level
  // Instead: patch the game's internal update step
  // The cleanest approach: override the part that draws field NPCs/player
  // We inject into the game object a postRender hook

  game._coopPostRender = function(){
    if(game.state === 'field'){
      COOP.drawRemotePlayers(ctx);
    }
  };

  // Now patch game loop to call _coopPostRender
  // We do this by wrapping the game's _drawField or loop
  // Since the loop is a method on the game object, let's replace loop carefully
  const _gameLoopOrig = game.loop;

  // Actually the simplest safe approach: run COOP in a separate RAF loop
  // that draws ON TOP of the game canvas each frame
  let coopRafId;
  function coopRenderLoop(ts){
    const dt = Math.min((ts - lastCoopT)/1000, 0.1);
    lastCoopT = ts;
    if(game.state === 'field'){
      COOP.tick(dt);
      COOP.drawRemotePlayers(ctx);
    }
    coopRafId = requestAnimationFrame(coopRenderLoop);
  }
  requestAnimationFrame(coopRenderLoop);

  // Also patch playAnim to broadcast to others
  const _origPlayAnim = game.playAnim.bind(game);
  game.playAnim = function(animId){
    _origPlayAnim(animId);
    COOP.sendAnim(animId);
  };

  // Init UI
  coopUI.init();
  COOP.init();
})();

