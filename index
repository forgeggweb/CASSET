      } else {
        // Badge de clase/trait
        const badgeCols={kid:'#3b82f6',fairy:'#a855f7',ranger:'#b45309',scientist:'#0ea5e9',robot:'#94a3b8',mage:'#7c3aed',chef:'#f59e0b',ninja:'#1d4ed8',elder:'#c084fc',explorer:'#22c55e'};
        const bc=badgeCols[c.trait]||'#6b7280';
