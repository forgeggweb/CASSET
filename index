  placeBuilding(wx, wy){
    if(!this.ghostMode)return;
    const {itemType}=this.ghostMode;
    const r=CRAFT_RECIPES.find(x=>x.id===itemType);
    if(!r)return;
    if(!(inventory[itemType]>0)){ this._msg('❌ Ya no tienes ese item'); this.cancelGhostPlacement(); return; }
    inventory[itemType]--;
    updateInventoryUI();
    PLACED_BUILDINGS.push({
      type: itemType, x: wx-r.w/2, y: wy-r.h/2, w: r.w, h: r.h,
      data:{ doorOpen:false, doorAnim:0, doorTimer:0 }
    });
    sfx.tada();
    this._msg('⛺ ¡Carpa colocada! Acércate y presioná "Interactuar" para entrar');
    this.cancelGhostPlacement();
    if(this.player) this.player.danceTimer=2;
    updateMissionsHUD();
  }

