/* ---- AUDIO ---- */
class Sfx {
  constructor(){try{this.ac=new(window.AudioContext||window.webkitAudioContext)();this.mg=this.ac.createGain();this.mg.gain.value=0.25;this.mg.connect(this.ac.destination);}catch(e){}}
  _r(){if(this.ac&&this.ac.state==='suspended')this.ac.resume();}
  tone(f1,f2,d,v=0.35,t=null){if(!this.ac)return;this._r();const T=t||this.ac.currentTime;const o=this.ac.createOscillator(),g=this.ac.createGain();o.frequency.setValueAtTime(f1,T);if(f1!==f2)o.frequency.exponentialRampToValueAtTime(Math.max(1,f2),T+d);g.gain.setValueAtTime(v,T);g.gain.exponentialRampToValueAtTime(0.001,T+d);o.connect(g);g.connect(this.mg);o.start(T);o.stop(T+d);}
  step(){this.tone(90,60,0.05,0.07);}
  boing(){this.tone(180,600,0.12,0.3);setTimeout(()=>this.tone(600,200,0.1,0.2),110);}
  collect(){const n=this.ac?.currentTime||0;[500,700,900,1100].forEach((f,i)=>this.tone(f,f*1.2,0.08,0.2,n+i*0.06));}
  splash(){this.tone(400,150,0.35,0.28);}
  rustle(){this.tone(300,180,0.15,0.18);}
  chirp(){const n=this.ac?.currentTime||0;[600,900,750,1000].forEach((f,i)=>this.tone(f,f*1.4,0.07,0.18,n+i*0.06));}
  coin(){const n=this.ac?.currentTime||0;[800,1200,1000,1500].forEach((f,i)=>this.tone(f,f*1.3,0.09,0.25,n+i*0.07));}
  eat(){this.tone(280,90,0.25,0.22);}
  menuSelect(){const n=this.ac?.currentTime||0;[300,500,700].forEach((f,i)=>this.tone(f,f*1.5,0.1,0.25,n+i*0.08));}
  titleFanfare(){if(!this.ac)return;this._r();const n=this.ac.currentTime;[261,329,392,523].forEach((f,i)=>this.tone(f,f,0.25,0.3,n+i*0.15));this.tone(784,784,0.4,0.35,n+0.75);}
  funnyBounce(){this.tone(200,800,0.08,0.4);setTimeout(()=>this.tone(800,150,0.15,0.3),80);}
  woosh(){this.tone(600,100,0.3,0.2);}
  trombone(){const n=this.ac?.currentTime||0;[220,180,260,200].forEach((f,i)=>this.tone(f,f*0.8,0.18,0.35,n+i*0.15));}
  tada(){const n=this.ac?.currentTime||0;[400,600,800,1200].forEach((f,i)=>this.tone(f,f,0.15,0.3,n+i*0.1));}
  silly(){const n=this.ac?.currentTime||0;[900,400,750,350].forEach((f,i)=>this.tone(f,f*0.5,0.12,0.3,n+i*0.09));}
  fireCrackle(){this.tone(180,80,0.4,0.15);setTimeout(()=>this.tone(120,60,0.3,0.1),200);}
  cookDone(){const n=this.ac?.currentTime||0;[500,700,600,900,800].forEach((f,i)=>this.tone(f,f*1.3,0.1,0.28,n+i*0.08));}
  tentEnter(){if(!this.ac)return;this._r();const n=this.ac.currentTime;
    // Zip de tela: barrido rápido agudo→grave
    this.tone(900,200,0.18,0.22,n);
    // Golpe sordo de paso al entrar
    this.tone(80,40,0.12,0.18,n+0.15);
    // Pequeño acorde cálido de "llegaste"
    this.tone(300,300,0.2,0.12,n+0.25);
    this.tone(380,380,0.2,0.10,n+0.28);}
  tentExit(){if(!this.ac)return;this._r();const n=this.ac.currentTime;
    // Zip inverso: grave→agudo
    this.tone(150,700,0.18,0.22,n);
    // Golpe de paso al salir
    this.tone(80,40,0.1,0.15,n+0.12);}
}
const sfx = new Sfx();

/* ---- UTILS ---- */
function rr(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();}
function lerp(a,b,t){return a+(b-a)*t;}
function bubble(ctx,x,y,txt,bg='#ffffcc'){
  ctx.font='bold 12px Arial';const w=ctx.measureText(txt).width+16;
  ctx.fillStyle=bg;rr(ctx,x-w/2,y-20,w,22,8);ctx.fill();
  ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;ctx.stroke();
  ctx.fillStyle='#333';ctx.textAlign='center';ctx.fillText(txt,x,y-4);
}

const WORLD = {w:12800, h:9600};

// Borde orgánico del desierto (función global reutilizable)
function desertEdgeX(wy){
  return 7000
    + Math.sin(wy*0.0008)*600
    + Math.sin(wy*0.0022+1.3)*300
    + Math.sin(wy*0.005+2.7)*140
    + Math.sin(wy*0.012+0.8)*60
    + Math.sin(wy*0.028+4.1)*30;
}

