  if(funnyAnim==='wiggle') { ctx.rotate(Math.sin(frame*12)*0.4); }
  if(funnyAnim==='shake')  { ctx.translate(Math.sin(frame*20)*6, 0); }
  if(funnyAnim==='dizzy')  { ctx.rotate(Math.sin(frame*3)*0.6); extraBob=-Math.abs(Math.sin(frame*2))*5; }
  if(funnyAnim==='flex')   { ctx.scale(1+Math.sin(frame*5)*0.08, 1-Math.sin(frame*5)*0.05); }
  if(funnyAnim==='moonwalk'){ ctx.translate(Math.sin(frame*6)*4, 0); }
  if(funnyAnim==='fall')   { ctx.rotate(Math.PI*0.5); ctx.translate(0,-10); }
  if(funnyAnim==='sneeze') { const sn=Math.sin(frame*20);ctx.translate(sn*3,sn*2);ctx.rotate(sn*0.15); }
  if(funnyAnim==='slide')  { ctx.translate(Math.cos(frame)*8, 0); }
  if(funnyAnim==='bounce_crazy') { ctx.translate(Math.sin(frame*14)*5, -Math.abs(Math.sin(frame*7))*12); }
  if(funnyAnim==='robot')  { ctx.translate(Math.floor(Math.sin(frame*8))*4, 0); }
  if(funnyAnim==='celebrate') {
    const ce=frame%1;
    ctx.translate(Math.sin(frame*8)*10, -Math.abs(Math.sin(frame*4))*20);
    ctx.rotate(Math.sin(frame*6)*0.3);
  }

  const bob = state==='walk' ? Math.sin(frame*2)*4 : Math.sin(frame*0.5)*1.5 + extraBob;
  ctx.translate(0, bob);

  // Shadow
  ctx.fillStyle='rgba(0,0,0,0.2)';
  ctx.beginPath();
  const sw = s==='fat'||s==='round'?22:s==='tiny'||s==='kid'||s==='enzin'?12:16;
  ctx.ellipse(0,4,sw,6,0,0,Math.PI*2);ctx.fill();

  // Wings (fairy)
  if(char.wings){
    ctx.save();ctx.globalAlpha=0.6+Math.sin(frame*8)*0.2;ctx.fillStyle='#a5f3fc';
    ctx.beginPath();ctx.ellipse(-18,-30,12,20,-0.5,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.ellipse(18,-30,12,20,0.5,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=1;ctx.restore();
  }

  let bw,bh,bx,legsY,headR,headY;
  if(s==='fat')    {bw=34;bh=36;bx=-17;legsY=0;headR=20;headY=-48;}
  else if(s==='tiny')   {bw=20;bh=22;bx=-10;legsY=0;headR=14;headY=-34;}
  else if(s==='tall')   {bw=26;bh=42;bx=-13;legsY=0;headR=17;headY=-58;}
  else if(s==='bighead'){bw=28;bh=32;bx=-14;legsY=0;headR=24;headY=-52;}
  else if(s==='robot')  {bw=34;bh=34;bx=-17;legsY=0;headR=0;headY=-50;}
  else if(s==='round')  {bw=32;bh=38;bx=-16;legsY=0;headR=19;headY=-48;}
  else if(s==='slim')   {bw=22;bh=38;bx=-11;legsY=0;headR=16;headY=-52;}
  else if(s==='hunched'){bw=26;bh=30;bx=-13;legsY=4;headR=16;headY=-40;ctx.translate(5,5);}
  else if(s==='predator'){bw=30;bh=38;bx=-15;legsY=0;headR=0;headY=-52;} // headR=0 = custom head drawn below
  else if(s==='kid')    {bw=22;bh=26;bx=-11;legsY=0;headR=16;headY=-38;}
  else if(s==='enzin')  {bw=18;bh=28;bx=-9;legsY=0;headR=26;headY=-46;}
  else              {bw=28;bh=34;bx=-14;legsY=0;headR=18;headY=-48;}

  const legLen = s==='tall'?36:s==='tiny'||s==='kid'||s==='enzin'?18:s==='fat'||s==='round'?22:28;
  const legW   = s==='fat'||s==='round'?10:s==='tiny'||s==='kid'||s==='enzin'?5:8;

  ctx.strokeStyle=char.pants;ctx.lineWidth=legW;ctx.lineCap='round';

  // Extended states for funny anims
  let legState = state;
  if(funnyAnim==='flail')     legState='flail';
  if(funnyAnim==='celebrate') legState='celebrate';
  if(funnyAnim==='moonwalk')  legState='moonwalk';

  if(legState==='walk'){
    ctx.beginPath();ctx.moveTo(-bw/4+legsY,0);ctx.lineTo(-bw/4+Math.sin(frame*2)*12+legsY,legLen);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bw/4+legsY,0);ctx.lineTo(bw/4-Math.sin(frame*2)*12+legsY,legLen);ctx.stroke();
  } else if(legState==='dance'||legState==='celebrate'){
    const dk=Math.sin(frame*4)*18;
    ctx.beginPath();ctx.moveTo(-bw/4,0);ctx.lineTo(-bw/4+dk,legLen);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bw/4,0);ctx.lineTo(bw/4-dk,legLen);ctx.stroke();
  } else if(legState==='flail'){
    ctx.beginPath();ctx.moveTo(-bw/4,0);ctx.lineTo(-bw/4+Math.sin(frame*8)*20,legLen-4);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bw/4,0);ctx.lineTo(bw/4+Math.cos(frame*8)*20,legLen-4);ctx.stroke();
  } else if(legState==='moonwalk'){
    ctx.beginPath();ctx.moveTo(-bw/4,0);ctx.lineTo(-bw/4-Math.sin(frame*2)*10,legLen);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bw/4,0);ctx.lineTo(bw/4+Math.sin(frame*2)*10,legLen);ctx.stroke();
  } else {
    ctx.beginPath();ctx.moveTo(-bw/4,legsY);ctx.lineTo(-bw/4,legsY+legLen);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bw/4,legsY);ctx.lineTo(bw/4,legsY+legLen);ctx.stroke();
  }

  if(s==='robot'){
    ctx.fillStyle=char.color;ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1.5;
    rr(ctx,bx,-34,bw,34,4);ctx.fill();ctx.stroke();
    ctx.fillStyle='rgba(255,255,100,0.7)';ctx.fillRect(bx+6,-28,8,8);
    ctx.fillStyle='rgba(255,100,100,0.7)';ctx.fillRect(bx+18,-28,8,8);
    ctx.fillStyle='rgba(100,200,255,0.5)';ctx.fillRect(bx+6,-16,20,6);
  } else if(s==='predator'){
    // Torso — armadura biomecánica marrón oscuro con placas
    ctx.fillStyle='#3d2a10';rr(ctx,bx,-36,bw,36,5);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.35)';ctx.lineWidth=1.5;ctx.stroke();
    // Placas de armadura en el pecho — tiras horizontales
    ctx.fillStyle='#5a3e1a';
    rr(ctx,bx+2,-33,bw-4,8,3);ctx.fill();
    rr(ctx,bx+2,-22,bw-4,7,3);ctx.fill();
    rr(ctx,bx+2,-12,bw-4,7,3);ctx.fill();
    // Detalle central — columna vertebral biomecánica
    ctx.fillStyle='rgba(0,0,0,0.3)';
    ctx.fillRect(-2,-34,4,33);
    // Hombros bulbosos
    ctx.fillStyle='#4a3218';
    ctx.beginPath();ctx.arc(bx-2,-28,8,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(-bx+2,-28,8,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;ctx.stroke();
    // Brillo en armadura
    ctx.fillStyle='rgba(255,200,100,0.12)';rr(ctx,bx+3,-34,bw-6,16,3);ctx.fill();
    // Mini cañón en hombro derecho (plasma caster)
    ctx.fillStyle='#222';rr(ctx,-bx-2,-36,10,6,2);ctx.fill();
    ctx.fillStyle='#333';ctx.beginPath();ctx.arc(-bx+6,-33,3,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(255,50,50,0.7)';ctx.beginPath();ctx.arc(-bx+6,-33,1.5,0,Math.PI*2);ctx.fill();
  } else {
    ctx.fillStyle=char.color;rr(ctx,bx,-34,bw,34,7);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.25)';ctx.lineWidth=1.5;ctx.stroke();
    // Sub-Zero: armadura negra con placas azules
    if(char.hat==='ninja'){
      // Torso negro base ya dibujado con char.color (#1a3a6e)
      // Sobreescribir con negro como base
      ctx.fillStyle='#0d1b2e';
      rr(ctx,bx,-34,bw,34,7);ctx.fill();
      ctx.strokeStyle='rgba(0,0,0,0.5)';ctx.lineWidth=1.5;ctx.stroke();

      // Placa central del pecho — azul con detalle
      ctx.fillStyle='#1a3a6e';
      rr(ctx,-7,-32,14,20,4);ctx.fill();
      ctx.strokeStyle='#2d5a9e';ctx.lineWidth=1;ctx.stroke();
      // Línea V del cuello
      ctx.strokeStyle='#0d1b2e';ctx.lineWidth=2;ctx.lineCap='round';
      ctx.beginPath();ctx.moveTo(-5,-32);ctx.lineTo(0,-24);ctx.lineTo(5,-32);ctx.stroke();
      // Detalle inferior de placa central
      ctx.fillStyle='#2d5a9e';
      rr(ctx,-5,-14,10,6,2);ctx.fill();
      // Punto circular en placa (botón/medallón)
      ctx.fillStyle='#4a7ab5';
      ctx.beginPath();ctx.arc(0,-26,3,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='rgba(147,197,253,0.5)';
      ctx.beginPath();ctx.arc(-0.5,-26.5,1.2,0,Math.PI*2);ctx.fill();

      // Hombreras azul oscuro con borde metálico
      ctx.fillStyle='#1a3a6e';
      rr(ctx,bx-2,-34,12,10,3);ctx.fill();
      rr(ctx,-bx-10,-34,12,10,3);ctx.fill();
      ctx.strokeStyle='#3d6aa0';ctx.lineWidth=1;
      ctx.strokeRect(bx-2,-34,12,10);
      ctx.strokeRect(-bx-10,-34,12,10);
      // Highlight hombreras
      ctx.fillStyle='rgba(147,197,253,0.25)';
      ctx.beginPath();ctx.ellipse(bx+4,-30,3,2,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(-bx-4,-30,3,2,0,0,Math.PI*2);ctx.fill();

      // Cinturón negro con doble hebilla
      ctx.fillStyle='#060c14';
      ctx.fillRect(bx,-8,bw,10);
      // Hebillas del cinturón (dos placas)
      [-5,5].forEach(ox=>{
        ctx.fillStyle='#2d5a9e';
        rr(ctx,ox-3,-7,6,8,1);ctx.fill();
        ctx.strokeStyle='#4a7ab5';ctx.lineWidth=0.8;ctx.stroke();
      });
      // Detalle central cinturón
      ctx.fillStyle='#1a3a6e';
      rr(ctx,-4,-6,8,6,1);ctx.fill();
      // Emblema en cinturón
      ctx.strokeStyle='#4a7ab5';ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(0,-6);ctx.lineTo(-3,-1);ctx.lineTo(0,-3);ctx.lineTo(3,-1);ctx.closePath();ctx.stroke();
    }
    // Dusty: bandana around neck + shirt details
    if(char.bandana){
      // Cowboy shirt — darker plaid lines
      ctx.strokeStyle='rgba(0,0,0,0.15)';ctx.lineWidth=1.2;
      for(let pi=0;pi<4;pi++){ctx.beginPath();ctx.moveTo(bx,bx+pi*8-30);ctx.lineTo(-bx,bx+pi*8-30);ctx.stroke();}
      // Bandana triangle at neck
      ctx.fillStyle='#dc2626';
      ctx.beginPath();ctx.moveTo(-8,-34);ctx.lineTo(8,-34);ctx.lineTo(0,-20);ctx.closePath();ctx.fill();
      ctx.fillStyle='#b91c1c';
      // Bandana dots pattern
      [[0,-30],[4,-26],[-4,-26]].forEach(([px,py])=>{
        ctx.beginPath();ctx.arc(px,py,1.5,0,Math.PI*2);ctx.fill();
      });
      // Belt buckle
      ctx.fillStyle='#d4a017';
      ctx.fillRect(-5,-4,10,6);
      ctx.fillStyle='rgba(0,0,0,0.3)';
      ctx.fillRect(-3,-2,6,2);
      // Boot spurs hint
      ctx.strokeStyle='#9a7040';ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(bx+2,legLen-4);ctx.lineTo(bx+8,legLen);ctx.stroke();
      ctx.beginPath();ctx.moveTo(-bx-2,legLen-4);ctx.lineTo(-bx-8,legLen);ctx.stroke();
    }
    // Dr. Lupe: white lab coat
    if(char.ponytail){
      // Lab coat overlay (white with blue trim)
      ctx.fillStyle='rgba(240,248,255,0.92)';
      rr(ctx,bx+1,-33,bw-2,32,5);ctx.fill();
      ctx.strokeStyle='#bfdbfe';ctx.lineWidth=1;ctx.stroke();
      // Lab coat lapels (V-neck)
      ctx.fillStyle='#e0f2fe';
      ctx.beginPath();ctx.moveTo(-4,-33);ctx.lineTo(-4,-10);ctx.lineTo(0,-6);ctx.lineTo(4,-10);ctx.lineTo(4,-33);ctx.closePath();ctx.fill();
      ctx.strokeStyle='#93c5fd';ctx.lineWidth=1;ctx.stroke();
      // Blue shirt underneath
      ctx.fillStyle='#1e3a5f';
      ctx.beginPath();ctx.moveTo(-3,-30);ctx.lineTo(-3,-10);ctx.lineTo(0,-7);ctx.lineTo(3,-10);ctx.lineTo(3,-30);ctx.closePath();ctx.fill();
      // Pocket with pen
      ctx.fillStyle='rgba(147,197,253,0.4)';
      ctx.fillRect(bx+3,-22,9,10);
      ctx.strokeStyle='#0ea5e9';ctx.lineWidth=0.8;ctx.strokeRect(bx+3,-22,9,10);
      // Pen in pocket
      ctx.strokeStyle='#dc2626';ctx.lineWidth=1.5;ctx.lineCap='round';
      ctx.beginPath();ctx.moveTo(bx+8,-22);ctx.lineTo(bx+8,-14);ctx.stroke();
      ctx.lineCap='butt';
      // Coat buttons
      ctx.fillStyle='#93c5fd';
      [-20,-12,-4].forEach(py=>{
        ctx.beginPath();ctx.arc(0,py,2,0,Math.PI*2);ctx.fill();
      });
    }
  }

  const armW = s==='fat'?8:s==='tiny'||s==='kid'||s==='enzin'?4:7;
  // Para ninja los brazos son del color del traje (no piel expuesta)
  ctx.strokeStyle = char.hat==='ninja' ? '#0d1b2e' : char.skin;
  ctx.lineWidth=armW;ctx.lineCap='round';

  // Arm animations
  let armState = state;
  if(funnyAnim==='flail')     armState='flail';
  if(funnyAnim==='celebrate') armState='celebrate';
  if(funnyAnim==='flex')      armState='flex';
  if(isCarrying)              armState='carry';

  if(armState==='interact'||armState==='dance'||armState==='celebrate'){
    const da=Math.sin(frame*4)*15;
    ctx.beginPath();ctx.moveTo(bx,-22);ctx.lineTo(bx-10+da,-42);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-bx,-22);ctx.lineTo(-bx+10-da,-42);ctx.stroke();
  } else if(armState==='flail'){
    ctx.beginPath();ctx.moveTo(bx,-22);ctx.lineTo(bx-20+Math.sin(frame*10)*14,-35+Math.cos(frame*8)*12);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-bx,-22);ctx.lineTo(-bx+20+Math.cos(frame*9)*14,-35+Math.sin(frame*7)*12);ctx.stroke();
  } else if(armState==='flex'){
    ctx.beginPath();ctx.moveTo(bx,-22);ctx.lineTo(bx-18,-38);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-bx,-22);ctx.lineTo(-bx+18,-38);ctx.stroke();
  } else if(armState==='carry'){
    ctx.beginPath();ctx.moveTo(bx,-20);ctx.lineTo(bx+2,-8);ctx.lineTo(-bx+2,-8);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-bx,-20);ctx.lineTo(-bx-2,-8);ctx.lineTo(bx-2,-8);ctx.stroke();
  } else if(char.hat==='ninja'){
    // Ninja idle: solo brazo izquierdo — el derecho+guardabrazos se dibujan al final
    ctx.beginPath();ctx.moveTo(bx,-20);ctx.lineTo(bx-4+Math.sin(frame)*3,-3);ctx.stroke();
  } else {
    ctx.beginPath();ctx.moveTo(bx,-20);ctx.lineTo(bx-4+Math.sin(frame)*3,-3);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-bx,-20);ctx.lineTo(-bx+4-Math.sin(frame)*3,-3);ctx.stroke();
  }

  if(char.hat==='wizard'||char.hat==='flower'){
    // bastón eliminado — solo queda la esfera del gorro dibujada con el sombrero
  }
  if(char.hat==='cap' && s==='kid'){
    ctx.fillStyle='#16a34a';
    rr(ctx,-bx-4,-30,-bx+14,22,5);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.3)';ctx.fillRect(-bx,-26,10,4);
    ctx.fillRect(-bx,-20,10,4);
  }

  if(s==='robot'){
    ctx.fillStyle='#cbd5e1';rr(ctx,-14,headY,28,24,4);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.25)';ctx.lineWidth=1.5;ctx.stroke();
    ctx.fillStyle='rgba(0,255,200,0.9)';ctx.beginPath();ctx.arc(-5,headY+8,4,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(5,headY+8,4,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(255,200,0,0.8)';ctx.fillRect(-6,headY+16,12,3);
  } else if(s==='predator'){
    // ---- PREDATOR CHIBI HEAD ----
    const hy = headY; // -52
    // Neck short
    ctx.fillStyle='#c8a46e';ctx.fillRect(-5,hy+22,10,12);
    // Casco principal — azul oscuro marino
    ctx.fillStyle='#1e3555';
    ctx.beginPath();ctx.ellipse(0,hy+10,22,20,0,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.4)';ctx.lineWidth=2;ctx.stroke();
    // Borde cromado del casco
    ctx.strokeStyle='#5a8ab0';ctx.lineWidth=2.5;
    ctx.beginPath();ctx.ellipse(0,hy+10,22,20,0,0,Math.PI*2);ctx.stroke();
    // Parte interior/cara — piel del predator visible
    ctx.fillStyle='#c8a46e';
    ctx.beginPath();ctx.ellipse(0,hy+13,14,15,0,0,Math.PI*2);ctx.fill();
    // Máscara facial central — marrón orgánico
    ctx.fillStyle='#5a3e10';
    ctx.beginPath();ctx.ellipse(0,hy+14,9,12,0,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.3)';ctx.lineWidth=1;ctx.stroke();
    // Rejilla de respiración — líneas horizontales
    ctx.strokeStyle='rgba(0,0,0,0.5)';ctx.lineWidth=1;
    for(let r=-2;r<=3;r++){ctx.beginPath();ctx.moveTo(-7,hy+14+r*3);ctx.lineTo(7,hy+14+r*3);ctx.stroke();}
    // Ojos del casco — luces rojas brillantes pequeñas
    ctx.fillStyle='rgba(255,30,30,0.9)';
    ctx.beginPath();ctx.ellipse(-7,hy+7,3.5,2.5,0,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.ellipse(7,hy+7,3.5,2.5,0,0,Math.PI*2);ctx.fill();
    // Brillo en ojos
    ctx.fillStyle='rgba(255,150,150,0.8)';
    ctx.beginPath();ctx.arc(-8,hy+6,1.2,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(6,hy+6,1.2,0,Math.PI*2);ctx.fill();
    // Detalle central del casco — placa nasal
    ctx.fillStyle='#2d4a6e';
    rr(ctx,-4,hy+2,8,10,3);ctx.fill();
    // Sensor tri-dot en la sien izquierda
    ctx.fillStyle='#c00';
    ctx.beginPath();ctx.arc(-18,hy+6,2.5,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(-16,hy+11,2,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(-20,hy+11,2,0,Math.PI*2);ctx.fill();
    // Brillo global del casco
    ctx.fillStyle='rgba(100,160,220,0.18)';
    ctx.beginPath();ctx.ellipse(-5,hy+2,10,7,0,0,Math.PI*2);ctx.fill();
    // Dreadlocks — tentáculos capilos
    const dlColors=['#1a1a1a','#2a1a0a','#111'];
    const dreads = [
      {x:-20,y:hy+4,len:28,angle:-0.3},{x:-23,y:hy+10,len:32,angle:-0.5},
      {x:-22,y:hy+16,len:30,angle:-0.7},{x:-18,y:hy+20,len:26,angle:-0.55},
      {x:20,y:hy+4,len:28,angle:0.3},{x:23,y:hy+10,len:32,angle:0.5},
      {x:22,y:hy+16,len:30,angle:0.7},{x:18,y:hy+20,len:26,angle:0.55},
      {x:-10,y:hy+1,len:22,angle:-0.15},{x:10,y:hy+1,len:22,angle:0.15},
    ];
    dreads.forEach((d,i)=>{
      ctx.strokeStyle=dlColors[i%dlColors.length];ctx.lineWidth=5;ctx.lineCap='round';
      const swing=Math.sin(frame*1.5+i*0.8)*3;
      ctx.beginPath();ctx.moveTo(d.x,d.y);
      ctx.quadraticCurveTo(d.x+Math.sin(d.angle)*d.len*0.5+swing,d.y+d.len*0.6,d.x+Math.sin(d.angle)*d.len+swing,d.y+d.len);
      ctx.stroke();
      // Band rings on dreads
      ctx.strokeStyle='#8b6914';ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(d.x+Math.sin(d.angle)*d.len*0.4+swing*0.4,d.y+d.len*0.45);
      ctx.lineTo(d.x+Math.sin(d.angle)*d.len*0.4+swing*0.4+3,d.y+d.len*0.45);
      ctx.stroke();
    });
  } else {
    ctx.fillStyle=char.skin;ctx.beginPath();ctx.arc(0,headY,headR,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,0.2)';ctx.lineWidth=1.5;ctx.stroke();

    // Enzin: chubby rosy cheeks
    if(s==='enzin'){
      ctx.fillStyle='rgba(255,130,100,0.22)';
      ctx.beginPath();ctx.ellipse(-headR*0.52,headY+headR*0.18,8,6,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(headR*0.52,headY+headR*0.18,8,6,0,0,Math.PI*2);ctx.fill();
    }

    drawHair(ctx, char, headR, headY);
    if(char.glasses){
      // Big scientist glasses with thick frame
      const glassR = headR*0.38;
      // Frame thick
      ctx.strokeStyle='#0c2461';ctx.lineWidth=2.5;
      ctx.fillStyle='rgba(147,197,253,0.25)';
      // Left lens
      ctx.beginPath();ctx.arc(-headR*0.38,headY-headR*0.12,glassR*0.85,0,Math.PI*2);
      ctx.fill();ctx.stroke();
      // Right lens
      ctx.beginPath();ctx.arc(headR*0.38,headY-headR*0.12,glassR*0.85,0,Math.PI*2);
      ctx.fill();ctx.stroke();
      // Bridge
      ctx.strokeStyle='#0c2461';ctx.lineWidth=1.8;
      ctx.beginPath();ctx.moveTo(-headR*0.38+glassR*0.85,headY-headR*0.12);
      ctx.lineTo(headR*0.38-glassR*0.85,headY-headR*0.12);ctx.stroke();
      // Arms of glasses
      ctx.beginPath();ctx.moveTo(-headR*0.38-glassR*0.85,headY-headR*0.12);
      ctx.lineTo(-headR-2,headY-headR*0.05);ctx.stroke();
      ctx.beginPath();ctx.moveTo(headR*0.38+glassR*0.85,headY-headR*0.12);
      ctx.lineTo(headR+2,headY-headR*0.05);ctx.stroke();
      // Lens glare
      ctx.fillStyle='rgba(255,255,255,0.6)';
      ctx.beginPath();ctx.arc(-headR*0.52,headY-headR*0.28,3,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(headR*0.24,headY-headR*0.28,3,0,Math.PI*2);ctx.fill();
    }
    if(char.hat==='ninja'){
      // Sub-Zero chibi: capucha redondeada con cara oval visible al frente

      // 1. Capucha grande negra (fondo completo)
      ctx.fillStyle='#111827';
      ctx.beginPath();
      ctx.arc(0, headY, headR+4, 0, Math.PI*2);
      ctx.fill();

      // 2. Franja azul de la capucha (anillo alrededor)
      ctx.fillStyle='#1e3a8a';
      ctx.beginPath();
      ctx.arc(0, headY, headR+4, 0, Math.PI*2);
      ctx.arc(0, headY-headR*0.05, headR*0.72, 0, Math.PI*2, true);
      ctx.fill('evenodd');

      // 3. Cara (piel) — óvalo centrado, levemente desplazado hacia arriba
      ctx.fillStyle=char.skin;
      ctx.beginPath();
      ctx.ellipse(0, headY-headR*0.05, headR*0.72, headR*0.78, 0, 0, Math.PI*2);
      ctx.fill();
      // Sombra lateral sutil en cara
      const faceGrad = ctx.createRadialGradient(-headR*0.25, headY-headR*0.2, 0, 0, headY, headR*0.75);
      faceGrad.addColorStop(0, 'rgba(255,255,255,0.08)');
      faceGrad.addColorStop(1, 'rgba(0,0,0,0.12)');
      ctx.fillStyle=faceGrad;
      ctx.beginPath();
      ctx.ellipse(0, headY-headR*0.05, headR*0.72, headR*0.78, 0, 0, Math.PI*2);
      ctx.fill();

      // 4. Highlight superior de la capucha
      ctx.fillStyle='rgba(96,165,250,0.22)';
      ctx.beginPath();
      ctx.ellipse(0, headY-headR*0.82, headR*0.55, headR*0.22, 0, 0, Math.PI*2);
      ctx.fill();

      // 5. Borde/contorno de la capucha
      ctx.strokeStyle='#0f172a'; ctx.lineWidth=2;
      ctx.beginPath();ctx.arc(0, headY, headR+4, 0, Math.PI*2);ctx.stroke();
      // Borde interno donde capucha se une a la cara
      ctx.strokeStyle='rgba(30,58,138,0.8)'; ctx.lineWidth=1.5;
      ctx.beginPath();
      ctx.ellipse(0, headY-headR*0.05, headR*0.72, headR*0.78, 0, 0, Math.PI*2);
      ctx.stroke();
    }

    // ---- BLINK CALCULATION ----
    // Each char has a different blink rhythm based on id
    const blinkCycle = 4.5 + (char.id * 0.7) % 2.5; // 4.5-7s cycle per char
    const blinkPhase = (frame * 0.12 + char.id * 3.7) % blinkCycle;
    const isBlinking = blinkPhase > blinkCycle - 0.18; // blink window ~0.18s
    const blinkAmt = isBlinking ? Math.max(0, 1 - Math.abs((blinkPhase-(blinkCycle-0.09))/0.09)) : 0;
    // Double-blink for some chars
    const isDoubleBlink = (char.id===0||char.id===1||char.id===9);
    const blink2Phase = (frame*0.12 + char.id*3.7 + 0.25) % blinkCycle;
    const blink2Amt = (isDoubleBlink && blink2Phase > blinkCycle-0.15) ? Math.max(0,1-Math.abs((blink2Phase-(blinkCycle-0.075))/0.075)) : 0;
    const finalBlink = Math.max(blinkAmt, blink2Amt);

    // Eye size — enzin has much bigger eyes
    const eyeScale = s==='enzin' ? 1.55 : 1;
    const ex=headR*0.38,ey=headY-headR*0.15;
    const er=headR*0.28*eyeScale;
    const eyeH = er*(s==='enzin'?1.3:1.1);

    // ---- DETERMINE EXPRESSION MODE ----
    // Priority: funnyAnim > state > trait/char
    let exprMode = 'default';
    if(funnyAnim==='dizzy')          exprMode='dizzy';
    else if(funnyAnim==='fall')      exprMode='fall';
    else if(funnyAnim==='sneeze')    exprMode='sneeze';
    else if(funnyAnim==='celebrate'||funnyAnim==='bounce_crazy') exprMode='happy';
    else if(funnyAnim==='flex')      exprMode='flex';
    else if(funnyAnim==='wiggle'||funnyAnim==='dance') exprMode='dance';
    else if(funnyAnim==='robot')     exprMode='focused';
    else if(funnyAnim==='moonwalk')  exprMode='cool';
    else if(funnyAnim==='spin')      exprMode='dizzy';
    else if(funnyAnim==='shake')     exprMode='scared';
    else if(state==='interact')      exprMode='interact';
    else if(state==='dance')         exprMode='happy';
    else if(state==='walk'){
      // trait-based walk expression
      if(char.trait==='ninja')       exprMode='focused';
      else if(char.trait==='mage')   exprMode='curious';
      else if(char.trait==='kid'&&s==='enzin') exprMode='smug';
      else                           exprMode='walk';
    } else {
      // idle — trait personality
      if(char.trait==='ninja')       exprMode='serious';
      else if(char.trait==='mage')   exprMode='curious';
      else if(char.trait==='chef')   exprMode='proud';
      else if(char.trait==='elder')  exprMode='kind';
      else if(char.trait==='fairy')  exprMode='playful';
      else if(char.trait==='robot')  exprMode='focused';
      else if(char.trait==='scientist') exprMode='curious';
      else if(char.trait==='ranger') exprMode='confident';
      else if(s==='enzin')           exprMode='smug';
      else                           exprMode='default';
    }

    // ---- EYEBROWS ----
    ctx.strokeStyle = char.hair && char.hair!=='#e2e8f0' ? char.hair : 'rgba(0,0,0,0.75)';
    ctx.lineCap='round';
    const browY=ey-er*1.2;
    const browW=er*1.05;
    const bw2 = s==='enzin' ? 3 : 2;

    function drawBrows(liftL,liftR,slopeL,slopeR,thick){
      ctx.lineWidth=thick||bw2;
      // left brow
      ctx.beginPath();ctx.moveTo(-ex-browW,browY+slopeL);ctx.quadraticCurveTo(-ex,browY-liftL,-ex+browW,browY+slopeL*0.3);ctx.stroke();
      // right brow
      ctx.beginPath();ctx.moveTo(ex-browW,browY+slopeR*0.3);ctx.quadraticCurveTo(ex,browY-liftR,ex+browW,browY+slopeR);ctx.stroke();
    }

    if(exprMode==='dizzy'||exprMode==='fall')      { ctx.lineWidth=2; ctx.beginPath();ctx.moveTo(-ex-browW,browY+2);ctx.quadraticCurveTo(-ex-browW*0.2,browY-3,-ex+browW,browY+2);ctx.stroke();ctx.beginPath();ctx.moveTo(ex-browW,browY+2);ctx.quadraticCurveTo(ex+browW*0.2,browY-3,ex+browW,browY+2);ctx.stroke(); }
    else if(exprMode==='sneeze'||exprMode==='flex'||exprMode==='scared') { ctx.lineWidth=bw2+0.5; ctx.beginPath();ctx.moveTo(-ex-browW,browY-2);ctx.lineTo(-ex+browW,browY+5);ctx.stroke();ctx.beginPath();ctx.moveTo(ex+browW,browY-2);ctx.lineTo(ex-browW,browY+5);ctx.stroke(); }
    else if(exprMode==='happy'||exprMode==='playful'||exprMode==='dance')   { drawBrows(9,9,0,0,bw2); }
    else if(exprMode==='interact')    { drawBrows(7,12,0,-3,bw2); } // one raised = curious
    else if(exprMode==='serious'||exprMode==='focused') { const browThick = char.hat==='ninja'?3.5:bw2; ctx.lineWidth=browThick;ctx.strokeStyle=char.hat==='ninja'?'#111':ctx.strokeStyle;ctx.beginPath();ctx.moveTo(-ex-browW,browY);ctx.lineTo(-ex+browW,browY+4);ctx.stroke();ctx.beginPath();ctx.moveTo(ex+browW,browY);ctx.lineTo(ex-browW,browY+4);ctx.stroke(); }
    else if(exprMode==='smug')        { ctx.lineWidth=bw2+0.5;ctx.beginPath();ctx.moveTo(-ex-browW,browY+3);ctx.lineTo(-ex+browW,browY-2);ctx.stroke();ctx.beginPath();ctx.moveTo(ex-browW,browY-4);ctx.quadraticCurveTo(ex,browY-10,ex+browW,browY-4);ctx.stroke(); } // one flat one raised = smug
    else if(exprMode==='curious')     { drawBrows(4,10,-1,-3,bw2); }
    else if(exprMode==='cool')        { ctx.lineWidth=bw2;ctx.beginPath();ctx.moveTo(-ex-browW,browY-1);ctx.lineTo(-ex+browW,browY-1);ctx.stroke();ctx.beginPath();ctx.moveTo(ex-browW,browY-1);ctx.lineTo(ex+browW,browY-1);ctx.stroke(); }
    else if(exprMode==='proud')       { drawBrows(5,5,1,1,bw2+0.5); }
    else if(exprMode==='kind')        { drawBrows(3,3,2,2,bw2); }
    else if(exprMode==='confident')   { drawBrows(6,3,0,2,bw2); }
    else if(exprMode==='walk')        { drawBrows(4,4,1,1,bw2); }
    else                               { drawBrows(5,5,1,1,bw2); }

    // ---- EYES (with blink) ----
    const eyeOpenH = eyeH * (1 - finalBlink*0.95);

    if(exprMode==='dizzy'){
      ctx.fillStyle='white';ctx.beginPath();ctx.ellipse(-ex,ey,er,eyeOpenH,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(ex,ey,er,eyeOpenH,0,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle='#222';ctx.lineWidth=1.5;
      ctx.beginPath();ctx.moveTo(-ex-er*0.5,ey-er*0.5);ctx.lineTo(-ex+er*0.5,ey+er*0.5);ctx.stroke();
      ctx.beginPath();ctx.moveTo(-ex+er*0.5,ey-er*0.5);ctx.lineTo(-ex-er*0.5,ey+er*0.5);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ex-er*0.5,ey-er*0.5);ctx.lineTo(ex+er*0.5,ey+er*0.5);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ex+er*0.5,ey-er*0.5);ctx.lineTo(ex-er*0.5,ey+er*0.5);ctx.stroke();
    } else if(exprMode==='sneeze'||exprMode==='scared'){
      // tightly shut eyes
      ctx.fillStyle='#222';
      ctx.beginPath();ctx.ellipse(-ex,ey,er*0.8,er*0.2*(1-finalBlink)+0.5,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(ex,ey,er*0.8,er*0.2*(1-finalBlink)+0.5,0,0,Math.PI*2);ctx.fill();
    } else if(exprMode==='cool'||exprMode==='smug'){
      // half-lidded eyes
      ctx.fillStyle='white';ctx.beginPath();ctx.ellipse(-ex,ey,er,eyeOpenH*0.65,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(ex,ey,er,eyeOpenH*0.65,0,0,Math.PI*2);ctx.fill();
      // lid
      ctx.fillStyle=char.skin;ctx.beginPath();ctx.ellipse(-ex,ey-eyeOpenH*0.3,er,eyeOpenH*0.4,0,Math.PI,0);ctx.fill();
      ctx.beginPath();ctx.ellipse(ex,ey-eyeOpenH*0.3,er,eyeOpenH*0.4,0,Math.PI,0);ctx.fill();
      let px=0,py=0;
      if(window.gMX!==undefined&&isPlayer){const ang=Math.atan2(window.gMY-(0+headY),window.gMX-0);px=Math.cos(ang)*2;py=Math.sin(ang)*2;}
      ctx.fillStyle='#222';ctx.beginPath();ctx.arc(-ex+px,ey+py,er*0.5,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(ex+px,ey+py,er*0.5,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='white';ctx.beginPath();ctx.arc(-ex+1,ey-1,er*0.2,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(ex+1,ey-1,er*0.2,0,Math.PI*2);ctx.fill();
    } else if(char.hat==='ninja'){
      // Sub-Zero: ojos celestes glowing con párpado semientornado (enojado)
      if(finalBlink<0.9){
        const eyeH2 = Math.max(0.5, eyeOpenH*0.7); // ojos un poco cerrados = enojado
        // Blanco del ojo
        ctx.fillStyle='#d0eeff';
        ctx.beginPath();ctx.ellipse(-ex,ey,er,eyeH2,0,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.ellipse(ex,ey,er,eyeH2,0,0,Math.PI*2);ctx.fill();
        // Iris celeste brillante
        ctx.shadowColor='#7dd3fc'; ctx.shadowBlur=6;
        ctx.fillStyle='#7dd3fc';
        ctx.beginPath();ctx.arc(-ex,ey,er*0.62,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(ex,ey,er*0.62,0,Math.PI*2);ctx.fill();
        // Núcleo blanco
        ctx.shadowBlur=3;
        ctx.fillStyle='rgba(220,245,255,0.9)';
        ctx.beginPath();ctx.arc(-ex-1,ey-1,er*0.32,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(ex-1,ey-1,er*0.32,0,Math.PI*2);ctx.fill();
        ctx.shadowBlur=0; ctx.shadowColor='transparent';
        // Párpado superior semientornado (ceño)
        ctx.fillStyle=char.skin;
        ctx.beginPath();ctx.ellipse(-ex,ey-eyeH2*0.55,er*1.05,eyeH2*0.5,0,Math.PI,0);ctx.fill();
        ctx.beginPath();ctx.ellipse(ex,ey-eyeH2*0.55,er*1.05,eyeH2*0.5,0,Math.PI,0);ctx.fill();
      }
    } else {
      // Normal eyes with blink
      ctx.fillStyle='white';ctx.beginPath();ctx.ellipse(-ex,ey,er,Math.max(0.5,eyeOpenH),0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(ex,ey,er,Math.max(0.5,eyeOpenH),0,0,Math.PI*2);ctx.fill();

      // Eyelid when blinking
      if(finalBlink>0.1){
        ctx.fillStyle=char.skin;
        ctx.beginPath();ctx.ellipse(-ex,ey-eyeOpenH*0.1,er*1.05,eyeH*finalBlink*1.05,0,Math.PI,0);ctx.fill();
        ctx.beginPath();ctx.ellipse(ex,ey-eyeOpenH*0.1,er*1.05,eyeH*finalBlink*1.05,0,Math.PI,0);ctx.fill();
      }

      let px=0,py=0;
      if(window.gMX!==undefined&&isPlayer){const ang=Math.atan2(window.gMY-(0+headY),window.gMX-0);px=Math.cos(ang)*2.5;py=Math.sin(ang)*2.5;}

      if(finalBlink<0.85){
        // pupils
        ctx.fillStyle='#222';ctx.beginPath();ctx.arc(-ex+px,ey+py,er*0.55,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(ex+px,ey+py,er*0.55,0,Math.PI*2);ctx.fill();
        // shine
        const shineX = s==='enzin'?-2:1, shineY=s==='enzin'?-3:-1, shineR=er*(s==='enzin'?0.28:0.2);
        ctx.fillStyle='white';ctx.beginPath();ctx.arc(-ex+shineX,ey+shineY,shineR,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(ex+shineX,ey+shineY,shineR,0,Math.PI*2);ctx.fill();
        // Extra shine dot for Enzin (big sparkly eyes)
        if(s==='enzin'){
          ctx.beginPath();ctx.arc(-ex+3,ey+2,er*0.13,0,Math.PI*2);ctx.fill();
          ctx.beginPath();ctx.arc(ex+3,ey+2,er*0.13,0,Math.PI*2);ctx.fill();
        }
      }
    }

    // ---- MOUTH ---- (hidden for ninja Sub-Zero)
    if(char.hat!=='ninja'){
    const mouthY = headY+headR*(char.id===3 ? 0.52 : 0.3);
    const mouthR = headR*0.25;
    ctx.strokeStyle='#8b4513';ctx.lineCap='round';

    if(exprMode==='sneeze'){
      ctx.fillStyle='#c1440e';ctx.beginPath();ctx.arc(0,mouthY,headR*0.18,0,Math.PI);ctx.fill();
      ctx.fillStyle='rgba(100,180,255,0.7)';
      for(let i=-1;i<=1;i++){ctx.beginPath();ctx.arc(i*7,headY+headR*0.55,3,0,Math.PI*2);ctx.fill();}
    } else if(exprMode==='happy'||exprMode==='playful'){
      ctx.lineWidth=2;ctx.beginPath();ctx.arc(0,headY+headR*0.22,headR*0.3,0.1,Math.PI-0.1);ctx.stroke();
      ctx.fillStyle='white';ctx.fillRect(-headR*0.2,headY+headR*0.19,headR*0.4,headR*0.13);
    } else if(exprMode==='dizzy'||exprMode==='fall'){
      ctx.lineWidth=1.8;
      ctx.beginPath();ctx.moveTo(-mouthR,mouthY);ctx.quadraticCurveTo(-mouthR*0.4,mouthY-5,0,mouthY);ctx.quadraticCurveTo(mouthR*0.4,mouthY+5,mouthR,mouthY);ctx.stroke();
    } else if(exprMode==='scared'){
      ctx.lineWidth=1.8;ctx.beginPath();ctx.arc(0,headY+headR*0.35,headR*0.15,Math.PI,0);ctx.stroke();
    } else if(exprMode==='serious'||exprMode==='focused'){
      ctx.lineWidth=1.8;ctx.beginPath();ctx.moveTo(-mouthR*0.8,mouthY);ctx.lineTo(mouthR*0.8,mouthY);ctx.stroke();
    } else if(exprMode==='smug'){
      // smirk — mouth curves only on one side
      ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(-mouthR*0.2,mouthY+1);ctx.quadraticCurveTo(mouthR*0.3,mouthY-4,mouthR*0.85,mouthY-2);ctx.stroke();
    } else if(exprMode==='curious'||exprMode==='interact'){
      // small open O mouth
      ctx.fillStyle='#c1440e';ctx.beginPath();ctx.ellipse(0,mouthY,headR*0.08,headR*0.1,0,0,Math.PI*2);ctx.fill();
    } else if(exprMode==='proud'){
      ctx.lineWidth=2;ctx.beginPath();ctx.arc(0,headY+headR*0.25,headR*0.22,0.2,Math.PI-0.2);ctx.stroke();
    } else if(exprMode==='kind'){
      ctx.lineWidth=1.8;ctx.beginPath();ctx.arc(0,headY+headR*0.28,headR*0.2,0.3,Math.PI-0.3);ctx.stroke();
    } else if(s==='enzin'){
      // default Enzin: wide mischievous grin + freckles
      ctx.lineWidth=2.5;ctx.beginPath();ctx.arc(0,headY+headR*0.26,headR*0.32,0.12,Math.PI-0.12);ctx.stroke();
      ctx.fillStyle='rgba(170,90,40,0.35)';
      [[-10,headY+headR*0.1],[10,headY+headR*0.1]].forEach(([fx,fy])=>{
        ctx.beginPath();ctx.arc(fx-3,fy,2,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(fx,fy,2,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(fx+3,fy,2,0,Math.PI*2);ctx.fill();
      });
    } else {
      ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(0,mouthY,mouthR,0.2,Math.PI-0.2);ctx.stroke();
    }

    // ---- MUSTACHE (Dr Lupe id=3) ----
    if(char.id===3){
      const muY = mouthY - headR*0.18; // justo encima de la boca
      ctx.fillStyle='#2a2a2a';
      // Lado izquierdo del bigote
      ctx.save();
      ctx.translate(-headR*0.07, muY);
      ctx.beginPath();
      ctx.moveTo(0,0);
      ctx.bezierCurveTo(-headR*0.12,-headR*0.08,-headR*0.3,-headR*0.1,-headR*0.3,headR*0.02);
      ctx.bezierCurveTo(-headR*0.3,headR*0.1,-headR*0.1,headR*0.1,0,headR*0.04);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
      // Lado derecho del bigote (espejo)
      ctx.save();
      ctx.translate(headR*0.07, muY);
      ctx.scale(-1,1);
      ctx.beginPath();
      ctx.moveTo(0,0);
      ctx.bezierCurveTo(-headR*0.12,-headR*0.08,-headR*0.3,-headR*0.1,-headR*0.3,headR*0.02);
      ctx.bezierCurveTo(-headR*0.3,headR*0.1,-headR*0.1,headR*0.1,0,headR*0.04);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }
    } // end if(char.hat!=='ninja') — mouth hidden for Sub-Zero
  }
  drawHat(ctx, char, headR, headY);
  // ---- BRAZOS Sub-Zero — limpios, con guardabrazos azules (solo en idle/walk) ----
  if(char.hat==='ninja' && armState!=='interact' && armState!=='dance' && armState!=='celebrate' && armState!=='flail' && armState!=='flex' && armState!=='carry'){
    // Brazos colgando naturalmente (como el personaje base)
    ctx.strokeStyle='#0d1b2e'; ctx.lineWidth=armW+1; ctx.lineCap='round';
    ctx.beginPath(); ctx.moveTo(bx,-20); ctx.lineTo(bx-4+Math.sin(frame)*3,-3); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(-bx,-20); ctx.lineTo(-bx+4-Math.sin(frame)*3,-3); ctx.stroke();

    // Guardabrazo derecho — placa azul redondeada
    const gaX = bx-2+Math.sin(frame)*1.5;
    ctx.fillStyle='#1a3a6e';
    rr(ctx, gaX-2, -18, 10, 9, 3); ctx.fill();
    ctx.strokeStyle='#2d5a9e'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='rgba(147,197,253,0.3)';
    ctx.beginPath(); ctx.ellipse(gaX+3, -15, 3, 2, 0, 0, Math.PI*2); ctx.fill();

    // Guardabrazo izquierdo
    const gaX2 = -bx-8+Math.sin(frame)*1.5;
    ctx.fillStyle='#1a3a6e';
    rr(ctx, gaX2-2, -18, 10, 9, 3); ctx.fill();
    ctx.strokeStyle='#2d5a9e'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='rgba(147,197,253,0.3)';
    ctx.beginPath(); ctx.ellipse(gaX2+3, -15, 3, 2, 0, 0, Math.PI*2); ctx.fill();
  }
  ctx.restore();
}

function drawHair(ctx,char,headR,headY){
  ctx.fillStyle=char.hair;
  const id=char.id;
  if(id===0){
    // Enzin: spiky messy hair on big head
    ctx.beginPath();ctx.arc(0,headY-headR*0.15,headR*0.95,Math.PI,0);ctx.fill();
    // spikes
    for(let i=-2;i<=2;i++){ctx.beginPath();ctx.moveTo(i*9,headY-headR*0.6);ctx.lineTo(i*9+4,headY-headR*1.05);ctx.lineTo(i*9+8,headY-headR*0.6);ctx.fill();}
  }
  else if(id===1){ctx.beginPath();ctx.arc(0,headY,headR+4,Math.PI,0);ctx.fill();ctx.fillRect(-headR-2,headY,7,headR*1.2);ctx.fillRect(headR-5,headY,7,headR*1.2);}
  else if(id===2){
    // Dusty: rugged cowboy hair, slightly wavy under the hat
    ctx.beginPath();ctx.arc(0,headY,headR*0.88,Math.PI,0);ctx.fill();
    // Sideburns
    ctx.fillRect(-headR-2,headY,8,headR*0.6);
    ctx.fillRect(headR-6,headY,8,headR*0.6);
    // stubble hint on chin
    ctx.fillStyle='rgba(100,60,0,0.3)';
    ctx.beginPath();ctx.arc(0,headY+headR*0.55,headR*0.55,0.1,Math.PI-0.1);ctx.fill();
  }
  else if(id===3){
    // Dr Lupe: neat dark hair with ponytail
    ctx.beginPath();ctx.arc(0,headY,headR*0.92,Math.PI,0);ctx.fill();
    // Ponytail on the side (when facing right)
    ctx.save();
    ctx.fillStyle=char.hair;
    // Ponytail base
    ctx.beginPath();ctx.ellipse(headR*0.7,headY-2,7,12,-0.4,0,Math.PI*2);ctx.fill();
    // Ponytail strand flowing down
    ctx.strokeStyle=char.hair;ctx.lineWidth=5;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(headR*0.9,headY-4);
    ctx.quadraticCurveTo(headR*1.4,headY+14,headR*1.2,headY+30);ctx.stroke();
    // Hair tie (color accent)
    ctx.fillStyle='#0ea5e9';
    ctx.beginPath();ctx.arc(headR*1.1,headY+18,3,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }
  else if(id===5){ctx.beginPath();ctx.arc(0,headY,headR+2,Math.PI,0);ctx.fill();ctx.fillRect(-headR-2,headY,6,headR*1.5);ctx.fillRect(headR-4,headY,6,headR*1.5);}
  else if(id===6){ctx.beginPath();ctx.arc(0,headY-headR*0.2,headR*0.75,Math.PI,0);ctx.fill();}
  else if(id===8){/* predator — dreads drawn in head block */}
  else if(id===9){for(let i=-1;i<=1;i++){ctx.beginPath();ctx.arc(i*8,headY-headR*0.5,9,Math.PI,0);ctx.fill();}ctx.beginPath();ctx.arc(0,headY-headR,8,Math.PI,0);ctx.fill();}
  else{ctx.beginPath();ctx.arc(0,headY-headR*0.2,headR*0.9,Math.PI,0);ctx.fill();}
}

function drawHat(ctx,char,headR,headY){
  const hat=char.hat;
  if(!hat||hat==='none')return;
  if(hat==='straw'){
    ctx.fillStyle='#d4a017';rr(ctx,-headR-6,headY-headR-4,headR*2+12,8,3);ctx.fill();
    ctx.fillStyle='#b8860b';rr(ctx,-headR*0.6,headY-headR-22,headR*1.2,22,4);ctx.fill();
    ctx.strokeStyle='#92400e';ctx.lineWidth=1;ctx.stroke();
  } else if(hat==='cowboy'){
    // Wide brim cowboy hat — detailed with band and crease
    const brimW = headR*2+18, brimH = 8;
    const crownW = headR*1.15, crownH = 30;
    // Hat shadow under brim
    ctx.fillStyle='rgba(0,0,0,0.2)';
    ctx.beginPath();ctx.ellipse(0,headY-headR+2,headR+10,5,0,0,Math.PI*2);ctx.fill();
    // Wide brim
    ctx.fillStyle='#7a3210';
    rr(ctx,-brimW/2,headY-headR-brimH+2,brimW,brimH+2,3);ctx.fill();
    // Brim underside darker
    ctx.fillStyle='#5c2508';
    ctx.fillRect(-brimW/2,headY-headR-1,brimW,4);
    // Crown (main hat body)
    ctx.fillStyle='#8B4513';
    rr(ctx,-crownW/2,headY-headR-crownH-4,crownW,crownH+4,4);ctx.fill();
    ctx.strokeStyle='#5c2508';ctx.lineWidth=1;ctx.stroke();
    // Crease on top of crown
    ctx.fillStyle='#7a3210';
    ctx.fillRect(-crownW/2+4,headY-headR-crownH-4,crownW-8,8);
    ctx.fillStyle='#5c2508';
    ctx.fillRect(-crownW/2+4,headY-headR-crownH,crownW-8,3);
    // Hat band (decorative stripe)
    ctx.fillStyle='#d4a017';
    ctx.fillRect(-crownW/2,headY-headR-10,crownW,5);
    // Metal buckle on band
    ctx.fillStyle='#fbbf24';
    ctx.fillRect(-4,headY-headR-10,8,5);
    ctx.fillStyle='rgba(0,0,0,0.3)';
    ctx.fillRect(-2,headY-headR-9,4,3);
    // Brim curve effect
    ctx.fillStyle='rgba(0,0,0,0.12)';
    ctx.beginPath();ctx.ellipse(-brimW/4+4,headY-headR-1,headR*0.6,3,0.2,0,Math.PI*2);ctx.fill();
  } else if(hat==='labcoat'){
    // No hat — Dr Lupe just has her hair + ponytail (drawn in drawHair)
  } else if(hat==='antenna'){
    ctx.strokeStyle='#94a3b8';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(0,headY-headR);ctx.lineTo(0,headY-headR-18);ctx.stroke();
    ctx.fillStyle='#f472b6';ctx.beginPath();ctx.arc(0,headY-headR-20,4,0,Math.PI*2);ctx.fill();
  } else if(hat==='wizard'){
    ctx.fillStyle='#4c1d95';
    ctx.beginPath();ctx.moveTo(-headR*0.65,headY-headR+4);ctx.lineTo(0,headY-headR-36);ctx.lineTo(headR*0.65,headY-headR+4);ctx.closePath();ctx.fill();
    ctx.fillStyle='#fde047';ctx.beginPath();ctx.arc(0,headY-headR-38,5,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#6d28d9';rr(ctx,-headR-2,headY-headR-2,headR*2+4,10,3);ctx.fill();
    ctx.fillStyle='rgba(253,224,71,0.8)';
    [[6,-headR-26],[-8,-headR-18]].forEach(([x,y])=>{ctx.beginPath();ctx.arc(x,y,2.5,0,Math.PI*2);ctx.fill();});
  } else if(hat==='chef'){
    ctx.fillStyle='white';ctx.beginPath();ctx.arc(0,headY-headR-14,16,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(-10,headY-headR-8,10,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(10,headY-headR-8,10,0,Math.PI*2);ctx.fill();
    ctx.fillRect(-headR*0.6,headY-headR-4,headR*1.2,10);
  } else if(hat==='ninja'){
    // Sub-Zero: máscara ninja sobre la parte inferior de la cara
    // La cara/capucha ya fue dibujada en el head block

    // mT = donde empieza la máscara (justo debajo de los ojos)
    const mT = headY + headR*0.22;
    const mH = headR*0.75;
    const mW = headR*0.68; // semiancho de la cara visible en ese punto

    // === Alas azules laterales (se solapan con la capucha) ===
    ctx.fillStyle='#1e40af';
    // Ala izquierda
    ctx.beginPath();
    ctx.moveTo(-mW, mT);
    ctx.quadraticCurveTo(-headR*0.9, mT+mH*0.4, -headR*0.75, mT+mH);
    ctx.lineTo(-mW*0.38, mT+mH);
    ctx.lineTo(-mW*0.42, mT);
    ctx.closePath();ctx.fill();
    // Ala derecha
    ctx.beginPath();
    ctx.moveTo(mW, mT);
    ctx.quadraticCurveTo(headR*0.9, mT+mH*0.4, headR*0.75, mT+mH);
    ctx.lineTo(mW*0.38, mT+mH);
    ctx.lineTo(mW*0.42, mT);
    ctx.closePath();ctx.fill();
    // Borde de alas
    ctx.strokeStyle='#1e3a8a';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(-mW,mT);ctx.quadraticCurveTo(-headR*0.9,mT+mH*0.4,-headR*0.75,mT+mH);ctx.stroke();
    ctx.beginPath();ctx.moveTo(mW,mT);ctx.quadraticCurveTo(headR*0.9,mT+mH*0.4,headR*0.75,mT+mH);ctx.stroke();

    // === Placa central metálica (gris azulado oscuro) ===
    ctx.fillStyle='#1e293b';
    ctx.beginPath();
    ctx.moveTo(-mW*0.42, mT);
    ctx.lineTo( mW*0.42, mT);
    ctx.lineTo( mW*0.36, mT+mH);
    ctx.lineTo(-mW*0.36, mT+mH);
    ctx.closePath();ctx.fill();
    ctx.strokeStyle='#0f172a';ctx.lineWidth=1;ctx.stroke();

    // Líneas de ventilación horizontales
    ctx.strokeStyle='#334155';ctx.lineWidth=1;
    for(let i=1;i<=4;i++){
      const ry = mT + mH*i/5;
      const rx = mW*0.33*(1-i*0.04);
      ctx.beginPath();ctx.moveTo(-rx,ry);ctx.lineTo(rx,ry);ctx.stroke();
    }
    // Líneas verticales
    ctx.strokeStyle='#334155';ctx.lineWidth=0.7;
    [-0.13,0,0.13].forEach(ox=>{
      ctx.beginPath();ctx.moveTo(mW*ox,mT+mH*0.15);ctx.lineTo(mW*ox*0.9,mT+mH*0.9);ctx.stroke();
    });

    // Pieza nasal en el centro
    ctx.fillStyle='#0f172a';
    ctx.beginPath();
    ctx.ellipse(0, mT+mH*0.28, mW*0.16, mH*0.28, 0, 0, Math.PI*2);
    ctx.fill();

    // Highlight máscara
    ctx.fillStyle='rgba(147,197,253,0.12)';
    ctx.beginPath();ctx.ellipse(0, mT+4, mW*0.32, 4, 0, 0, Math.PI*2);ctx.fill();

    // Borde inferior redondeado (mentón de la máscara)
    ctx.strokeStyle='#3b82f6';ctx.lineWidth=1.5;ctx.lineCap='round';
    ctx.beginPath();
    ctx.moveTo(-headR*0.75, mT+mH);
    ctx.quadraticCurveTo(0, mT+mH+5, headR*0.75, mT+mH);
    ctx.stroke();
  } else if(hat==='flower'){
    ctx.fillStyle='#c084fc';
    for(let i=0;i<6;i++){ctx.save();ctx.rotate(i*Math.PI/3);ctx.beginPath();ctx.ellipse(0,headY-headR-8,4,9,0,0,Math.PI*2);ctx.fill();ctx.restore();}
    ctx.fillStyle='#fde047';ctx.beginPath();ctx.arc(0,headY-headR-8,5,0,Math.PI*2);ctx.fill();
  } else if(hat==='cap'){
    ctx.fillStyle='#166534';rr(ctx,-headR*0.6,headY-headR-8,headR*1.2,14,3);ctx.fill();
    ctx.fillRect(-headR,headY-headR-2,headR*0.4,6);
    ctx.fillStyle='#fff';ctx.font='bold 7px Arial';ctx.textAlign='center';ctx.fillText('🌿',0,headY-headR-2);
  } else if(hat==='pred_mask'){
    // Predator head drawn entirely in body shape block — nothing extra needed here
  }
}

