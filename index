  }
}

function _showTutStep(i){
  const s=TUTORIAL_STEPS[i];
  const box=document.getElementById('tutorial-box');
  const title=document.getElementById('tutorial-title');
  const text=document.getElementById('tutorial-text');
  const btn=document.getElementById('tutorial-btn');
  const prog=document.getElementById('tutorial-progress');
  const hl=document.getElementById('tutorial-highlight');
  const arr=document.getElementById('tutorial-arrow');

  title.innerHTML=s.icon+' '+s.title;
  text.innerHTML=s.text;
  btn.textContent=s.btn;
  box.style.display='block';

  // Dots
  prog.innerHTML='';
  TUTORIAL_STEPS.forEach((_,idx)=>{
    const d=document.createElement('div');
    d.className='tut-dot'+(idx<i?' done':idx===i?' active':'');
    prog.appendChild(d);
  });

  // Highlight
  if(s.highlight){
    const target=document.querySelector(s.highlight.el);
    if(target){
      const r=target.getBoundingClientRect();
      const wrap=document.getElementById('wrap').getBoundingClientRect();
      const pad=s.highlight.pad||6;
      hl.style.left=(r.left-wrap.left-pad)+'px';
      hl.style.top=(r.top-wrap.top-pad)+'px';
      hl.style.width=(r.width+pad*2)+'px';
      hl.style.height=(r.height+pad*2)+'px';
      hl.style.display='block';
    }else{ hl.style.display='none'; }
  } else { hl.style.display='none'; }

  // Arrow
  if(s.arrow && s.highlight){
    const target=document.querySelector(s.highlight.el);
    if(target){
      const r=target.getBoundingClientRect();
      const wrap=document.getElementById('wrap').getBoundingClientRect();
      arr.style.left=(r.left-wrap.left+r.width/2-16)+'px';
      arr.style.top=s.arrow==='above'?(r.top-wrap.top-52)+'px':(r.bottom-wrap.top+8)+'px';
      arr.textContent=s.arrow==='above'?'⬇️':'⬆️';
      arr.style.display='block';
    } else { arr.style.display='none'; }
  } else { arr.style.display='none'; }

  // Animate box in
  box.style.opacity='0'; box.style.transform='translateX(-50%) translateY(20px)';
  requestAnimationFrame(()=>{
    box.style.transition='opacity 0.4s, transform 0.4s';
    box.style.opacity='1'; box.style.transform='translateX(-50%) translateY(0)';
  });
}

function _hideTutorial(){
  document.getElementById('tutorial-box').style.display='none';
  document.getElementById('tutorial-highlight').style.display='none';
  document.getElementById('tutorial-arrow').style.display='none';
  game._msg('🌿 ¡Buena suerte, aventurero! ¡A recolectar recursos!');
}

