        ctx.strokeStyle='#15803d';ctx.lineWidth=2.5;
      } else {
        ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;
      }
      rr(ctx,cx-cardW/2,cardY-cardH/2,cardW,cardH,16);
      ctx.stroke();

      // Dibujar personaje
      ctx.save();
      ctx.translate(cx, cardY+8);
      let charScale=1.15, charAnim='idle', charFrame=t*2.5;
      if(hover && !isSelected){
        charScale=1.2;
        ctx.translate(0, Math.sin(t*4)*6);
        charAnim='dance';charFrame=t*6;
      }
      if(isSelected){
        // Animación de salto y celebración
        const jmp=-Math.abs(Math.sin(selAnim*7))*32-Math.abs(Math.sin(selAnim*14))*16;
        ctx.translate(Math.sin(selAnim*9)*8, jmp);
        ctx.scale(1+Math.abs(Math.sin(selAnim*7))*0.12, 1);
        charScale=1.25;
        charAnim='celebrate';charFrame=selAnim*10;
      }
      ctx.scale(charScale,charScale);
      drawChar(ctx,c,charFrame,charAnim,true,false,1,isSelected?'celebrate':'none');
      ctx.restore();

      // Nombre
