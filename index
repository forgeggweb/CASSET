  _buildCraftInvBar(){
    const bar=document.getElementById('craft-inv-bar');
    if(!bar)return;
    bar.innerHTML='';
    // show items relevant to current recipe if selected, else all
    const r=CRAFT_RECIPES.find(x=>x.id===this._selectedCraftRecipe);
    const relevantItems=r ? [...new Set(r.pattern.filter(Boolean))] : Object.keys(ITEMS).filter(k=>(inventory[k]||0)>0);
    const showItems=r ? relevantItems : relevantItems.slice(0,8);
    if(showItems.length===0){
      bar.innerHTML='<div style="font-size:10px;color:rgba(255,255,255,0.3);padding:4px 8px">Sin ítems relevantes en inventario</div>';
      return;
    }
    showItems.forEach(itemId=>{
      const have=inventory[itemId]||0;
      const slot=document.createElement('div');
      slot.className='craft-inv-slot'+(this._craftSelectedItem===itemId?' selected-item':'');
      slot.innerHTML=`${itemSVG(itemId,28)}<div class="cis-name">${ITEMS[itemId]?.name||itemId}</div><div class="cis-count">${have}</div>`;
      slot.draggable=true;
      slot.addEventListener('dragstart', e=>{
        e.dataTransfer.setData('craft-item', itemId);
        e.dataTransfer.effectAllowed='copy';
        slot.style.opacity='0.6';
        this._craftSelectedItem=itemId;
        this._updateCursorLabel();
      });
      slot.addEventListener('dragend', ()=>{ slot.style.opacity=''; });
      slot.onclick=()=>{
        this._craftSelectedItem=(this._craftSelectedItem===itemId)?null:itemId;
        this._buildCraftInvBar();
        this._updateCursorLabel();
      };
      bar.appendChild(slot);
    });
  }
  _updateCursorLabel(){
    const el=document.getElementById('craft-cursor-item');
    if(!el)return;
    if(this._craftSelectedItem){
      const name=ITEMS[this._craftSelectedItem]?.name||this._craftSelectedItem;
      el.innerHTML=`✋ Colocando: <strong style="color:#f5c842">${name}</strong> — clic en celda para poner · clic en celda ocupada para quitar`;
    } else {
      el.textContent=this._selectedCraftRecipe?'👆 Elegí un ítem del inventario para colocar en la grilla':'';
    }
  }
  _addCraftCellDragDrop(cell, idx){
    // Allow dropping inventory items onto any craft cell
    cell.addEventListener('dragover', e=>{ e.preventDefault(); cell.style.outline='2px solid #f5c842'; });
    cell.addEventListener('dragleave', ()=>{ cell.style.outline=''; });
    cell.addEventListener('drop', e=>{
      e.preventDefault(); cell.style.outline='';
      const itemId=e.dataTransfer.getData('craft-item');
      if(!itemId) return;
      // count how many of this item already placed
      const alreadyPlaced=this._craftGrid.filter(x=>x===itemId).length;
      const have=inventory[itemId]||0;
      if(alreadyPlaced>=have){ this._msg(`❌ No tenés más ${ITEMS[itemId]?.name||itemId}`); return; }
      this._craftGrid[idx]=itemId;
      this._buildCraftGrid(); this._buildCraftInvBar();
    });
  }
  _buildCraftGrid(){
    const gridEl=document.getElementById('craft-grid');
    const resultEl=document.getElementById('craft-result-cell');
    const doBtn=document.getElementById('craft-do-btn');
    if(!gridEl)return;
    gridEl.innerHTML='';
    const r=CRAFT_RECIPES.find(x=>x.id===this._selectedCraftRecipe);
    this._updateCursorLabel();
    for(let i=0;i<9;i++){
      const cell=document.createElement('div');
      const placed=this._craftGrid[i];   // what player put here
      const needed=r?r.pattern[i]:null;  // what recipe needs here
      if(placed){
        // player placed something
        const isCorrect=placed===needed;
        cell.className='craft-cell has-item '+(isCorrect?'placed-ok':'placed-wrong');
        cell.innerHTML=`${itemSVG(placed,28)}<div class="cell-name">${ITEMS[placed]?.name||placed}</div>`;
        // click to remove
        cell.onclick=(()=>{
          const idx=i;
          return ()=>{ this._craftGrid[idx]=null; this._buildCraftGrid(); this._buildCraftInvBar(); };
        })();
      } else if(r && needed){
        // empty cell that recipe needs — just show as empty, clickeable
        cell.className='craft-cell';
        cell.onclick=(()=>{ const idx=i; return ()=>this._placeCraftItem(idx); })();
      } else if(r && !needed){
        // recipe says this cell should be empty
        cell.className='craft-cell needed-empty';
        cell.onclick=(()=>{ const idx=i; return ()=>this._placeCraftItem(idx); })();
      } else {
        // no recipe selected — still accept drops
        cell.className='craft-cell';
        cell.onclick=(()=>{ const idx=i; return ()=>this._placeCraftItem(idx); })();
      }
      // Enable drag-and-drop onto every cell
      this._addCraftCellDragDrop(cell, i);
      gridEl.appendChild(cell);
    }
    // check if pattern matches any recipe (auto-detect)
    let matchedRecipe = null;
    const hasAnything = this._craftGrid.some(x=>x);
    if(hasAnything){
      matchedRecipe = CRAFT_RECIPES.find(recipe =>
        this._craftGrid.every((placed,i) => placed === (recipe.pattern[i]||null))
      );
    }
    const patternMatch = !!matchedRecipe;
    if(patternMatch) this._selectedCraftRecipe = matchedRecipe.id;
    const r2 = matchedRecipe || CRAFT_RECIPES.find(x=>x.id===this._selectedCraftRecipe);
    // Result cell
    if(patternMatch && matchedRecipe){
      resultEl.className='craft-result-cell can-craft';
      resultEl.innerHTML=`${itemSVG(matchedRecipe.result.id,40)}<div class="res-name">${matchedRecipe.name}${matchedRecipe.result.qty>1?' x'+matchedRecipe.result.qty:''}</div>`;
      resultEl.onclick=()=>this.doCraft();
      doBtn.style.display='block';
      doBtn.disabled=false;
      doBtn.textContent=`⚒️ Craftear ${matchedRecipe.name}`;
    } else if(r2 && !patternMatch){
      resultEl.className='craft-result-cell';
      resultEl.innerHTML=`<div style="opacity:0.35">${itemSVG(r2.result.id,36)}</div><div class="res-name" style="opacity:0.4">${r2.name}</div>`;
      resultEl.onclick=null;
      doBtn.style.display='block';
      doBtn.disabled=true;
      doBtn.textContent='🔲 Completá el patrón';
    } else {
      resultEl.className='craft-result-cell';
      resultEl.innerHTML='<div style="font-size:24px;opacity:0.2">❓</div>';
      resultEl.onclick=null;
      doBtn.style.display='none';
    }
    this._updateCraftMaterials();
  }
  _placeCraftItem(cellIdx){
    const itemId=this._craftSelectedItem;
    if(!itemId){ this._msg('👆 Primero elegí un ítem del inventario'); return; }
    // count how many of this item already placed
    const alreadyPlaced=this._craftGrid.filter(x=>x===itemId).length;
    const have=inventory[itemId]||0;
    if(alreadyPlaced>=have){ this._msg(`❌ No tenés más ${ITEMS[itemId]?.name||itemId}`); return; }
    this._craftGrid[cellIdx]=itemId;
    this._buildCraftGrid();
    this._buildCraftInvBar();
  }
  doCraft(){
    // auto-detect matching recipe
    const r = CRAFT_RECIPES.find(recipe =>
      this._craftGrid.every((placed,i) => placed === (recipe.pattern[i]||null))
    );
    if(!r){ this._msg('❌ El patrón no coincide con ninguna receta'); return; }
    // verify real inventory
    const needed={};
    r.pattern.forEach(s=>{ if(s) needed[s]=(needed[s]||0)+1; });
    for(const [item,qty] of Object.entries(needed)){
      if((inventory[item]||0)<qty){ this._msg('❌ Faltan materiales'); return; }
    }
    // consume
    for(const [item,qty] of Object.entries(needed)) inventory[item]-=qty;
    // add result
    for(let q=0;q<r.result.qty;q++) addItem(r.result.id);
    sfx.tada();
    this._msg(`🎉 ¡${r.name} crafteada!`+(r.placeable?' Selecciónala en el inventario para colocarla':''));
    this.closeCraftPanel();
    if(!this.invOpen) this.toggleInventory();
    updateInventoryUI();
    this._hookInventoryPlaceables();
  }

