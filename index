    });

    // Título
    ctx.textAlign='center';
    ctx.font='bold 60px Arial';
    ctx.fillStyle='rgba(0,0,0,0.35)';ctx.fillText('CARTOON CAMPO',514,97);
    ctx.fillStyle='#dcfce7';
    ctx.strokeStyle='#166534';ctx.lineWidth=7;ctx.strokeText('CARTOON CAMPO',512,95);
