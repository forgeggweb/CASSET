    // Partículas de selección (reutilizamos titleParticles)
    this.titleParticles.forEach(p=>{p.life-=0.022;p.y+=p.vy*0.016;p.x+=p.vx*0.016;p.vy+=6;});
    this.titleParticles=this.titleParticles.filter(p=>p.life>0);
    this.titleParticles.forEach(p=>{
      ctx.save();ctx.globalAlpha=Math.max(0,p.life);
      ctx.font=`${p.sz}px Arial`;ctx.textAlign='center';ctx.fillText(p.t,p.x,p.y);ctx.restore();
    });

    // Footer
    ctx.fillStyle='rgba(187,247,208,0.55)';ctx.font='12px Arial';ctx.textAlign='center';
    ctx.fillText('Hacé clic para elegir tu aventurero 🌿',512,686);
  }

  /* ---- DRAW FIELD ---- */
  drawField(){
    const z=this.zoom;
    ctx.save();
    ctx.scale(z,z);
    ctx.translate(-this.cam.x,-this.cam.y);
    const cx=this.cam.x,cy=this.cam.y,t=this.t;
    const isNight=this.gameTime<360||this.gameTime>1200;
    const isDusk=this.gameTime>=1080&&this.gameTime<=1200||this.gameTime>=360&&this.gameTime<=480;
    let skyTop='#87CEEB',skyBot='#c8f5a0';
    if(isNight){skyTop='#1e1b4b';skyBot='#0f172a';}
    else if(isDusk){skyTop='#fb923c';skyBot='#fde68a';}
    const sg=ctx.createLinearGradient(cx,cy,cx,cy+400);
