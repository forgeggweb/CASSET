    ctx.fillStyle=sg;ctx.fillRect(cx,cy,1024/z,700/z);
    if(isNight){ctx.fillStyle='rgba(255,255,255,0.8)';for(let i=0;i<120;i++){const sx=i*137.5%WORLD.w,sy=i*89.3%300+cy;ctx.beginPath();ctx.arc(sx,sy,1+Math.sin(t*1.5+i)*0.5,0,Math.PI*2);ctx.fill();}}
    const dayPct=this.gameTime/(24*60);const sunX=cx+dayPct*1800,sunY=290-Math.sin(dayPct*Math.PI)*240;
    if(isNight){ctx.fillStyle='#e0e7ff';ctx.beginPath();ctx.arc(sunX,sunY,20,0,Math.PI*2);ctx.fill();ctx.fillStyle='rgba(30,27,75,0.6)';ctx.beginPath();ctx.arc(sunX+8,sunY-6,16,0,Math.PI*2);ctx.fill();}
    else{const grd=ctx.createRadialGradient(sunX,sunY,5,sunX,sunY,60);grd.addColorStop(0,'rgba(253,224,71,0.8)');grd.addColorStop(1,'rgba(253,224,71,0)');ctx.fillStyle=grd;ctx.fillRect(sunX-60,sunY-60,120,120);ctx.fillStyle='#fde047';ctx.beginPath();ctx.arc(sunX,sunY,28,0,Math.PI*2);ctx.fill();}
    if(this.weather!=='rain')ctx.fillStyle='rgba(255,255,255,0.78)';else ctx.fillStyle='rgba(180,180,200,0.7)';
    [0.1,0.3,0.5,0.7,0.9].forEach((s,i)=>{const cl=((t*25+s*WORLD.w))%WORLD.w,ch=60+i*35+cy;ctx.beginPath();ctx.arc(cl,ch,26,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(cl+24,ch-5,32,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(cl+50,ch,22,0,Math.PI*2);ctx.fill();});
    const gg=ctx.createLinearGradient(0,0,0,WORLD.h);gg.addColorStop(0,'#4ade80');gg.addColorStop(0.3,'#22c55e');gg.addColorStop(0.7,'#16a34a');gg.addColorStop(1,'#14532d');ctx.fillStyle=gg;ctx.fillRect(0,0,WORLD.w,WORLD.h);
    // === DESERT BIOME — forma orgánica con borde irregular ===
    // desertEdgeX() es función global definida arriba
    const DESERT_X = 7000; // referencia para culling
    // Dibujar forma del desierto con borde orgánico
    const dg = ctx.createLinearGradient(6200,0,WORLD.w,WORLD.h);
    dg.addColorStop(0,'#d4a855'); dg.addColorStop(0.4,'#c49040'); dg.addColorStop(0.7,'#b87c2e'); dg.addColorStop(1,'#a06820');
    ctx.fillStyle=dg;
    ctx.beginPath();
    // Borde izquierdo ondulado (de arriba a abajo)
    const YSTEP=20;
    ctx.moveTo(desertEdgeX(0), 0);
    for(let wy=0; wy<=WORLD.h; wy+=YSTEP){
      ctx.lineTo(desertEdgeX(wy), wy);
    }
    // Borde derecho (lado del mundo)
    ctx.lineTo(WORLD.w, WORLD.h);
